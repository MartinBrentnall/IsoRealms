<?xml version="1.0" encoding="UTF-8" standalone="no" ?>

<Dialog title="Spindizzy Texture Set Properties">
  <FlexibleGrid name="grid" align="top left" rows="4" columns="2">
    <Cell row="4" column="1">
      <Label>Floor Colour:</Label>
    </Cell>
    <Cell row="3" column="1">
      <Label>Wall Colour:</Label>
    </Cell>
    <Cell row="2" column="1">
      <Label>Grid Colour:</Label>
    </Cell>
    <Cell row="1" column="1">
      <Label>Detail Colour:</Label>
    </Cell>
    <Cell row="4" column="2">
      <Selectable name="floorColour"/>
    </Cell>
    <Cell row="3" column="2">
      <Selectable name="wallColour"/>
    </Cell>
    <Cell row="2" column="2">
      <Selectable name="gridColour"/>
    </Cell>
    <Cell row="1" column="2">
      <Selectable name="detailColour"/>
    </Cell>
  </FlexibleGrid>
  <Label name="previewLabel" align="left" top="below grid">Preview</Label>
  <Button name="okButton" text="OK" align="bottom right"/>
  <Button name="cancelButton" text="Cancel" align="bottom" right="leftof okButton"/>
  <Button name="undoButton" text="Undo" align="bottom" right="leftof cancelButton"/>
  <WrappingGrid name="previewPane" top="below previewLabel" bottom="above okButton"/>
</Dialog>
