    <Configuration/>
  </Plugin>
  <Plugin implementation="IntegerValueCommands" instance="TimerCommands" type="Utilities">
    <UsePlugin implementation="IntegerValue" instance="SpindizzyTimeLimit" socketid=""/>
    <Configuration>
      <Command name="IncreaseTimeForJewel" value="12000"/>
      <Command name="IncreaseTimeForZone" value="8000"/>
    </Configuration>
  </Plugin>
  <ElementSet instance="Blocks" type="SpindizzyBlocks">
    <UsePlugin implementation="CollidableSurfaceRegistry" instance="SpindizzySurfaces"/>
    <UsePlugin implementation="SpindizzyTextureSetChanger" instance="PerZone"/>
    <UsePlugin implementation="SurfaceProcessor" instance="BlockSubtractor"/>
    <Configuration>
      <State>SwitchDiamondLeft</State>
      <State>SwitchDiamondRight</State>
      <State>SwitchDiamondBoth</State>
      <State>SwitchSquareNone</State>
      <State>SwitchSquareLeft</State>
      <State>SwitchSquareRight</State>
      <State>SwitchSquareBoth</State>
      <State>SwitchCircleNone</State>
      <State>SwitchCircleLeft</State>
      <State>SwitchCircleRight</State>
      <State>SwitchCircleBoth</State>
      <BlockType name="Ice" friction="0.0" grip="0.0" bounce="0.0" respawnAllowed="false"/>
      <BlockType name="Trampoline" friction="0.0" grip="1.0" bounce="1.0" respawnAllowed="false">
        <ImpactScript>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Trampoline.ogg</Command>
        </ImpactScript>
      </BlockType>
      <BlockType name="Plain" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true"/>
      <BlockType name="ArrowWest" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true"/>
      <BlockType name="ArrowEast" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true"/>
      <BlockType name="ArrowNorth" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true"/>
      <BlockType name="ArrowNorth" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true"/>
      <BlockType name="SwitchDiamondNone" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Reset Spindizzy Switches</Command>
        </ContactScript>
      </BlockType>
      <BlockType name="SwitchDiamondLeft" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Activate switch LeftDiamondSwitch</Command>
        </ContactScript>
      </BlockType>
      <BlockType name="SwitchDiamondRight" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Activate switch RightDiamondSwitch</Command>
        </ContactScript>
      </BlockType>
      <BlockType name="SwitchDiamondBoth" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Activate switch FilledDiamondSwitch</Command>
        </ContactScript>
      </BlockType>
      <BlockType name="SwitchSquareNone" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Activate switch EmptySquareSwitch</Command>
        </ContactScript>
      </BlockType>
      <BlockType name="SwitchSquareLeft" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Activate switch LeftSquareSwitch</Command>
        </ContactScript>
      </BlockType>
      <BlockType name="SwitchSquareRight" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Activate switch RightSquareSwitch</Command>
        </ContactScript>
      </BlockType>
      <BlockType name="SwitchSquareBoth" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Activate switch FilledSquareSwitch</Command>
        </ContactScript>
      </BlockType>
      <BlockType name="SwitchCircleNone" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Activate switch EmptyCircleSwitch</Command>
        </ContactScript>
      </BlockType>
      <BlockType name="SwitchCircleLeft" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true">
