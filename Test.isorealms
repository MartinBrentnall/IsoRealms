      </ZoneExploredScript>
    </Configuration>
  </Plugin>
  <Plugin implementation="KeyCommands" instance="DebugCommands" type="Utilities">
    <Configuration>
      <Input type="key" value="1">
        <Command>Plugin/Utilities/SpindizzySwitches/Reset Spindizzy Switches</Command>
      </Input>
      <Input type="key" value="2">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch LeftDiamondSwitch</Command>
      </Input>
      <Input type="key" value="3">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch RightDiamondSwitch</Command>
      </Input>
      <Input type="key" value="4">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch FilledDiamondSwitch</Command>
      </Input>
      <Input type="key" value="5">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch EmptySquareSwitch</Command>
      </Input>
      <Input type="key" value="6">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch LeftSquareSwitch</Command>
      </Input>
      <Input type="key" value="7">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch RightSquareSwitch</Command>
      </Input>
      <Input type="key" value="8">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch FilledSquareSwitch</Command>
      </Input>
      <Input type="key" value="9">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch EmptyCircleSwitch</Command>
      </Input>
      <Input type="key" value="0">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch LeftCircleSwitch</Command>
      </Input>
      <Input type="key" value="[">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch RightCircleSwitch</Command>
      </Input>
      <Input type="key" value="]">
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch FilledCircleSwitch</Command>
      </Input>
      <Input type="key" value="m">
        <Command>Plugin/Utilities/GameSwitches/Toggle MapOverview</Command>
      </Input>
    </Configuration>
  </Plugin>
  <Plugin implementation="RandomCommand" instance="PlayLiftClick" type="Utilities">
    <Configuration>
      <Command name="LiftClick">
        <PossibleScript>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Lift Click 1.ogg</Command>
        </PossibleScript>
        <PossibleScript>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Lift Click 2.ogg</Command>
        </PossibleScript>
        <PossibleScript>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Lift Click 3.ogg</Command>
        </PossibleScript>
      </Command>
    </Configuration>
  </Plugin>
  <Plugin implementation="SoundCommandSupport" instance="SoundCommandWrapper" type="Utilities">
    <UsePlugin implementation="SoundSupport" instance="SpindizzySounds" socketid=""/>
    <Configuration/>
  </Plugin>
  <Plugin implementation="SpindizzySwitches" instance="SpindizzySwitches" type="Utilities">
    <Configuration>
      <ResetSwitch>
        <Command>Plugin/Utilities/SoundCommandWrapper/Play Diamond None.ogg</Command>
      </ResetSwitch>
      <Switch name="FilledDiamondSwitch" type="primary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Diamond Both.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts DiamondBoth</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchDiamondBoth</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts DiamondBoth</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchDiamondBoth</Command>
        </Off>
      </Switch>
      <Switch name="LeftDiamondSwitch" type="primary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Diamond Left.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts DiamondLeft</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchDiamondLeft</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts DiamondLeft</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchDiamondLeft</Command>
        </Off>
      </Switch>
      <Switch name="RightDiamondSwitch" type="primary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Diamond Right.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts DiamondRight</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchDiamondRight</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts DiamondRight</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchDiamondRight</Command>
        </Off>
      </Switch>
      <Switch name="FilledSquareSwitch" type="primary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Square Both.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts SquareBoth</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchSquareBoth</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts SquareBoth</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchSquareBoth</Command>
        </Off>
      </Switch>
      <Switch name="LeftSquareSwitch" type="primary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Square Left.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts SquareLeft</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchSquareLeft</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts SquareLeft</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchSquareLeft</Command>
        </Off>
      </Switch>
      <Switch name="RightSquareSwitch" type="primary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Square Right.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts SquareRight</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchSquareRight</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts SquareRight</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchSquareRight</Command>
        </Off>
      </Switch>
      <Switch name="EmptySquareSwitch" type="primary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Square None.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts SquareNone</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchSquareNone</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts SquareNone</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchSquareNone</Command>
        </Off>
      </Switch>
      <Switch name="FilledCircleSwitch" type="secondary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Circle Both.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts CircleBoth</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchCircleBoth</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts CircleBoth</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchCircleBoth</Command>
        </Off>
      </Switch>
      <Switch name="LeftCircleSwitch" type="secondary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Circle Left.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts CircleLeft</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchCircleLeft</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts CircleLeft</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchCircleLeft</Command>
        </Off>
      </Switch>
      <Switch name="RightCircleSwitch" type="secondary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Circle Right.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts CircleRight</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchCircleRight</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts CircleRight</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchCircleRight</Command>
        </Off>
      </Switch>
      <Switch name="EmptyCircleSwitch" type="secondary">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Circle None.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts CircleNone</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchCircleNone</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts CircleNone</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchCircleNone</Command>
        </Off>
      </Switch>
    </Configuration>
  </Plugin>
  <Plugin implementation="ToggleSwitches" instance="GameSwitches" type="Utilities">
    <Configuration>
      <Switch name="MapOverview">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Lift Click 1.ogg</Command>
        </On>
        <Off>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Lift Click 2.ogg</Command>
        </Off>
      </Switch>
    </Configuration>
  </Plugin>
