<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Project filename="IsoRealms/ProjectName">
  <InputConfiguration>
    <DigitalInput name="Brake">
      <Mapping type="keyDown" value="Space"/>
      <OnStart name="IsoRealms/playerBrake">
        <Argument name="player" type="Spindizzy/GERALD" value="Player"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Change Craft Appearance">
      <Mapping type="keyDown" value="i"/>
      <OnStart name="IsoRealms/ChangeCraft"/>
    </DigitalInput>
    <DigitalInput name="Debug Activate Empty Circle Switch">
      <Mapping type="keyDown" value="9"/>
      <OnStart name="IsoRealms/setSecondarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchCircleNone"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchCircleEmpty"/>
        <Argument name="sound" type="Sound" value="IsoRealms/CircleNone"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Empty Square Switch">
      <Mapping type="keyDown" value="5"/>
      <OnStart name="IsoRealms/setPrimarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchSquareNone"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchSquareEmpty"/>
        <Argument name="sound" type="Sound" value="IsoRealms/SquareNone"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Filled Circle Switch">
      <Mapping type="keyDown" value="]"/>
      <OnStart name="IsoRealms/setSecondarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchCircleBoth"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchCircleFilled"/>
        <Argument name="sound" type="Sound" value="IsoRealms/CircleBoth"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Filled Diamond Switch">
      <Mapping type="keyDown" value="4"/>
      <OnStart name="IsoRealms/setPrimarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchDiamondBoth"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchDiamondFilled"/>
        <Argument name="sound" type="Sound" value="IsoRealms/DiamondBoth"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Filled Square Switch">
      <Mapping type="keyDown" value="8"/>
      <OnStart name="IsoRealms/setPrimarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchSquareBoth"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchSquareFilled"/>
        <Argument name="sound" type="Sound" value="IsoRealms/SquareBoth"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Left Circle Switch">
      <Mapping type="keyDown" value="0"/>
      <OnStart name="IsoRealms/setSecondarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchCircleLeft"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchCircleLeft"/>
        <Argument name="sound" type="Sound" value="IsoRealms/CircleLeft"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Left Diamond Switch">
      <Mapping type="keyDown" value="2"/>
      <OnStart name="IsoRealms/setPrimarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchDiamondLeft"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchDiamondLeft"/>
        <Argument name="sound" type="Sound" value="IsoRealms/DiamondLeft"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Left Square Switch">
      <Mapping type="keyDown" value="6"/>
      <OnStart name="IsoRealms/setPrimarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchSquareLeft"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchSquareLeft"/>
        <Argument name="sound" type="Sound" value="IsoRealms/SquareLeft"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Right Circle Switch">
      <Mapping type="keyDown" value="["/>
      <OnStart name="IsoRealms/setSecondarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchCircleRight"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchCircleRight"/>
        <Argument name="sound" type="Sound" value="IsoRealms/CircleRight"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Right Diamond Switch">
      <Mapping type="keyDown" value="3"/>
      <OnStart name="IsoRealms/setPrimarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchDiamondRight"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchDiamondRight"/>
        <Argument name="sound" type="Sound" value="IsoRealms/DiamondRight"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Right Square Switch">
      <Mapping type="keyDown" value="7"/>
      <OnStart name="IsoRealms/setPrimarySwitch">
        <Argument name="switchState" type="Boolean" value="IsoRealms/SwitchSquareRight"/>
        <Argument name="switchIcon" type="3DModel" value="IsoRealms/SwitchSquareRight"/>
        <Argument name="sound" type="Sound" value="IsoRealms/SquareRight"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Reset Switches">
      <Mapping type="keyDown" value="1"/>
      <OnStart name="IsoRealms/resetSwitch">
        <Argument name="sound" type="Sound" value="IsoRealms/DiamondNone"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Map">
      <Mapping type="keyDown" value="m"/>
      <OnStart name="IsoRealms/toggleMapOverview"/>
    </DigitalInput>
    <DigitalInput name="Move East">
      <Mapping type="keyDown" value="ArrowRight"/>
      <Mapping type="keyDown" value="d"/>
    </DigitalInput>
    <DigitalInput name="Move North">
      <Mapping type="keyDown" value="ArrowUp"/>
      <Mapping type="keyDown" value="w"/>
    </DigitalInput>
    <DigitalInput name="Move South">
      <Mapping type="keyDown" value="ArrowDown"/>
      <Mapping type="keyDown" value="s"/>
    </DigitalInput>
    <DigitalInput name="Move West">
      <Mapping type="keyDown" value="ArrowLeft"/>
      <Mapping type="keyDown" value="a"/>
    </DigitalInput>
    <DigitalInput name="Quit">
      <Mapping type="keyDown" value="q"/>
      <OnStart name="IsoRealms/Quit"/>
    </DigitalInput>
    <DigitalInput name="Reset Camera">
      <Mapping type="keyDown" value="F1"/>
      <OnStart name="IsoRealms/rotateViewTo">
        <Argument name="angle" type="Integer" value="#-45"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Reverse Camera">
      <Mapping type="keyDown" value="F7"/>
      <OnStart name="IsoRealms/rotateViewBy">
        <Argument name="amount" type="Integer" value="#180"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Rotate Camera Left">
      <Mapping type="keyDown" value="F3"/>
      <OnStart name="IsoRealms/rotateViewBy">
        <Argument name="amount" type="Integer" value="#90"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Rotate Camera Right">
      <Mapping type="keyDown" value="F5"/>
      <OnStart name="IsoRealms/rotateViewBy">
        <Argument name="amount" type="Integer" value="#-90"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Thrust">
      <Mapping type="keyDown" value="LeftControl"/>
    </DigitalInput>
    <DigitalInput name="View Mode">
      <Mapping type="keyDown" value="F9"/>
      <OnStart name="IsoRealms/toggleRenderingMode"/>
    </DigitalInput>
  </InputConfiguration>
  <Module locks="IsoRealms/Locks" name="IsoRealms">
    <BooleanFixed name="SwitchDiamondLeft"/>
    <BooleanFixed name="SwitchDiamondRight"/>
    <BooleanFixed name="SwitchDiamondBoth"/>
    <BooleanFixed name="SwitchSquareNone"/>
    <BooleanFixed name="SwitchSquareLeft"/>
    <BooleanFixed name="SwitchSquareRight"/>
    <BooleanFixed name="SwitchSquareBoth"/>
    <BooleanFixed name="SwitchCircleNone"/>
    <BooleanFixed name="SwitchCircleLeft"/>
    <BooleanFixed name="SwitchCircleRight"/>
    <BooleanFixed name="SwitchCircleBoth"/>
    <ColourFixed alpha="1" blue="0" green="0" name="Black" red="0"/>
    <ColourFixed alpha="1" blue="1" green="1" name="White" red="1"/>
    <ColourFixed alpha="1" blue="0.203125" green="0.242188" name="Red" red="0.546875"/>
    <ColourFixed alpha="1" blue="0.777344" green="0.746094" name="Cyan" red="0.476562"/>
    <ColourFixed alpha="1" blue="0.699219" green="0.277344" name="Purple" red="0.550781"/>
    <ColourFixed alpha="1" blue="0.253906" green="0.660156" name="Green" red="0.40625"/>
    <ColourFixed alpha="1" blue="0.632812" green="0.191406" name="Blue" red="0.242188"/>
    <ColourFixed alpha="1" blue="0.441406" green="0.859375" name="Yellow" red="0.8125"/>
    <ColourFixed alpha="1" blue="0.144531" green="0.371094" name="Orange" red="0.5625"/>
    <ColourFixed alpha="1" blue="0" green="0.257812" name="Brown" red="0.339844"/>
    <ColourFixed alpha="1" blue="0.425781" green="0.464844" name="Pink" red="0.730469"/>
    <ColourFixed alpha="1" blue="0.328125" green="0.328125" name="DarkGray" red="0.328125"/>
    <ColourFixed alpha="1" blue="0.5" green="0.5" name="MediumGray" red="0.5"/>
    <ColourFixed alpha="1" blue="0.53125" green="0.914062" name="LightGreen" red="0.671875"/>
    <ColourFixed alpha="1" blue="0.851562" green="0.4375" name="LightBlue" red="0.484375"/>
    <ColourFixed alpha="1" blue="0.667969" green="0.667969" name="LightGray" red="0.667969"/>
    <FontFile detail="64" file="Data/Fonts/MenuFont.ttf" name="HUDFont"/>
    <ElementHUDModel camera="Spindizzy/Camera" model="Spindizzy/Jewel" name="JewelIcon" scale="1.000000" z="-0.600000"/>
    <ElementHUDModel model="IsoRealms/HUDIconMap" name="MapIcon" scale="1.000000"/>
    <ElementHUDModel model="IsoRealms/HUDIconScore" name="ScoreIcon" scale="1.000000"/>
    <ElementHUDModel model="IsoRealms/HUDIconTime" name="TimeIcon" scale="1.000000"/>
    <ElementHUDModel camera="Spindizzy/Camera" model="IsoRealms/Compass" name="Compass" scale="0.700000" z="-0.500000"/>
    <ElementHUDModel camera="Spindizzy/Camera" model=":Model/IsoRealms/PrimarySwitchState" name="PrimarySwitchState" scale="1.000000"/>
    <ElementHUDModel camera="Spindizzy/Camera" model=":Model/IsoRealms/SecondarySwitchState" name="SecondarySwitchState" scale="1.000000"/>
    <ElementHUDModel camera="Spindizzy/Camera" model=":Model/IsoRealms/Clue" name="Clue" scale="0.000000"/>
    <ElementHUDRoundedRectangle name="HUDPanel"/>
    <ElementHUDString font="IsoRealms/HUDFont" alignment="Right" name="ScoreDisplay" value=":Integer/IsoRealms/Score"/>
    <ElementHUDString font="IsoRealms/HUDFont" alignment="Left" name="TimeDisplay" value="IsoRealms/SpindizzyTimeLimit"/>
    <ElementHUDString font="IsoRealms/HUDFont" alignment="Left" name="ZonesToExploreDisplay" value=":Integer/IsoRealms/ZonesToExplore"/>
    <ElementHUDString font="IsoRealms/HUDFont" alignment="Right" name="JewelCountDisplay" value=":Integer/IsoRealms/Collected"/>
    <IntegerFixed name="Score"/>
    <IntegerFixed name="ZonesToExplore"/>
    <IntegerFixed name="Collected"/>
    <IntegerFixed name="Locks"/>
    <IntegerTimer name="SpindizzyTimeLimit" value="150000"/>
    <LayerHUD name="HUD"/>
    <ModelElement name="Compass">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/ArrowNorth" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueDiamondLeft">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchDiamondLeft" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueDiamondRight">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchDiamondRight" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueDiamondBoth">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchDiamondBoth" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueCircleNone">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchCircleNone" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueCircleLeft">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchCircleLeft" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueCircleRight">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchCircleRight" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueCircleBoth">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchCircleBoth" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueSquareNone">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchSquareNone" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueSquareLeft">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchSquareLeft" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueSquareRight">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchSquareRight" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ClueSquareBoth">
      <Element behaviour="dynamic" height="1" length="1" type="Spindizzy/SwitchSquareBoth" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelElement name="ThemeModelIcon">
      <Element height="1" length="1" type="Spindizzy/Plain" width="1" x="0" y="0" z="0"/>
    </ModelElement>
    <ModelScriptable name="ModelScriptable">
      <Instance name="PrimarySwitchState"/>
      <Instance name="SecondarySwitchState"/>
      <Instance name="Clue"/>
    </ModelScriptable>
    <ModelCycleable name="CraftEnemy">
      <Model name="Spindizzy/CraftPyramidEnemy"/>
      <Model name="IsoRealms/CraftBall"/>
      <Model name="Spindizzy/CraftGyroscopeEnemy"/>
    </ModelCycleable>
    <ModelCycleable name="CraftPlayer">
      <Model name="Spindizzy/CraftPyramidPlayer"/>
      <Model name="IsoRealms/CraftBall"/>
      <Model name="Spindizzy/CraftGyroscopePlayer"/>
    </ModelCycleable>
    <ModelSprite applyCameraRotation="true" applyCameraTilt="true" camera="Spindizzy/Camera" name="CraftBall" offsetRotation="90.000000" offsetZ="0.330000" size="0.660000" texture="Spindizzy/Ball"/>
    <ModelSprite name="HUDIconMap" size="1.000000" texture="IsoRealms/Map"/>
    <ModelSprite name="HUDIconScore" size="1.000000" texture="IsoRealms/Score"/>
    <ModelSprite name="HUDIconTime" size="1.000000" texture="IsoRealms/Time"/>
    <ModelSprite name="LiftDiamondEmpty" size="1.450000" texture="Spindizzy/C64Sprites_LiftDiamondEmpty"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="LiftDiamondLeft" offsetRotation="-45.000000" rotate="Reverse" size="1.450000" texture="Spindizzy/C64Sprites_LiftDiamondOne"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="LiftDiamondRight" offsetRotation="-45.000000" size="1.450000" texture="Spindizzy/C64Sprites_LiftDiamondOne"/>
    <ModelSprite name="LiftDiamondFilled" size="1.450000" texture="Spindizzy/C64Sprites_LiftDiamondFilled"/>
    <ModelSprite name="LiftSquareEmpty" size="1.000000" texture="Spindizzy/C64Sprites_LiftSquareEmpty"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="LiftSquareLeft" offsetRotation="-45.000000" size="1.000000" texture="Spindizzy/C64Sprites_LiftSquareOne"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="LiftSquareRight" offsetRotation="-45.000000" rotate="Reverse" size="1.000000" texture="Spindizzy/C64Sprites_LiftSquareOne"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="LiftSquareFilled" offsetRotation="-45.000000" size="1.000000" texture="Spindizzy/C64Sprites_LiftSquareFilled"/>
    <ModelSprite name="LiftCircleEmpty" size="1.300000" texture="Spindizzy/C64Sprites_LiftCircleEmpty"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="LiftCircleLeft" offsetRotation="-45.000000" rotate="Reverse" size="1.300000" texture="Spindizzy/C64Sprites_LiftCircleOne"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="LiftCircleRight" offsetRotation="-45.000000" size="1.300000" texture="Spindizzy/C64Sprites_LiftCircleOne"/>
    <ModelSprite name="LiftCircleFilled" size="1.300000" texture="Spindizzy/C64Sprites_LiftCircleFilled"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="SwitchDiamondLeft" offsetRotation="-45.000000" rotate="Reverse" size="1.087500" texture="Spindizzy/C64HUDSprites_LiftDiamondOne"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="SwitchDiamondRight" offsetRotation="-45.000000" size="1.087500" texture="Spindizzy/C64HUDSprites_LiftDiamondOne"/>
    <ModelSprite name="SwitchDiamondFilled" size="1.087500" texture="Spindizzy/C64HUDSprites_LiftDiamondFilled"/>
    <ModelSprite name="SwitchSquareEmpty" size="0.750000" texture="Spindizzy/C64HUDSprites_LiftSquareEmpty"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="SwitchSquareLeft" offsetRotation="-45.000000" size="0.750000" texture="Spindizzy/C64HUDSprites_LiftSquareOne"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="SwitchSquareRight" offsetRotation="-45.000000" rotate="Reverse" size="0.750000" texture="Spindizzy/C64HUDSprites_LiftSquareOne"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="SwitchSquareFilled" offsetRotation="-45.000000" size="0.750000" texture="Spindizzy/C64HUDSprites_LiftSquareFilled"/>
    <ModelSprite name="SwitchCircleEmpty" size="0.975000" texture="Spindizzy/C64HUDSprites_LiftCircleEmpty"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="SwitchCircleLeft" offsetRotation="-45.000000" rotate="Reverse" size="0.975000" texture="Spindizzy/C64HUDSprites_LiftCircleOne"/>
    <ModelSprite applyCameraRotation="true" camera="Spindizzy/Camera" name="SwitchCircleRight" offsetRotation="-45.000000" size="0.975000" texture="Spindizzy/C64HUDSprites_LiftCircleOne"/>
    <ModelSprite name="SwitchCircleFilled" size="0.975000" texture="Spindizzy/C64HUDSprites_LiftCircleFilled"/>
    <ScriptLua name="ChangeCraft">
      <Argument name="playerCraftModels" type="IsoRealms/ModelSetCycleable" value="CraftPlayer"/>
      <Argument name="enemyCraftModels" type="IsoRealms/ModelSetCycleable" value="CraftEnemy"/>
      <Code>playerCraftModels:next()
enemyCraftModels:next()</Code>
    </ScriptLua>
    <ScriptLua name="jewelCollected">
      <Argument name="sound" type="Sound" value="IsoRealms/Jewel"/>
      <Argument name="score" type="Integer" value="IsoRealms/Score"/>
      <Argument name="time" type="Integer" value="IsoRealms/SpindizzyTimeLimit"/>
      <Argument name="jewelHandler" type="Spindizzy/ItemHandler" value="ItemHandler"/>
      <Argument name="jewelsCollected" type="Integer" value="IsoRealms/Collected"/>
      <Argument name="zone" type="Spindizzy/Zone" value="Zone"/>
      <Code>sound:play()
jewelsCollected = jewelsCollected + 1
score = score + 600
time = time + 12000
if time &gt; 180000 then
  local excess = time - 180000
  local extraScore = excess / 10
  score = score + extraScore
  time = 180000
end
count = jewelHandler:getCount()
if count == 0 then
  zone:setFlag(false)
end</Code>
    </ScriptLua>
    <ScriptLua name="playSound">
      <Argument name="sound" type="Sound"/>
      <Code>sound:play()</Code>
    </ScriptLua>
    <ScriptLua name="playerBrake">
      <Argument name="player" type="Spindizzy/GERALD"/>
      <Argument name="time" type="Integer" value="IsoRealms/SpindizzyTimeLimit"/>
      <Code>player:stop()
time = time - 500</Code>
    </ScriptLua>
    <ScriptLua name="playerFallImpact">
      <Argument name="player" type="Spindizzy/GERALD"/>
      <Argument name="fallDistance" type="Float"/>
      <Argument name="sound" type="Sound" value="IsoRealms/ImpactHard"/>
      <Code>if fallDistance &gt; 2.75 then
  player:destroy()
  sound:play()
end</Code>
    </ScriptLua>
    <ScriptLua name="Quit">
      <Argument name="project" type="Project" value="Project"/>
      <Code>project:finish()</Code>
    </ScriptLua>
    <ScriptLua name="randomClick">
      <Argument name="click1" type="Sound" value="IsoRealms/LiftClick1"/>
      <Argument name="click2" type="Sound" value="IsoRealms/LiftClick2"/>
      <Argument name="click3" type="Sound" value="IsoRealms/LiftClick3"/>
      <Code>local val = math.random(0,2)
if val == 0 then
  click1:play()
elseif val == 1 then
  click2:play()
elseif val == 2 then
  click3:play()
end</Code>
    </ScriptLua>
    <ScriptLua name="resetSwitch">
      <Argument name="sound" type="Sound"/>
      <Argument name="switchIconPrimary" type="IsoRealms/ModelScriptable" value="PrimarySwitchState"/>
      <Argument name="switchIconSecondary" type="IsoRealms/ModelScriptable" value="SecondarySwitchState"/>
      <Argument name="clueIcon" type="IsoRealms/ModelScriptable" value="Clue"/>
      <Argument name="terrainHandler" type="Spindizzy/SpindizzyBlockHandler" value="SpindizzyBlockHandler"/>
      <Code>if activeSwitchA ~= nil then
  sound:play()
  nextSwitch = 0
  activeSwitchA:setValue(false)
  switchIconPrimary:setModel(nil)
  activeSwitchA = nil
  if activeSwitchB ~= nil then
    activeSwitchB:setValue(false)
    switchIconSecondary:setModel(nil)
    activeSwitchB = nil
  end
end
if terrainHandler ~= nil then
  local clueCount = terrainHandler:getClueCount()
  if clueCount &gt; 0 then
    local clueModel = terrainHandler:getClue(0)
    clueIcon:setModel(clueModel)
  else
    clueIcon:setModel(nil)
  end
end</Code>
    </ScriptLua>
    <ScriptLua name="respawn">
      <Argument name="time" type="Integer" value="IsoRealms/SpindizzyTimeLimit"/>
      <Code>time = time - 10000
if time &lt; 0 then
  time = 0
end</Code>
    </ScriptLua>
    <ScriptLua name="rotateViewBy">
      <Argument name="amount" type="Integer"/>
      <Argument name="camera" type="Spindizzy/Camera" value="Camera"/>
      <Code>if mapOverviewMode == 0 and mapTrasition == 0 then
  camera:changeAngleRelative(amount)
  camera:startTransition()
end</Code>
    </ScriptLua>
    <ScriptLua name="rotateViewTo">
      <Argument name="angle" type="Integer"/>
      <Argument name="camera" type="Spindizzy/Camera" value="Camera"/>
      <Code>if mapOverviewMode == 0 and mapTrasition == 0 then
  camera:changeAngle(angle)
  camera:startTransition()
end</Code>
    </ScriptLua>
    <ScriptLua name="setPrimarySwitch">
      <Argument name="switchState" type="Boolean"/>
      <Argument name="switchIcon" type="3DModel"/>
      <Argument name="sound" type="Sound"/>
      <Argument name="switchIconPrimary" type="IsoRealms/ModelScriptable" value="PrimarySwitchState"/>
      <Argument name="switchIconSecondary" type="IsoRealms/ModelScriptable" value="SecondarySwitchState"/>
      <Argument name="clueIcon" type="IsoRealms/ModelScriptable" value="Clue"/>
      <Argument name="terrainHandler" type="Spindizzy/SpindizzyBlockHandler" value="SpindizzyBlockHandler"/>
      <Code>if activeSwitchA ~= _switchState or activeSwitchB ~= nil then
  sound:play()
  nextSwitch = 1
  if activeSwitchA ~= nil then
    activeSwitchA:setValue(false)
  end
  if activeSwitchB ~= nil then
    activeSwitchB:setValue(false)
    switchIconSecondary:setModel(nil)
    activeSwitchB = nil 
  end
  switchState = true
  -- TODO: The following line shouldn't be here!
  _switchState:setValue(true)
  switchIconPrimary:setModel(switchIcon)
  activeSwitchA = _switchState;
end
if terrainHandler ~= nil then
  local clueCount = terrainHandler:getClueCount()
  if clueCount &gt; 0 then
    local clueModel = terrainHandler:getClue(0)
    clueIcon:setModel(clueModel)
  else
    clueIcon:setModel(nil)
  end
end</Code>
    </ScriptLua>
    <ScriptLua name="setSecondarySwitch">
      <Argument name="switchState" type="Boolean"/>
      <Argument name="switchIcon" type="3DModel"/>
      <Argument name="sound" type="Sound"/>
      <Argument name="switchIconPrimary" type="IsoRealms/ModelScriptable" value="PrimarySwitchState"/>
      <Argument name="switchIconSecondary" type="IsoRealms/ModelScriptable" value="SecondarySwitchState"/>
      <Argument name="clueIcon" type="IsoRealms/ModelScriptable" value="Clue"/>
      <Argument name="terrainHandler" type="Spindizzy/SpindizzyBlockHandler" value="SpindizzyBlockHandler"/>
      <Code>if activeSwitchA ~= _switchState and activeSwitchB ~= _switchState then
  sound:play()
  if nextSwitch == 1 then
    if activeSwitchB ~= nil then
      activeSwitchB:setValue(false)
    end
    activeSwitchB = _switchState
    switchIconSecondary:setModel(switchIcon)
    nextSwitch = 0
  else
    if activeSwitchA ~= nil then
      activeSwitchA:setValue(false)
    end
    activeSwitchA = _switchState
    switchIconPrimary:setModel(switchIcon)
    nextSwitch = 1
  end
  switchState = true
  -- TODO: The following line shouldn't be here!
  _switchState:setValue(true)
end
if terrainHandler ~= nil then
  local clueCount = terrainHandler:getClueCount()
  if clueCount &gt; 0 then
    local clueModel = terrainHandler:getClue(0)
    clueIcon:setModel(clueModel)
  else
    clueIcon:setModel(nil)
  end
end</Code>
    </ScriptLua>
    <ScriptLua name="spindizzyInit">
      <Argument name="zoneCount" type="Integer" value="IsoRealms/ZonesToExplore"/>
      <Argument name="spindizzy" type="Spindizzy/Spindizzy" value="Spindizzy"/>
      <Argument name="player" type="Spindizzy/GERALD" value="Player"/>
      <Code>zoneCount = spindizzy:getZoneCount()
mapOverviewMode = 0
mapTrasition = 0
classicMode = true
universe = player:getUniverse()
spindizzy:setActiveUniverse(universe)</Code>
    </ScriptLua>
    <ScriptLua name="switchToGameplay">
      <Argument name="locks" type="Integer" value="IsoRealms/Locks"/>
      <Argument name="map" type="Spindizzy/Map" value="Hangworld"/>
      <Argument name="spindizzy" type="Spindizzy/Spindizzy" value="Spindizzy"/>
      <Code>if mapOverviewMode == 0 and mapTrasition == 1 then
  locks = locks - 1
  mapTrasition = 0
  spindizzy:setOverview(false)
end</Code>
    </ScriptLua>
    <ScriptLua name="toggleMapOverview">
      <Argument name="locks" type="Integer" value="IsoRealms/Locks"/>
      <Argument name="camera" type="Spindizzy/Camera" value="Camera"/>
      <Argument name="map" type="Spindizzy/Map" value="Hangworld"/>
      <Argument name="spindizzy" type="Spindizzy/Spindizzy" value="Spindizzy"/>
      <Code>if mapOverviewMode == 1 then
  camera:changeAngle(oldAngle)
  camera:changeTilt(oldTilt)
  camera:changeZoom(oldZoom)
  camera:changeLocation(oldLocation)
  mapOverviewMode = 0
  mapTrasition = 1
else
  oldAngle = camera:getAngle()
  oldTilt = camera:getTilt()
  oldZoom = camera:getZoom()
  oldLocation = camera:getLocation()
  mapEast = map:getEast()
  mapWest = map:getWest()
  mapNorth = map:getNorth()
  mapSouth = map:getSouth()
  mapTop = map:getTop()
  mapBottom = map:getBottom()
  aspectRation = map:getAspectRatio()
  mapSizeX = mapEast - mapWest;
  mapSizeY = mapNorth - mapSouth;
  mapSizeX = mapSizeX * aspectRation;
  if mapSizeX &gt; mapSizeY then
    mapSize = mapSizeX
  else
    mapSize = mapSizeY
  end
  mapSize = mapSize / 1.98
  centerX = mapWest + (mapEast - mapWest) / 2.0
  centerY = mapNorth + (mapSouth - mapNorth) / 2.0
  centerZ = mapTop + (mapBottom - mapTop) / 2.0
  camera:changeAngle(0)
  camera:changeTilt(0)
  camera:changeZoom(mapSize)
  camera:changeLocationFixed(centerX, centerY, centerZ)
  spindizzy:setOverview(true)
  if mapTrasition ~= 1 then
    locks = locks + 1
--     map:setZoneHandler(mapHandler)
  end
  mapOverviewMode = 1
end
camera:startTransition()</Code>
    </ScriptLua>
    <ScriptLua name="toggleRenderingMode">
      <Argument name="zoneHandler" type="Spindizzy/ZoneHandler" value="ZoneHandler"/>
      <Argument name="camera" type="Spindizzy/Camera" value="Camera"/>
      <Argument name="zoneLocation" type="Vertex" value="IsoRealms/ZoneLocation"/>
      <Argument name="playerLocation" type="Vertex" value="Spindizzy/Player"/>
      <Argument name="background" type="Spindizzy/Background" value="Background"/>
      <Code>if mapOverviewMode == 0 and mapTrasition == 0 then
  if classicMode == true then
    zoneHandler:setSingleZone(false)
    camera:changeLocation(playerLocation)
    background:setChangeSpeed(0.0025)
    classicMode = false
  else
    zoneHandler:setSingleZone(true)
    camera:changeLocation(zoneLocation)
    background:setChangeSpeed(1.0)
    classicMode = true
  end
  camera:startTransition()
end</Code>
    </ScriptLua>
    <ScriptLua name="zoneEntered">
      <Argument name="score" type="Integer" value="IsoRealms/Score"/>
      <Argument name="time" type="Integer" value="IsoRealms/SpindizzyTimeLimit"/>
      <Argument name="zoneCount" type="Integer" value="IsoRealms/ZonesToExplore"/>
      <Argument name="zoneHandler" type="Spindizzy/ZoneHandler" value="ZoneHandler"/>
      <Argument name="jewelHandler" type="Spindizzy/ItemHandler" value="ItemHandler"/>
      <Argument name="background" type="Spindizzy/Background" value="Background"/>
      <Argument name="zoneBackgroundColour" type="Spindizzy/ThemeColour" value="Background"/>
      <Argument name="entered" type="Spindizzy/Zone"/>
      <Argument name="dynamicElements" type="Spindizzy/DynamicElements" value="DynamicElements"/>
      <Argument name="zoneLocation" type="IsoRealms/Vertex" value="ZoneLocation"/>
      <Argument name="clueIcon" type="IsoRealms/ModelScriptable" value="Clue"/>
      <Argument name="terrainHandler" type="Spindizzy/SpindizzyBlockHandler" value="SpindizzyBlockHandler"/>
      <Argument name="spindizzy" type="Spindizzy/Spindizzy" value="Spindizzy"/>
      <Code>if terrainHandler ~= nil then
  local clueCount = terrainHandler:getClueCount()
  if clueCount &gt; 0 then
    local clueModel = terrainHandler:getClue(0)
    clueIcon:setModel(clueModel)
  else
    clueIcon:setModel(nil)
  end
end
if entered:isVisited() == false then
  score = score + 400
  if jewelHandler ~= nil then
    entered:setFlag(true)
  end
  time = time + 8000
  if time &gt; 180000 then
    local excess = time - 180000
    local extraScore = excess / 10
    score = score + extraScore
    time = 180000
  end
  zoneCount = zoneCount - 1
  entered:setVisited()        
end
zoneEast = entered:getEast()
zoneWest = entered:getWest()
zoneNorth = entered:getNorth()
zoneSouth = entered:getSouth()
zoneTop = entered:getTop()
zoneBottom = entered:getBottom()
centerX = zoneWest + (zoneEast - zoneWest) / 2.0
centerY = zoneNorth + (zoneSouth - zoneNorth) / 2.0
centerZ = (zoneTop + (zoneBottom - zoneTop) / 2.0) + 1.5
zoneLocation:setX(centerX)
zoneLocation:setY(centerY)
zoneLocation:setZ(centerZ)
backgroundColour = entered:getColour(zoneBackgroundColour)
background:setColour(backgroundColour)
zoneHandler:setCurrentZone(entered)
theme = entered:getTheme()
spindizzy:setTheme(theme)
changeMusicScript = entered:getScriptCall("changeMusic")
if changeMusicScript ~= nil then
  changeMusicScript:execute()
end
if dynamicElements ~= nil then
  dynamicElements:setActive(true)
  dynamicElements:reset()
end</Code>
    </ScriptLua>
    <ScriptLua name="zoneExited">
      <Argument name="dynamicElements" type="Spindizzy/DynamicElements" value="DynamicElements"/>
      <Code>if dynamicElements ~= nil then
  dynamicElements:setActive(false)
end</Code>
    </ScriptLua>
