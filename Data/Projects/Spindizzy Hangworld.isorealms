  </Plugin>
  <Plugin name="ZoneCollectables">
    <Resources>
      <Collectables name="Jewels" map="HangWorld">
        <CollectedScript name="jewelCollected">
          <Argument name="jewelsInZone" type="Integer" value="~zoneRemaining"/>
          <Argument name="zone" type="Zone" value="~zone"/>
        </CollectedScript>
      </Collectables>
    </Resources>
