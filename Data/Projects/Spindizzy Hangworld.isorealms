    <UsePlugin implementation="Camera" instance="CraftCamera" socketid=""/>
    <UsePlugin implementation="HUD" instance="SpindizzyHUD" socketid=""/>
    <Configuration>
      <ResetSwitch>
        <Command>Plugin/Utilities/SoundCommandWrapper/Play Diamond None.ogg</Command>
      </ResetSwitch>
      <Switch name="FilledDiamondSwitch" type="primary" HUDModel="2">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Diamond Both.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts DiamondFilled</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchDiamondBoth</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts DiamondFilled</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchDiamondBoth</Command>
        </Off>
      </Switch>
      <Switch name="LeftDiamondSwitch" type="primary" HUDModel="0">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Diamond Left.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts DiamondLeft</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchDiamondLeft</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts DiamondLeft</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchDiamondLeft</Command>
        </Off>
      </Switch>
      <Switch name="RightDiamondSwitch" type="primary" HUDModel="1">
        <On>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Diamond Right.ogg</Command>
          <Command>ElementSet/Lifts/Enable Lifts DiamondRight</Command>
          <Command>ElementSet/Blocks/Set Block Flag SwitchDiamondRight</Command>
        </On>
        <Off>
          <Command>ElementSet/Lifts/Disable Lifts DiamondRight</Command>
          <Command>ElementSet/Blocks/Unset Block Flag SwitchDiamondRight</Command>
        </Off>
      </Switch>
      <Switch name="FilledSquareSwitch" type="primary" HUDModel="6">
