<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Project>
  <Script name="jewelCollected">
    <Argument name="sound" type="Sound" value="SDLMixerSupport/Jewel.ogg"/>
    <Argument name="score" type="Integer" value="DumbIntegerValue/Score"/>
    <Argument name="time" type="Integer" value="TimeLimit/SpindizzyTimeLimit"/>
    <Argument name="jewelsInZone" type="Integer"/>
    <Argument name="zone" type="Zone"/>
    <Argument name="mapOverviewMap" type="MappedZoneHandler/Handler" value="MapOverview"/>
    <Argument name="jewelToCollectIcon" type="ZoneHandler" value="ZoneModelRenderer/UncollectedJewels"/>
    <Code>  sound:play()
  score = score + 600
  time = time + 12000
  if time &gt; 180000 then
    local excess = time - 180000
    local extraScore = excess / 10
    score = score + extraScore
    time = 180000
  end
  if jewelsInZone == 0 then
    mapOverviewMap:removeHandler(zone, jewelToCollectIcon)    
  end</Code>
  </Script>
  <Script name="playSound">
    <Argument name="sound" type="Sound"/>
    <Code>  sound:play()</Code>
  </Script>
  <Script name="playerBrake">
    <Argument name="player" type="SpindizzyGERALD/GERALD"/>
    <Argument name="time" type="Integer" value="TimeLimit/SpindizzyTimeLimit"/>
    <Code>  player:stop()
  time = time - 500</Code>
  </Script>
  <Script name="playerFallImpact">
    <Argument name="player" type="SpindizzyGERALD/GERALD"/>
    <Argument name="fallDistance" type="Float"/>
    <Argument name="sound" type="Sound" value="SDLMixerSupport/Impact Hard.ogg"/>
    <Code>  if fallDistance &gt; 2.75 then
    player:destroy()
    sound:play()
  end</Code>
  </Script>
  <Script name="randomClick">
    <Argument name="click1" type="Sound" value="SDLMixerSupport/Lift Click 1.ogg"/>
    <Argument name="click2" type="Sound" value="SDLMixerSupport/Lift Click 2.ogg"/>
    <Argument name="click3" type="Sound" value="SDLMixerSupport/Lift Click 3.ogg"/>
    <Code>  local val = math.random(0,2)
  if val == 0 then
    click1:play()
  elseif val == 1 then
    click2:play()
  elseif val == 2 then
    click3:play()
  end</Code>
  </Script>
  <Script name="resetSwitch">
    <Argument name="sound" type="Sound"/>
    <Code>  if activeLiftA ~= nil then
    sound:play()
    nextSwitch = 0
    activeLiftA:setActive(false)
    blockStateA:setActive(false)
    activeSwitchA:setModel(nil)
    activeLiftA = nil
    blockStateA = nil
  end
  if activeLiftB ~= nil then
    activeLiftB:setActive(false)
    blockStateB:setActive(false)
    activeSwitchB:setModel(nil)
    activeLiftB = nil
    blockStateB = nil
  end</Code>
  </Script>
  <Script name="respawn">
    <Argument name="time" type="Integer" value="TimeLimit/SpindizzyTimeLimit"/>
    <Code>  time = time - 10000
  if time &lt; 0 then
    time = 0
  end</Code>
  </Script>
  <Script name="rotateViewBy">
    <Argument name="amount" type="Integer"/>
    <Argument name="camera" type="SpindizzyCamera/Camera" value="Camera"/>
    <Code>  if mapOverviewMode == 0 and mapTrasition == 0 then
    camera:changeAngleRelative(amount)
    camera:startTransition()
  end</Code>
  </Script>
  <Script name="rotateViewTo">
    <Argument name="angle" type="Integer"/>
    <Argument name="camera" type="SpindizzyCamera/Camera" value="Camera"/>
    <Code>    if mapOverviewMode == 0 and mapTrasition == 0 then
    camera:changeAngle(angle)
    camera:startTransition()
  end</Code>
  </Script>
  <Script name="setPrimarySwitch">
    <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType"/>
    <Argument name="blockState" type="SpindizzyBlocks/BlockState"/>
    <Argument name="switchIcon" type="3DModel"/>
    <Argument name="sound" type="Sound"/>
    <Code>  if activeLiftA ~= lift or activeLiftB ~= nil then
    sound:play()
    nextSwitch = 1
    if activeLiftA ~= nil then
      activeLiftA:setActive(false)
      blockStateA:setActive(false)
    end
    if activeLiftB ~= nil then
      activeLiftB:setActive(false)
      blockStateB:setActive(false)
      activeSwitchB:setModel(nil)
      activeLiftB = nil
      blockStateB = nil
    end
    lift:setActive(true)
    blockState:setActive(true)
    activeSwitchA:setModel(switchIcon)
    activeLiftA = lift
    blockStateA = blockState
  end</Code>
  </Script>
  <Script name="setSecondarySwitch">
    <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType"/>
    <Argument name="blockState" type="SpindizzyBlocks/BlockState"/>
    <Argument name="switchIcon" type="3DModel"/>
    <Argument name="sound" type="Sound"/>
    <Code>  if activeLiftA ~= lift and activeLiftB ~= lift then
    sound:play()
    if nextSwitch == 1 then
      if activeLiftB ~= nil then
        activeLiftB:setActive(false)
        blockStateB:setActive(false)
      end
      activeLiftB = lift
      blockStateB = blockState
      activeSwitchB:setModel(switchIcon)
      nextSwitch = 0
    else
      if activeLiftA ~= nil then
        activeLiftA:setActive(false)
        blockStateA:setActive(false)
      end
      activeLiftA = lift
      blockStateA = blockState
      activeSwitchA:setModel(switchIcon)
      nextSwitch = 1
    end
    lift:setActive(true)
    blockState:setActive(true)
  end</Code>
  </Script>
  <Script name="spindizzyInit">
    <Argument name="gamePlayHandler" type="ZoneHandler" value="MappedZoneHandler/ExploredZones"/>
    <Argument name="zoneCount" type="Integer" value="DumbIntegerValue/ZonesToExplore"/>
    <Argument name="map" type="Map" value="HangWorld"/>
    <Code>  zoneCount = map:getZoneCount()
  mapOverviewMode = 0
  mapTrasition = 0
  currentHandler = gamePlayHandler</Code>
  </Script>
  <Script name="switchToGameplay">
    <Argument name="liftModule" type="SpindizzyLifts/Module" value="Module"/>
    <Argument name="geraldModule" type="SpindizzyGERALD/Module" value="Module"/>
    <Argument name="enemyModule" type="SpindizzyEnemies/Module" value="Module"/>
    <Argument name="timeModule" type="TimeLimit/Module" value="Module"/>
    <Argument name="map" type="Map" value="HangWorld"/>
    <Code>  if mapOverviewMode == 0 and mapTrasition == 1 then
    liftModule:removeLock()
    timeModule:removeLock()
    geraldModule:removeLock()
    enemyModule:removeLock()
    map:setZoneHandler(currentHandler)
    mapTrasition = 0
  end</Code>
  </Script>
  <Script name="toggleMapOverview">
    <Argument name="camera" type="SpindizzyCamera/Camera" value="Camera"/>
    <Argument name="liftModule" type="SpindizzyLifts/Module" value="Module"/>
    <Argument name="geraldModule" type="SpindizzyGERALD/Module" value="Module"/>
    <Argument name="enemyModule" type="SpindizzyEnemies/Module" value="Module"/>
    <Argument name="timeModule" type="TimeLimit/Module" value="Module"/>
    <Argument name="map" type="Map" value="HangWorld"/>
    <Argument name="gamePlayHandler" type="ZoneHandler" value="MappedZoneHandler/ExploredZones"/>
    <Argument name="mapHandler" type="ZoneHandler" value="MappedZoneHandler/MapOverview"/>
    <Code>  if mapOverviewMode == 1 then
    camera:changeAngle(oldAngle)
    camera:changeTilt(oldTilt)
    camera:changeZoom(oldZoom)
    camera:changeLocation(oldLocation)
    mapOverviewMode = 0
    mapTrasition = 1
  else
    oldAngle = camera:getAngle()
    oldTilt = camera:getTilt()
    oldZoom = camera:getZoom()
    print ("map dimensions")
    oldLocation = camera:getLocation()
    zoneCount = map:getZoneCount()
    print ("Zone Count:")
    print (zoneCount)
    mapEast = map:getEast()
    mapWest = map:getWest()
    mapNorth = map:getNorth()
    mapSouth = map:getSouth()
    mapTop = map:getTop()
    mapBottom = map:getBottom()
    aspectRation = map:getAspectRatio()
    mapSizeX = mapEast - mapWest;
    mapSizeY = mapNorth - mapSouth;
    mapSizeX = mapSizeX * aspectRation;
    if mapSizeX &gt; mapSizeY then
      mapSize = mapSizeX
    else
      mapSize = mapSizeY
    end
    mapSize = mapSize / 1.98
    centerX = mapWest + (mapEast - mapWest) / 2.0
    centerY = mapNorth + (mapSouth - mapNorth) / 2.0
    centerZ = mapTop + (mapBottom - mapTop) / 2.0
    camera:changeAngle(0)
    camera:changeTilt(0)
    camera:changeZoom(mapSize)
    camera:changeLocationFixed(centerX, centerY, centerZ)
    print ("Step 10")
    if mapTrasition ~= 1 then
      liftModule:addLock()
      timeModule:addLock()
      geraldModule:addLock()
      enemyModule:addLock()
      map:setZoneHandler(mapHandler)
    end
    mapOverviewMode = 1
  end
  camera:startTransition()</Code>
  </Script>
  <Script name="toggleRenderingMode">
    <Argument name="map" type="Map" value="HangWorld"/>
    <Argument name="gamePlayHandler" type="ZoneHandler" value="MappedZoneHandler/ExploredZones"/>
    <Argument name="classicHandler" type="ZoneHandler" value="MappedZoneHandler/SingleZone"/>
    <Argument name="camera" type="SpindizzyCamera/Camera" value="Camera"/>
    <Argument name="zoneLocation" type="Vertex" value="ScriptableVertex/ZoneLocation"/>
    <Argument name="playerLocation" type="Vertex" value="SpindizzyGERALD/Player"/>
    <Argument name="background" type="TextureSetPerZone/ColouredBackground" value="Background"/>
    <Code>  if mapOverviewMode == 0 and mapTrasition == 0 then
    if classicMode == 1 then
      print("Switching to modern mode")
      map:setZoneHandler(gamePlayHandler)
      currentHandler = gamePlayHandler
      camera:changeLocation(playerLocation)
      classicMode = 0
      background:setChangeSpeed(0.0025)
    else
      print("Switching to classic mode")
      map:setZoneHandler(classicHandler)
      currentHandler = classicHandler
      camera:changeLocation(zoneLocation)
      classicMode = 1
      background:setChangeSpeed(1.0)
    end
    camera:startTransition()
  end</Code>
  </Script>
  <Script name="zoneEntered">
    <Argument name="score" type="Integer" value="DumbIntegerValue/Score"/>
    <Argument name="time" type="Integer" value="TimeLimit/SpindizzyTimeLimit"/>
    <Argument name="zoneCount" type="Integer" value="DumbIntegerValue/ZonesToExplore"/>
    <Argument name="exploredZonesMap" type="MappedZoneHandler/Handler" value="ExploredZones"/>
    <Argument name="mapOverviewMap" type="MappedZoneHandler/Handler" value="MapOverview"/>
    <Argument name="classicHandler" type="MappedZoneHandler/Handler" value="SingleZone"/>
    <Argument name="background" type="TextureSetPerZone/ColouredBackground" value="Background"/>
    <Argument name="themedZones" type="TextureSetPerZone/ThemedZones" value="ThemedZones"/>
    <Argument name="themeColour" type="TextureSetPerZone/ThemeColour" value="Background"/>
    <Argument name="entered" type="Zone"/>
    <Argument name="defaultZoneHandler" type="ZoneHandler" value="!default"/>
    <Argument name="currentZoneOutline" type="ZoneHandler" value="ZoneOutlineRenderer/CurrentZone"/>
    <Argument name="unexploredZoneOutline" type="ZoneHandler" value="ZoneOutlineRenderer/UnexploredZones"/>
    <Argument name="exploredZoneOutline" type="ZoneHandler" value="ZoneOutlineRenderer/ExploredZones"/>
    <Argument name="jewelToCollectIcon" type="ZoneHandler" value="ZoneModelRenderer/UncollectedJewels"/>
    <Argument name="dynamicElementGroups" type="DynamicElementGroup/Type" value="Zones"/>
    <Argument name="liftModule" type="SpindizzyLifts/Module" value="Module"/>
    <Argument name="enemyModule" type="SpindizzyEnemies/Module" value="Module"/>
    <Argument name="collectables" type="ZoneCollectables/ZoneCollectables" value="Jewels"/>
    <Argument name="zoneLocation" type="ScriptableVertex/Vertex" value="ZoneLocation"/>
    <Code>  newZone = exploredZonesMap:addHandler(entered, defaultZoneHandler)
  mapOverviewMap:removeHandler(entered, exploredZoneOutline)
  mapOverviewMap:addHandler(entered, currentZoneOutline)
  classicHandler:removeHandler(previousEntered, defaultZoneHandler)
  classicHandler:addHandler(entered, defaultZoneHandler)
  zoneEast = entered:getEast()
  zoneWest = entered:getWest()
  zoneNorth = entered:getNorth()
  zoneSouth = entered:getSouth()
  zoneTop = entered:getTop()
  zoneBottom = entered:getBottom()
  centerX = zoneWest + (zoneEast - zoneWest) / 2.0
  centerY = zoneNorth + (zoneSouth - zoneNorth) / 2.0
  centerZ = zoneTop + (zoneBottom - zoneTop) / 2.0
  centerZ = centerZ - 4
  zoneLocation:setX(centerX)
  zoneLocation:setY(centerY)
  zoneLocation:setZ(centerZ)
  backgroundColour = themedZones:getColour(entered, themeColour)
  background:setColour(backgroundColour)
  if newZone == true then 
    score = score + 400
    mapOverviewMap:removeHandler(entered, unexploredZoneOutline)
    remaining = collectables:getRemaining(entered)
    if remaining ~= 0 then
      mapOverviewMap:addHandler(entered, jewelToCollectIcon)
    end
    time = time + 8000
    if time &gt; 180000 then
      local excess = time - 180000
      local extraScore = excess / 10
      score = score + extraScore
      time = 180000
    end
    zoneCount = zoneCount - 1
  end
  dynamicElementGroups:setActive(entered, true)
  liftModule:reset(entered)
  enemyModule:reset(entered)
  previousEntered = entered</Code>
  </Script>
  <Script name="zoneExited">
    <Argument name="exited" type="Zone"/>
    <Argument name="dynamicElementGroups" type="DynamicElementGroup/Type" value="Zones"/>
    <Argument name="mapOverviewMap" type="MappedZoneHandler/Handler" value="MapOverview"/>
    <Argument name="currentZoneOutline" type="ZoneHandler" value="ZoneOutlineRenderer/CurrentZone"/>
    <Argument name="exploredZoneOutline" type="ZoneHandler" value="ZoneOutlineRenderer/ExploredZones"/>
    <Argument name="defaultZoneHandler" type="ZoneHandler" value="!default"/>
    <Code>  dynamicElementGroups:setActive(exited, false)
  mapOverviewMap:removeHandler(exited, currentZoneOutline)
  mapOverviewMap:addHandler(exited, exploredZoneOutline)</Code>
  </Script>
  <InputConfiguration>
    <DigitalInput name="Brake">
      <Mapping type="keyDown" value="Space"/>
      <OnStart name="playerBrake">
        <Argument name="player" type="SpindizzyGERALD/GERALD" value="Player"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Empty Circle Switch">
      <Mapping type="keyDown" value="9"/>
      <OnStart name="setSecondarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="CircleEmpty"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchCircleNone"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchCircleEmpty"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Circle None.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Empty Square Switch">
      <Mapping type="keyDown" value="5"/>
      <OnStart name="setPrimarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="SquareEmpty"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchSquareNone"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchSquareEmpty"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Square None.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Filled Circle Switch">
      <Mapping type="keyDown" value="]"/>
      <OnStart name="setSecondarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="CircleFilled"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchCircleBoth"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchCircleFilled"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Circle Both.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Filled Diamond Switch">
      <Mapping type="keyDown" value="4"/>
      <OnStart name="setPrimarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="DiamondFilled"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchDiamondBoth"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchDiamondFilled"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Diamond Both.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Filled Square Switch">
      <Mapping type="keyDown" value="8"/>
      <OnStart name="setPrimarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="SquareFilled"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchSquareBoth"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchSquareFilled"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Square Both.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Left Circle Switch">
      <Mapping type="keyDown" value="0"/>
      <OnStart name="setSecondarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="CircleLeft"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchCircleLeft"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchCircleLeft"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Circle Left.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Left Diamond Switch">
      <Mapping type="keyDown" value="2"/>
      <OnStart name="setPrimarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="DiamondLeft"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchDiamondLeft"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchDiamondLeft"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Diamond Left.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Left Square Switch">
      <Mapping type="keyDown" value="6"/>
      <OnStart name="setPrimarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="SquareLeft"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchSquareLeft"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchSquareLeft"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Square Left.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Right Circle Switch">
      <Mapping type="keyDown" value="["/>
      <OnStart name="setSecondarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="CircleRight"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchCircleRight"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchCircleRight"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Circle Right.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Right Diamond Switch">
      <Mapping type="keyDown" value="3"/>
      <OnStart name="setPrimarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="DiamondRight"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchDiamondRight"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchDiamondRight"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Diamond Right.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Right Square Switch">
      <Mapping type="keyDown" value="7"/>
      <OnStart name="setPrimarySwitch">
        <Argument name="lift" type="SpindizzyLifts/SpindizzyLiftType" value="SquareRight"/>
        <Argument name="blockState" type="SpindizzyBlocks/BlockState" value="SwitchSquareRight"/>
        <Argument name="switchIcon" type="3DModel" value="FlatRectangle/SwitchSquareRight"/>
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Square Right.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Reset Switches">
      <Mapping type="keyDown" value="1"/>
      <OnStart name="resetSwitch">
        <Argument name="sound" type="Sound" value="SDLMixerSupport/Diamond None.ogg"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Map">
      <Mapping type="keyDown" value="m"/>
      <OnStart name="toggleMapOverview"/>
    </DigitalInput>
    <DigitalInput name="Move East">
      <Mapping type="keyDown" value="ArrowRight"/>
      <Mapping type="keyDown" value="d"/>
    </DigitalInput>
    <DigitalInput name="Move North">
      <Mapping type="keyDown" value="ArrowUp"/>
      <Mapping type="keyDown" value="w"/>
    </DigitalInput>
    <DigitalInput name="Move South">
      <Mapping type="keyDown" value="ArrowDown"/>
      <Mapping type="keyDown" value="s"/>
    </DigitalInput>
    <DigitalInput name="Move West">
      <Mapping type="keyDown" value="ArrowLeft"/>
      <Mapping type="keyDown" value="a"/>
    </DigitalInput>
    <DigitalInput name="Reset Camera">
      <Mapping type="keyDown" value="F1"/>
      <OnStart name="rotateViewTo">
        <Argument name="angle" type="Integer" value="#-45"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Reverse Camera">
      <Mapping type="keyDown" value="F7"/>
      <OnStart name="rotateViewBy">
        <Argument name="amount" type="Integer" value="#180"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Rotate Camera Left">
      <Mapping type="keyDown" value="F3"/>
      <OnStart name="rotateViewBy">
        <Argument name="amount" type="Integer" value="#90"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Rotate Camera Right">
      <Mapping type="keyDown" value="F5"/>
      <OnStart name="rotateViewBy">
        <Argument name="amount" type="Integer" value="#-90"/>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Thrust">
      <Mapping type="keyDown" value="LeftControl"/>
    </DigitalInput>
    <DigitalInput name="View Mode">
      <Mapping type="keyDown" value="F9"/>
      <OnStart name="toggleRenderingMode"/>
    </DigitalInput>
  </InputConfiguration>
  <Plugin name="3DModelToHUD">
    <Resources>
      <Component camera="SpindizzyCamera/Camera" model="SpindizzyJewelModel/Jewel" name="JewelIcon" x="0.000000" y="0.000000" z="-0.600000" scale="1.0"/>
      <Component model="FlatRectangle/HUDIconMap" name="MapIcon" x="0.000000" y="0.000000" z="0.000000" scale="1.0"/>
      <Component model="FlatRectangle/HUDIconScore" name="ScoreIcon" x="0.000000" y="0.000000" z="0.000000" scale="1.0"/>
      <Component model="FlatRectangle/HUDIconTime" name="TimeIcon" x="0.000000" y="0.000000" z="0.000000" scale="1.0"/>
      <Component camera="SpindizzyCamera/Camera" model="ElementModel/Compass" name="Compass" x="0.000000" y="0.000000" z="-0.500000" scale="0.7"/>
      <Component camera="SpindizzyCamera/Camera" model=":Model/ChangeableModel/PrimarySwitchState" name="PrimarySwitchState" x="0.000000" y="0.000000" z="0.000000" scale="1.0"/>
      <Component camera="SpindizzyCamera/Camera" model=":Model/ChangeableModel/SecondarySwitchState" name="SecondarySwitchState" x="0.000000" y="0.000000" z="0.000000" scale="1.0"/>
      <Component camera="SpindizzyCamera/Camera" model=":Model/ChangeableModel/Clue" name="Clue" x="0.000000" y="0.000000" z="0.000000" scale="1.0"/>
    </Resources>
  </Plugin>
  <Plugin name="BlockSubtractor">
    <Resources>
      <SurfaceProcessor name="visualSurfaceProcessor" removeHiddenSurfaces="false" useAdjacentZones="false" map="HangWorld"/>
      <SurfaceProcessor name="physicalSurfaceProcessor" removeHiddenSurfaces="true" useAdjacentZones="true" map="HangWorld"/>
    </Resources>
  </Plugin>
  <Plugin name="C64SpindizzySprites">
    <Resources>
      <TextureSet colour1="UserDefinablePalette/Purple" colour2="UserDefinablePalette/Yellow" colour3="UserDefinablePalette/Pink" name="C64Sprites" outline="UserDefinablePalette/Black"/>
      <TextureSet colour1="UserDefinablePalette/Cyan" colour2="UserDefinablePalette/Orange" colour3="UserDefinablePalette/Pink" name="C64HUDSprites" outline="UserDefinablePalette/Black"/>
    </Resources>
  </Plugin>
  <Plugin name="C64SpindizzyTextureSet">
    <Resources>
      <TextureSet extra="UserDefinablePalette/Blue" floor="UserDefinablePalette/LightBlue" grid="UserDefinablePalette/White" name="C64Blue" wall="UserDefinablePalette/Black"/>
      <TextureSet extra="UserDefinablePalette/Black" floor="UserDefinablePalette/LightBlue" grid="UserDefinablePalette/Yellow" name="C64BlueRed" wall="UserDefinablePalette/Red"/>
      <TextureSet extra="UserDefinablePalette/Yellow" floor="UserDefinablePalette/Blue" grid="UserDefinablePalette/White" name="C64BlueYellow" wall="UserDefinablePalette/Orange"/>
      <TextureSet extra="UserDefinablePalette/Yellow" floor="UserDefinablePalette/Purple" grid="UserDefinablePalette/Black" name="C64Chocolate" wall="UserDefinablePalette/Brown"/>
