  <Layer type="IsoRealms/HUD" name="Spindizzy HUD">
    <Element bottom="align ValueJewel" left="align ValueJewel" name="PanelRight"  right="align IconScore" top="align IconScore" type="IsoRealms/HUDPanel"/>
    <Element bottom="align ValueMap"   left="align IconMap"    name="PanelLift"   right="align ValueMap"  top="align IconTime"  type="IsoRealms/HUDPanel"/>
    <Element bottom="align Clue"       left="align Clue"       name="PanelMiddle" right="align Compass"   top="align Clue"      type="IsoRealms/HUDPanel"/>
    <Element name="SwitchStatePrimary"   right="center screen"                size="0.174" top="align screen 0.02" type="IsoRealms/PrimarySwitchState"/>
    <Element name="SwitchStateSecondary" left="center screen"                 size="0.174" top="align screen 0.02" type="IsoRealms/SecondarySwitchState"/>
    <Element name="Compass"              left="adjacent SwitchStateSecondary" size="0.174" top="align screen 0.02" type="IsoRealms/Compass"/>
    <Element name="Clue"                 right="adjacent SwitchStatePrimary"  size="0.174" top="align screen 0.02" type="IsoRealms/Clue"/>
    <Element name="IconScore"  right="align screen 0.02"       top="align screen 0.02"  size="0.09"               type="IsoRealms/ScoreIcon"/>
    <Element name="IconTime"   left="align screen 0.02"        top="align screen 0.02"  size="0.09"               type="IsoRealms/TimeIcon"/>
    <Element name="IconJewel"  right="align IconScore"         top="adjacent IconScore" size="0.09"               type="IsoRealms/JewelIcon"/>
    <Element name="IconMap"    left="align IconTime"           top="adjacent IconTime"  size="0.09"               type="IsoRealms/MapIcon"/> 
    <Element name="ValueTime"  left="adjacent IconTime 0.02"   top="align IconTime"     length="0.09" width="0.5" type="IsoRealms/TimeDisplay"/>
    <Element name="ValueScore" right="adjacent IconScore 0.02" top="align IconScore"    length="0.09" width="0.5" type="IsoRealms/ScoreDisplay"/>
    <Element name="ValueMap"   left="adjacent IconMap 0.02"    top="align IconMap"      length="0.09" width="0.5" type="IsoRealms/ZonesToExploreDisplay"/>
    <Element name="ValueJewel" right="adjacent IconJewel 0.02" top="align IconJewel"    length="0.09" width="0.5" type="IsoRealms/JewelCountDisplay"/>
  </Layer>
  <ReturnValue name="Score" type="Integer" value="IsoRealms/Score"/>
  <ReturnValue name="Time" type="Integer" value="IsoRealms/SpindizzyTimeLimit"/>
  <ReturnValue name="Zones" type="Integer" value="IsoRealms/ZonesToExplore"/>
  <ReturnValue name="Jewels" type="Integer" value="IsoRealms/Collected"/>
  <ReturnValue name="Project" type="String" value="IsoRealms/ProjectName"/>
