        <Texture type="WallWestBottom" name="Plugin/TextureSetChanger/PerZone/WallMixedCap" flip="true"/>
        <Texture type="WallEast" name="Plugin/TextureSetChanger/PerZone/WallMixedMiddle"/>
        <Texture type="WallEastTop" name="Plugin/TextureSetChanger/PerZone/WallMixedCap"/>
        <Texture type="WallEastBottom" name="Plugin/TextureSetChanger/PerZone/WallMixedCap" flip="true"/>
