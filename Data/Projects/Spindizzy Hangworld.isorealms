  <Plugin name="SpindizzyCamera">
    <Resources>
      <Camera location="SpindizzyGERALD/Player" name="Camera">
        <TransitionCompleteScript name="switchToGameplay"/>
      </Camera>
    </Resources>
  </Plugin>
  <Plugin name="SpindizzyEnemies">
    <Resources>
      <Type model="SpindizzyGERALDBallModel/Ball" type="Ball"/>
      <Type model="SpindizzyGERALDGyroscopeModel/Gyroscope" type="Gyroscope"/>
      <Type model="SpindizzyGERALDPyramidModel/Pyramid" type="Pyramid"/>
    </Resources>
  </Plugin>
  <Plugin name="SpindizzyGERALD">
    <Resources>
      <Type camera="SpindizzyCamera/Camera" collectablesRegistry="ZoneCollectables/Jewels" model="SpindizzyGERALDPyramidModel/Pyramid" surfaceRegistry="DefaultCollidableSurfaceRegistry/Surfaces" type="Player" map="HangWorld">
        <RespawnScript name="respawn"/>
        <FallImpactScript name="playerFallImpact">
          <Argument name="player" type="SpindizzyGERALD/GERALD" value="~craft"/>
          <Argument name="fallDistance" type="Float" value="~fallDistance"/>
        </FallImpactScript>
        <ZoneEnteredScript name="zoneEntered">
          <Argument name="entered" type="Zone" value="~entered"/>
        </ZoneEnteredScript>
        <ZoneExitedScript name="zoneExited">
          <Argument name="exited" type="Zone" value="~exited"/>
        </ZoneExitedScript>
      </Type>
      <Instance name="Player" type="Player" x="-4" y="3" z="0"/>
    </Resources>
  </Plugin>
  <Plugin name="SpindizzyGERALDBallModel">
    <Resources>
      <ModelType camera="SpindizzyCamera/Camera" name="Ball"/>
    </Resources>
  </Plugin>
  <Plugin name="SpindizzyGERALDGyroscopeModel">
    <Resources>
      <ModelType name="Gyroscope"/>
    </Resources>
  </Plugin>
  <Plugin name="SpindizzyGERALDPyramidModel">
    <Resources>
      <ModelType name="Pyramid" top="UserDefinablePalette/Cyan" side="UserDefinablePalette/Purple" outline="UserDefinablePalette/Black"/>
    </Resources>
  </Plugin>
  <Plugin name="SpindizzyJewelModel">
    <Resources>
      <ModelType name="Jewel" frameColour="UserDefinablePalette/Yellow" cycleSpeed="0.0015">
	<ColourCycle colour="UserDefinablePalette/Red"/>
	<ColourCycle colour="UserDefinablePalette/Yellow"/>
	<ColourCycle colour="UserDefinablePalette/Green"/>
	<ColourCycle colour="UserDefinablePalette/Cyan"/>
	<ColourCycle colour="UserDefinablePalette/Blue"/>
	<ColourCycle colour="UserDefinablePalette/Purple"/>
      </ModelType>/>
    </Resources>
  </Plugin>
  <Plugin name="SpindizzyJewels">
    <Resources>
      <Type collectablesRegistry="ZoneCollectables/Jewels" model="SpindizzyJewelModel/Jewel" name="Jewel"/>
    </Resources>
  </Plugin>
  <Plugin name="SpindizzyLifts">
    <Resources>
      <Configuration surfaceRegistry="DefaultCollidableSurfaceRegistry/Surfaces">
        <LiftMovedScript name="randomClick"/>
      </Configuration>
      <LiftType active="true" model="FlatRectangle/LiftDiamondEmpty" name="DiamondEmpty"/>
      <LiftType model="FlatRectangle/LiftDiamondLeft" name="DiamondLeft"/>
      <LiftType model="FlatRectangle/LiftDiamondRight" name="DiamondRight"/>
      <LiftType model="FlatRectangle/LiftDiamondFilled" name="DiamondFilled"/>
      <LiftType model="FlatRectangle/LiftSquareEmpty" name="SquareEmpty"/>
      <LiftType model="FlatRectangle/LiftSquareLeft" name="SquareLeft"/>
      <LiftType model="FlatRectangle/LiftSquareRight" name="SquareRight"/>
      <LiftType model="FlatRectangle/LiftSquareFilled" name="SquareFilled"/>
      <LiftType model="FlatRectangle/LiftCircleEmpty" name="CircleEmpty"/>
      <LiftType model="FlatRectangle/LiftCircleLeft" name="CircleLeft"/>
      <LiftType model="FlatRectangle/LiftCircleRight" name="CircleRight"/>
      <LiftType model="FlatRectangle/LiftCircleFilled" name="CircleFilled"/>
    </Resources>
  </Plugin>
  <Plugin name="StringToHUD">
    <Resources>
      <Component font="GLFreeType/HUDFont" name="ScoreDisplay" value=":Integer/DumbIntegerValue/Score"/>
      <Component font="GLFreeType/HUDFont" name="TimeDisplay" value="TimeString/SpindizzyTimeLimit"/>
      <Component font="GLFreeType/HUDFont" name="ZonesToExploreDisplay" value=":Integer/DumbIntegerValue/ZonesToExplore"/>
      <Component font="GLFreeType/HUDFont" name="JewelCountDisplay" value=":Integer/SpindizzyJewels/Collected"/>
    </Resources>
  </Plugin>
