  <ElementSet instance="Enemies" type="SpindizzyEnemies">
    <UsePlugin implementation="3DModel" instance="Ball" socketid="0"/>
    <UsePlugin implementation="3DModel" instance="Gyroscope" socketid="1"/>
    <UsePlugin implementation="3DModel" instance="Pyramid" socketid="2"/>
    <UsePlugin implementation="ZoneContext" instance="PlayerZoneContext" socketid=""/>
    <Configuration/>
  </ElementSet>
  <ElementSet instance="Jewels" type="SpindizzyJewels">
    <UsePlugin implementation="3DModel" instance="C64JewelModel"/>
    <UsePlugin implementation="Collectables" instance="Jewels"/>
    <Configuration>
      <JewelCollectedScript>
        <Command>Plugin/Utilities/SoundCommandWrapper/Play Jewel.ogg</Command>
        <Command>Plugin/Utilities/TimerCommands/IncreaseTimeForJewel</Command>
        <Command>Plugin/Utilities/ScoreCommands/IncreaseScoreForJewel</Command>
      </JewelCollectedScript>
    </Configuration>
  </ElementSet>
  <ElementSet instance="Lifts" type="SpindizzyLifts">
    <UsePlugin implementation="CollidableSurfaceRegistry" instance="SpindizzySurfaces"/>
    <UsePlugin implementation="3DModel" instance="LiftDiamondEmpty" socketid="0"/>
    <UsePlugin implementation="3DModel" instance="LiftDiamondLeft" socketid="1"/>
    <UsePlugin implementation="3DModel" instance="LiftDiamondRight" socketid="2"/>
    <UsePlugin implementation="3DModel" instance="LiftDiamondFilled" socketid="3"/>
    <UsePlugin implementation="3DModel" instance="LiftSquareEmpty" socketid="4"/>
    <UsePlugin implementation="3DModel" instance="LiftSquareLeft" socketid="5"/>
    <UsePlugin implementation="3DModel" instance="LiftSquareRight" socketid="6"/>
    <UsePlugin implementation="3DModel" instance="LiftSquareFilled" socketid="7"/>
    <UsePlugin implementation="3DModel" instance="LiftCircleEmpty" socketid="8"/>
    <UsePlugin implementation="3DModel" instance="LiftCircleLeft" socketid="9"/>
    <UsePlugin implementation="3DModel" instance="LiftCircleRight" socketid="10"/>
    <UsePlugin implementation="3DModel" instance="LiftCircleFilled" socketid="11"/>
    <UsePlugin implementation="ZoneContext" instance="PlayerZoneContext" socketid=""/>
    <Configuration>
      <LiftMovedScript>
        <Command>Plugin/Utilities/PlayLiftClick/Random LiftClick</Command>
      </LiftMovedScript>
      <LiftType name="DiamondEmpty" model="0" active="true"/>
      <LiftType name="DiamondLeft" model="1"/>
      <LiftType name="DiamondRight" model="2"/>
      <LiftType name="DiamondFilled" model="3"/>
      <LiftType name="SquareEmpty" model="4"/>
      <LiftType name="SquareLeft" model="5"/>
      <LiftType name="SquareRight" model="6"/>
      <LiftType name="SquareFilled" model="7"/>
      <LiftType name="CircleEmpty" model="8"/>
      <LiftType name="CircleLeft" model="9"/>
      <LiftType name="CircleRight" model="10"/>
      <LiftType name="CircleFilled" model="11"/>
    </Configuration>
  </ElementSet>
  <ElementSet instance="Player" type="SpindizzyGERALD">
    <UsePlugin implementation="3DModel" instance="Pyramid"/>
    <UsePlugin implementation="Camera" instance="CraftCamera"/>
    <UsePlugin implementation="Collectables" instance="Jewels"/>
    <UsePlugin implementation="CollidableSurfaceRegistry" instance="SpindizzySurfaces"/>
    <UsePlugin implementation="LocationAwareness" instance="PlayerLocation"/>
    <UsePlugin implementation="ZoneContext" instance="PlayerZoneContext"/>
    <Configuration>
      <FallLimit height="2.75">
        <Script>
          <Command>Plugin/Utilities/SoundCommandWrapper/Play Impact Hard.ogg</Command>
        </Script>
      </FallLimit>
      <Respawn>
        <Script>
          <Command>Plugin/Utilities/TimerCommands/DecreaseTimeForRespawn</Command>
        </Script>
      </Respawn>
    </Configuration>
  </ElementSet>
  <ZoneRenderer type="Utilities" instance="ExploredZones" renderer="mapOverview" active="false"/>
  <ZoneRenderer type="Utilities" instance="ExploredZones" renderer="explored" active="true"/>
  <ZoneRenderer type="Utilities" instance="ZoneContextRenderer" renderer="zone" active="false"/>
<!--  <ZoneRenderer/>-->
  <InputConfiguration>
    <DigitalInput name="Move North">
      <Mapping type="keyDown" value="ArrowUp"/>
      <Mapping type="keyDown" value="w"/>
    </DigitalInput>
    <DigitalInput name="Move East">
      <Mapping type="keyDown" value="ArrowRight"/>
      <Mapping type="keyDown" value="d"/>
    </DigitalInput>
    <DigitalInput name="Move South">
      <Mapping type="keyDown" value="ArrowDown"/>
      <Mapping type="keyDown" value="s"/>
    </DigitalInput>
    <DigitalInput name="Move West">
      <Mapping type="keyDown" value="ArrowLeft"/>
      <Mapping type="keyDown" value="a"/>
    </DigitalInput>
    <DigitalInput name="Thrust">
      <Mapping type="keyDown" value="LeftControl"/>
    </DigitalInput>
    <DigitalInput name="Brake">
      <Mapping type="keyDown" value="Space"/>
      <OnStart>
        <Command>ElementSet/Player/Stop</Command>
        <Command>Plugin/Timer/DeductForStop</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Map">
      <Mapping type="keyDown" value="m"/>
      <OnStart>
        <Command>Plugin/Utilities/GameSwitches/Toggle MapOverview</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="View Mode">
      <Mapping type="keyDown" value="F9"/>
      <OnStart>
        <Command>Plugin/Utilities/GameSwitches/Toggle RenderingMode</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Reset Camera">
      <Mapping type="keyDown" value="F1"/>
      <OnStart>
        <Command>Plugin/Camera/CraftCamera/Reset</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Rotate Camera Left">
      <Mapping type="keyDown" value="F3"/>
      <OnStart>
        <Command>Plugin/Camera/CraftCamera/RotateLeft</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Rotate Camera Right">
      <Mapping type="keyDown" value="F5"/>
      <OnStart>
        <Command>Plugin/Camera/CraftCamera/RotateRight</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Reverse Camera">
      <Mapping type="keyDown" value="F7"/>
      <OnStart>
        <Command>Plugin/Camera/CraftCamera/Rotate180</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Reset Switches">
      <Mapping type="keyDown" value="1"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Reset Spindizzy Switches</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Left Diamond Switch">
      <Mapping type="keyDown" value="2"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch LeftDiamondSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Right Diamond Switch">
      <Mapping type="keyDown" value="3"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch RightDiamondSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Filled Diamond Switch">
      <Mapping type="keyDown" value="4"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch FilledDiamondSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Empty Square Switch">
      <Mapping type="keyDown" value="5"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch EmptySquareSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Left Square Switch">
      <Mapping type="keyDown" value="6"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch LeftSquareSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Right Square Switch">
      <Mapping type="keyDown" value="7"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch RightSquareSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Filled Square Switch">
      <Mapping type="keyDown" value="8"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch FilledSquareSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Empty Circle Switch">
      <Mapping type="keyDown" value="9"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch EmptyCircleSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Left Circle Switch">
      <Mapping type="keyDown" value="0"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch LeftCircleSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Right Circle Switch">
      <Mapping type="keyDown" value="["/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch RightCircleSwitch</Command>
      </OnStart>
    </DigitalInput>
    <DigitalInput name="Debug Activate Filled Circle Switch">
      <Mapping type="keyDown" value="]"/>
      <OnStart>
        <Command>Plugin/Utilities/SpindizzySwitches/Activate switch FilledCircleSwitch</Command>
      </OnStart>
    </DigitalInput>
  </InputConfiguration>
