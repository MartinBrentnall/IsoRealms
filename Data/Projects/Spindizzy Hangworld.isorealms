        <Texture type="WallNorthBottom" name="Plugin/TextureSetChanger/PerZone/WallPlainCap" flip="true"/>
      </BlockType>
      <BlockType name="SwitchCircleRight" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true" wallType="capped">
        <ContactScript>
          <Command>Plugin/Utilities/SpindizzySwitches/Activate switch RightCircleSwitch</Command>
        </ContactScript>
        <Texture type="Surface" name="Plugin/TextureSetChanger/PerZone/SwitchCircleOne" rotate="Reverse"/>
