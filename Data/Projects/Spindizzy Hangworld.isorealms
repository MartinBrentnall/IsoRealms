      <RespawnScript name="IsoRealms/respawn"/>
      <FallImpactScript name="IsoRealms/playerFallImpact">
        <Argument name="player" type="Spindizzy/GERALD" value="~craft"/>
        <Argument name="fallDistance" type="Float" value="~fallDistance"/>
      </FallImpactScript>
      <Boundaries name="Spindizzy/Jewel">
        <EnteredScript name="IsoRealms/jewelCollected"/>
      </Boundaries>
      <Boundaries name="Spindizzy/Zone">
        <EnteredScript name="IsoRealms/zoneEntered">
          <Argument name="entered" type="Spindizzy/Zone" value="Zone"/>
        </EnteredScript>
        <ExitedScript name="IsoRealms/zoneExited"/>
      </Boundaries>
      <Instance name="Player" x="-4" y="3" z="0"/>
    </ElementSpindizzyCraft>
