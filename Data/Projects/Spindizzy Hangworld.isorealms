        <Texture type="WallNorthBottom" name="Plugin/TextureSetChanger/PerZone/WallPlainCap" flip="true"/>
      </BlockType>
      <BlockType name="SwitchCircleBoth" friction="0.001" grip="1.0" bounce="0.0" respawnAllowed="true" wallType="capped">
