  <Plugin name="TimeLimit">
    <Resources>
      <TimeLimit name="SpindizzyTimeLimit" value="150000"/>
    </Resources>
  </Plugin>
  <Plugin name="TimeString">
    <Resources>
      <String name="SpindizzyTimeLimit" value="TimeLimit/SpindizzyTimeLimit"/>
    </Resources>
  </Plugin>
  <Plugin name="UserDefinablePalette">
    <Resources>
      <Colour alpha="1" blue="0" green="0" name="Black" red="0"/>
      <Colour alpha="1" blue="1" green="1" name="White" red="1"/>
      <Colour alpha="1" blue="0.203125" green="0.242188" name="Red" red="0.546875"/>
