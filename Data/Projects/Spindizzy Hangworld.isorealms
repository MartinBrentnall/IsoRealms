  <Plugin implementation="SpindizzySwitches" instance="SpindizzySwitches" type="Utilities">
    <UsePlugin implementation="3DModel" instance="HUDDiamondLeft" socketid="0"/>
    <UsePlugin implementation="3DModel" instance="HUDDiamondRight" socketid="1"/>
    <UsePlugin implementation="3DModel" instance="HUDDiamondFilled" socketid="2"/>
    <UsePlugin implementation="3DModel" instance="HUDSquareEmpty" socketid="3"/>
    <UsePlugin implementation="3DModel" instance="HUDSquareLeft" socketid="4"/>
    <UsePlugin implementation="3DModel" instance="HUDSquareRight" socketid="5"/>
    <UsePlugin implementation="3DModel" instance="HUDSquareFilled" socketid="6"/>
    <UsePlugin implementation="3DModel" instance="HUDCircleEmpty" socketid="7"/>
    <UsePlugin implementation="3DModel" instance="HUDCircleLeft" socketid="8"/>
    <UsePlugin implementation="3DModel" instance="HUDCircleRight" socketid="9"/>
