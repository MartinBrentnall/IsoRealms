                      "variable": "project",
                      "to": {
                        "key": "Basics/Project/Project"
                      }
                    },
                    {
                      "variable": "templateOptions",
                      "to": {
                        "key": ":ProjectOptions",
                        "asset": {
                          "key": "Basics/ProjectOptions/Template"
                        }
                      }
                    },
                    {
                      "variable": "closeAllMenusFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/CloseAllMenus",
                          "bindings": []
                        }
                      }
                    },
                    {
                      "variable": "menuDisplay",
                      "to": {
                        "key": "UI/Layout/Main/Menu"
                      }
                    },
                    {
                      "variable": "throbber",
                      "to": {
                        "key": ":Screen",
                        "asset": {
                          "key": "UI/Throbber/LoadingScreen"
                        }
                      }
                    }
                  ],
                  "code": "project:prepare(templateOptions, true)\ncloseAllMenusFunction:execute()\nmenuDisplay:setScreen(throbber)"
                },
                "onCancel": {
                  "key": "Basics/Function/PopScreen",
                  "bindings": []
                }
              },
              {
                "id": "Close",
                "message": "Close IsoRealms?  Changes won't be saved!",
                "cancelLabel": "Cancel",
                "confirmLabel": "Close",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Quit"
                },
                "onCancel": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "cancelCloseIDEFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/ResumeEditor",
                          "bindings": []
                        }
                      }
                    }
                  ],
                  "code": "gCloseIDERequested = nil\ncancelCloseIDEFunction:execute()"
                }
              },
              {
                "id": "Quit",
                "message": "Quit Editor?  Changes won't be saved!",
                "cancelLabel": "Cancel",
                "confirmLabel": "Quit",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "project",
                      "to": {
                        "key": "Project"
                      }
                    }
                  ],
                  "code": "project:finish(false)"
                },
                "onCancel": {
                  "key": "Basics/Function/PopScreen",
                  "bindings": []
                }
              },
              {
                "id": "Load",
                "message": "Load App?  Changes to the current App won't be saved!",
                "cancelLabel": "Cancel",
                "confirmLabel": "Load App",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "project",
                      "to": {
                        "key": "Basics/Project/Project"
                      }
                    },
                    {
                      "variable": "loadMissionOptions",
                      "to": {
                        "key": ":ProjectOptions",
                        "asset": {
                          "key": "Basics/ProjectOptions/LoadMission"
                        }
                      }
                    },
                    {
                      "variable": "closeAllMenusFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/CloseAllMenus",
                          "bindings": []
                        }
                      }
                    },
                    {
                      "variable": "menuDisplay",
                      "to": {
                        "key": "UI/Layout/Main/Menu"
                      }
                    },
                    {
                      "variable": "throbber",
                      "to": {
                        "key": ":Screen",
                        "asset": {
                          "key": "UI/Throbber/LoadingScreen"
                        }
                      }
                    }
                  ],
                  "code": "project:prepare(loadMissionOptions, true)\ncloseAllMenusFunction:execute()\nmenuDisplay:setScreen(throbber)"
                },
                "onCancel": {
                  "key": "Basics/Function/PopScreen",
                  "bindings": []
                }
              },
              {
                "id": "Overwrite",
                "message": "Overwrite existing project?",
                "cancelLabel": "Cancel",
                "confirmLabel": "Overwrite",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "project",
                      "to": {
                        "key": "Basics/Project/Project"
                      }
                    },
                    {
                      "variable": "filename",
                      "to": {
                        "key": ":String",
                        "asset": {
                          "key": "UI/VirtualKeyboard/SaveAsPrompt"
                        }
                      }
                    },
                    {
                      "variable": "resumeEditorFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/ResumeEditor",
                          "bindings": []
                        }
                      }
                    }
                  ],
                  "code": "project:saveAs(\"Projects/\" .. filename:getValue())\nresumeEditorFunction:execute()"
                },
                "onCancel": {
                  "key": "Basics/Function/PopScreen",
                  "bindings": []
                }
              }
            ]
          },
          {
            "type": "Throbber",
            "instances": [
              {
                "id": "LoadingScreen",
                "colour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                }
              }
            ]
          },
          {
            "type": "VirtualKeyboard",
            "instances": [
              {
                "id": "SaveAsPrompt",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "project",
                      "to": {
                        "key": "Basics/Project/Project"
                      }
                    },
                    {
                      "variable": "filename",
                      "to": {
                        "key": ":String",
                        "asset": {
                          "key": "UI/VirtualKeyboard/SaveAsPrompt"
                        }
                      }
                    },
                    {
                      "variable": "confirmOverwriteFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/PushScreen",
                          "bindings": [
                            {
                              "argument": "menuScreen",
                              "to": {
                                "key": ":Screen",
                                "asset": {
                                  "key": "UI/Prompt/Overwrite"
                                }
                              }
                            },
                            {
                              "argument": "menu",
                              "to": {
                                "key": "UI/Prompt/Overwrite"
                              }
                            },
                            {
                              "argument": "menuInput",
                              "to": {
                                "key": ":InputHandler",
                                "asset": {
                                  "key": "UI/Prompt/Overwrite"
                                }
                              }
                            }
                          ]
                        }
                      }
                    },
                    {
                      "variable": "resumeEditorFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/ResumeEditor",
                          "bindings": []
                        }
                      }
                    }
                  ],
                  "code": "if project:exists(\"Projects/\" .. filename:getValue()) then\n  confirmOverwriteFunction:execute()\nelse\n  project:saveAs(\"Projects/\" .. filename:getValue())\n  resumeEditorFunction:execute()\nend"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
