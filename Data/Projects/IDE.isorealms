                  "bindings": []
                },
                "options": [
                  {
                    "item": {
                      "key": "Action",
                      "label": "Run App",
                      "onSelection": {
                        "key": "Basics/Script",
                        "bindings": [
                          {
                            "variable": "interactiveDisplay",
                            "to": {
                              "key": "UI/Layout/Runtime/Screen"
                            }
                          },
                          {
                            "variable": "interactiveInput",
                            "to": {
                              "key": "Basics/InputSwitch/Main"
                            }
                          },
                          {
                            "variable": "testInputHandler",
                            "to": {
                              "key": ":InputHandler",
                              "asset": {
                                "key": "Basics/InputGroup/Test"
                              }
                            }
                          },
                          {
                            "variable": "project",
                            "to": {
                              "key": "Basics/Project/Project"
                            }
                          }
                        ],
                        "code": "gProjectExecuting = true\nif gActiveEditor ~= nil then\n  gActiveEditor:notifyHidden()\nend\ninteractiveDisplay:setScreen(nil)\ninteractiveInput:setInputHandler(testInputHandler)\nproject:reset()\nproject:setRunning(true)\nproject:setEditing(false)"
                      }
                    }
                  },
                  {
                    "item": {
                      "key": "Action",
                      "label": "App Configuration",
                      "onSelection": {
                        "key": "Basics/Script",
                        "bindings": [
                          {
                            "variable": "closeAllMenusFunction",
                            "to": {
                              "key": ":Action",
                              "asset": {
                                "key": "Basics/Function/CloseAllMenus",
                                "bindings": []
                              }
                            }
                          },
                          {
                            "variable": "interactiveInput",
                            "to": {
                              "key": "Basics/InputSwitch/Main"
                            }
                          },
                          {
                            "variable": "inputHandlerEditor",
                            "to": {
                              "key": ":InputHandler",
                              "asset": {
                                "key": "Basics/InputGroup/EditorInput"
                              }
                            }
                          },
                          {
                            "variable": "directConfigurerInput",
                            "to": {
                              "key": "Basics/InputSwitch/DirectConfigurerInput"
                            }
                          },
                          {
                            "variable": "configurerInput",
                            "to": {
                              "key": ":InputHandler",
                              "asset": {
                                "key": "Basics/ProjectConfigurer/ProjectConfigurer"
                              }
                            }
                          },
                          {
                            "variable": "projectConfigurer",
                            "to": {
                              "key": "Basics/ProjectConfigurer/ProjectConfigurer"
                            }
                          },
                          {
                            "variable": "project",
                            "to": {
                              "key": "Basics/Project/Project"
                            }
                          }
                        ],
                        "code": "-- Get rid of the menus.\ncloseAllMenusFunction:execute()\n\n-- Enable project configurer navigation input (mapped from editing inputs... TODO: Maybe I'll change or remove this).\ninteractiveInput:setInputHandler(inputHandlerEditor)\n\n-- Enable project configurer direct input (for text fields etc.)\ndirectConfigurerInput:setInputHandler(configurerInput)\n\n-- Show the application configuration menu.\ngActiveProjectConfigurer = true\nif projectConfigurer:isHidden() then\n  projectConfigurer:show()\nelse\n  projectConfigurer:setProject(project:getProject())\nend\n\n-- Is this still needed?\nif gActiveEditor ~= nil then\n  gActiveEditor:notifyLostFocus()\nend"
                      }
                    }
                  },
                  {
                    "item": {
                      "key": "Action",
                      "label": "Save App",
                      "onSelection": {
                        "key": "Basics/Script",
                        "bindings": [
                          {
                            "variable": "project",
                            "to": {
                              "key": "Basics/Project/Project"
                            }
                          },
                          {
                            "variable": "resumeEditorFunction",
                            "to": {
                              "key": ":Action",
                              "asset": {
                                "key": "Basics/Function/ResumeEditor",
                                "bindings": []
                              }
                            }
                          },
                          {
                            "variable": "saveAsFunction",
                            "to": {
                              "key": ":Action",
                              "asset": {
                                "key": "Basics/Function/PushScreen",
                                "bindings": [
                                  {
                                    "argument": "menuScreen",
                                    "to": {
                                      "key": ":Screen",
                                      "asset": {
                                        "key": "UI/Layout/SaveAs"
                                      }
                                    }
                                  },
                                  {
                                    "argument": "menu",
                                    "to": {
                                      "key": "UI/VirtualKeyboard/SaveAsPrompt"
                                    }
                                  },
                                  {
                                    "argument": "menuInput",
                                    "to": {
                                      "key": ":InputHandler",
                                      "asset": {
                                        "key": "UI/VirtualKeyboard/SaveAsPrompt"
                                      }
                                    }
                                  }
                                ]
                              }
                            }
                          }
                        ],
                        "code": "if project:canSave() then\n  project:save()\n  resumeEditorFunction:execute()\nelse\n  saveAsFunction:execute()\nend"
                      }
                    }
