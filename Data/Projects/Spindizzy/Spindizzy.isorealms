":{"red":0.39542898535728457,"green":0.39542898535728457,"blue":0.39542898535728457,"alpha":1.0}},"omissions":[]},"Float":{"instances":{"Game Time Limit Countdown Speed":{"value":1.0}},"omissions":[]},"Function":{"instances":{"Application Quit":{"bindings":[{"variable":"project","to":{"key":"Project"}}],"arguments":[],"code":"project:finish(false)"},"Equilibria Activate State":{"bindings":[{"variable":"switchIconPrimary","to":{"key":"UI/Layout/Equilibria HUD/SwitchStatePrimary"}},{"variable":"switchIconSecondary","to":{"key":"UI/Layout/Equilibria HUD/SwitchStateSecondary"}},{"variable":"hintIcon","to":{"key":"UI/Layout/Equilibria HUD/Hint"}}],"arguments":[{"name":"State","luaName":"switchState","type":{"key":"Equilibria/Terrain State"}},{"name":"Icon","luaName":"switchIcon","type":{"key":"Screen"}},{"name":"Sound","luaName":"sound","type":{"key":"Action"}}],"code":"if activeSwitchA ~= switchState or activeSwitchB ~= nil then\nsound:execute()\nnextSwitch = 1\nif activeSwitchA ~= nil then\n  activeSwitchA:setValue(false)\nend\nif activeSwitchB ~= nil then\n  activeSwitchB:setValue(false)\n  switchIconSecondary:setScreen(nil)\n  activeSwitchB = nil\nend\nswitchState:setValue(true)\nif disableHud == nil then\n  switchIconPrimary:setScreen(switchIcon)\nend\nactiveSwitchA = switchState;\n\n-- Update the hint icon\nif currentZone ~= nil and disableHud == nil then\n  local hintCount = currentZone:getHintCount()\n  if hintCount > 0 then\n    currentZone:giveHint(0)\n  else\n    hintIcon:setScreen(nil)\n  end\nend\nend"},"Equilibria Activate State (retain last state)":{"bindings":[{"variable":"switchIconPrimary","to":{"key":"UI/Layout/Equilibria HUD/SwitchStatePrimary"}},{"variable":"switchIconSecondary","to":{"key":"UI/Layout/Equilibria HUD/SwitchStateSecondary"}},{"variable":"hintIcon","to":{"key":"UI/Layout/Equilibria HUD/Hint"}}],"arguments":[{"name":"switchState","luaName":"switchState","type":{"key":"Equilibria/Terrain State"}},{"name":"switchIcon","luaName":"switchIcon","type":{"key":"Screen"}},{"name":"sound","luaName":"sound","type":{"key":"Action"}}],"code":"if activeSwitchA ~= switchState and activeSwitchB ~= switchState then\nsound:execute()\nif nextSwitch == 1 then\n  if activeSwitchB ~= nil then\n    activeSwitchB:setValue(false)\n  end\n  activeSwitchB = switchState\n  if disableHud == nil then\n    switchIconSecondary:setScreen(switchIcon)\n  end\n  nextSwitch = 0\nelse\n  if activeSwitchA ~= nil then\n    activeSwitchA:setValue(false)\n  end\n  activeSwitchA = switchState\n  if disableHud == nil then\n    switchIconPrimary:setScreen(switchIcon)\n  end\n  nextSwitch = 1\nend\nswitchState:setValue(true)\n\n-- Update the hint icon\nif currentZone ~= nil and disableHud == nil then\n  local hintCount = currentZone:getHintCount()\n  if hintCount > 0 then\n    currentZone:giveHint(0)\n  else\n    hintIcon:setScreen(nil)\n  end\nend\nend"},"Equilibria Deactivate All States":{"bindings":[{"variable":"switchIconPrimary","to":{"key":"UI/Layout/Equilibria HUD/SwitchStatePrimary"}},{"variable":"switchIconSecondary","to":{"key":"UI/Layout/Equilibria HUD/SwitchStateSecondary"}},{"variable":"hintIcon","to":{"key":"UI/Layout/Equilibria HUD/Hint"}},{"variable":"sound","to":{"key":":Action","asset":{"key":"Basics/Sound/Deactivate All States"}}}],"arguments":[],"code":"if activeSwitchA ~= nil then\n  sound:execute()\n  nextSwitch = 0\n  activeSwitchA:setValue(false)\n  switchIconPrimary:setScreen(nil)\n  activeSwitchA = nil\n  if activeSwitchB ~= nil then\n    activeSwitchB:setValue(false)\n    switchIconSecondary:setScreen(nil)\n    activeSwitchB = nil\n  end\n\n  -- Update the hint icon\n  if currentZone ~= nil and disableHud == nil then\n    local hintCount = currentZone:getHintCount()\n    if hintCount > 0 then\n      currentZone:giveHint(0)\n    else\n      hintIcon:setScreen(nil)\n    end\n  end\nend"},"Equilibria Game Pause":{"bindings":[{"variable":"gameTimeLimit","to":{"key":"Basics/Sequence/Timer (Game Time Limit)/Instance"}},{"variable":"equilibria","to":{"key":"Equilibria"}},{"variable":"screenSwitch","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"screenMenu","to":{"key":":Screen","asset":{"key":"UI/Menu/Pause"}}},{"variable":"menu","to":{"key":"UI/Menu/Pause"}},{"variable":"inputSwitchFE","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"inputHandlerMenu","to":{"key":":InputHandler","asset":{"key":"UI/Menu/Pause"}}},{"variable":"sound","to":{"key":"Basics/Sequence/Alien Damage (Sound Loop)/Instance"}},{"variable":"damage","to":{"key":"Basics/Sequence/Alien Damage (Screen Border Effect)/Instance"}},{"variable":"mainInput","to":{"key":"Basics/InputSwitch/Main"}},{"variable":"optionsInput","to":{"key":":InputHandler","asset":{"key":"Basics/InputSwitch/Options Screen"}}}],"arguments":[],"code":"if hasFocus then\n\n  -- Pause the game\n  locks = locks + 1\n  if locks == 1 then\n    equilibria:setPause(true)\n    gameTimeLimit:pause()\n    if alienContactCount > 0 then\n      sound:pause()\n      damage:pause()\n    end\n  end\n  hasFocus = false\n\n  -- Show the menu\n  table.insert(gMenuScreenStack, screenMenu)\n  table.insert(gMenuInputStack, inputHandlerMenu)\n  screenSwitch:setScreen(screenMenu)\n  menu:reset()\n  inputSwitchFE:setInputHandler(inputHandlerMenu)\n  mainInput:setInputHandler(optionsInput)\nend"},"Equilibria Game Unpause":{"bindings":[{"variable":"gameTimeLimit","to":{"key":"Basics/Sequence/Timer (Game Time Limit)/Instance"}},{"variable":"equilibria","to":{"key":"Equilibria"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"menuInput","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"mainInput","to":{"key":"Basics/InputSwitch/Main"}},{"variable":"gameControls","to":{"key":":InputHandler","asset":{"key":"Basics/InputGroup/Equilibria Game Controls"}}},{"variable":"sound","to":{"key":"Basics/Sequence/Alien Damage (Sound Loop)/Instance"}},{"variable":"damage","to":{"key":"Basics/Sequence/Alien Damage (Screen Border Effect)/Instance"}}],"arguments":[],"code":"-- Unpause the game\nlocks = locks - 1\nif locks == 0 then\n  equilibria:setPause(false)\n  if GlobalExplorer ~= 1 then\n    gameTimeLimit:play()\n  end\n  if alienContactCount > 0 then\n    sound:play()\n    damage:play()\n  end\nend\nhasFocus = true\n\n-- Remove the menu\nwhile #gMenuScreenStack > 0 do\n  table.remove(gMenuScreenStack)\n  table.remove(gMenuInputStack)\nend\nscreen:setScreen(nil)\nmenuInput:setInputHandler(nil)\nmainInput:setInputHandler(gameControls)"},"Equilibria Handle Zone Entered":{"bindings":[{"variable":"score","to":{"key":"Basics/Integer/Score"}},{"variable":"gameTimeLimit","to":{"key":"Basics/Sequence/Timer (Game Time Limit)/Instance"}},{"variable":"zoneCount","to":{"key":"Basics/Integer/Remaining Zones Count"}},{"variable":"hintIcon","to":{"key":"UI/Layout/Equilibria HUD/Hint"}},{"variable":"themeSet","to":{"key":"Equilibria/ThemeSet/C64"}},{"variable":"topDebris","to":{"key":"Equilibria/World/Game World/DebrisGenerator/Top"}},{"variable":"ballDebris","to":{"key":"Equilibria/World/Game World/DebrisGenerator/Ball"}},{"variable":"gyroscopeDebris","to":{"key":"Equilibria/World/Game World/DebrisGenerator/Gyroscope"}},{"variable":"view","to":{"key":"Equilibria/WorldView/Game View"}},{"variable":"jewelsCollected","to":{"key":":Integer","asset":{"key":"Basics/Integer/Collected Jewel Count"}}},{"variable":"hangworld","to":{"key":"Equilibria/World/Game World"}},{"variable":"ending","to":{"key":":Action","asset":{"key":"Basics/Function/Equilibria Play Ending Cutscene","bindings":[]}}},{"variable":"mandatoryZoneTime","to":{"key":"Basics/Sequence/Timer (Minimum Zone Visible Time)/Instance"}},{"variable":"equilibria","to":{"key":"Equilibria"}},{"variable":"currentZoneColour","to":{"key":":Colour","asset":{"key":"Basics/Sequence/Colour Cycle (Overview Current Zone)/Instance/Colour"}}},{"variable":"sound","to":{"key":"Basics/Sequence/Alien Damage (Sound Loop)/Instance"}},{"variable":"damage","to":{"key":"Basics/Sequence/Alien Damage (Screen Border Effect)/Instance"}}],"arguments":[],"code":"-- Delay entry to the previous zone when leaving too quickly.\nif mandatoryZoneTime:getTime() > 200 or entered ~= previousZone then\n\n  -- Clear all debris from the screen.\n  if entered ~= exitedZone then\n    topDebris:clear()\n    ballDebris:clear()\n    gyroscopeDebris:clear()\n  end\n\n  -- Keep track of the current zone and the previous zone.\n  previousZone = currentZone\n  currentZone = entered\n\n  -- Update timer, score, and overview if this is the first time visiting the zone.\n  -- TODO: Can test colour from zone to determine if visited.\n  if entered:isVisited() == false then\n    zoneCount:setValue(zoneCount:getValue() - 1)\n    local earned = 400\n    local newTime = gameTimeLimit:getTime() - 8000\n    -- Any time to add beyond the 3-minute cap is converted to additional score bonus.\n    if newTime < 0 then\n      local excess = -newTime\n      local extraScore = excess / 10\n      earned = earned + extraScore\n      newTime = 0\n    end\n    gameTimeLimit:setTime(newTime)\n    score:setValue(math.floor(score:getValue() + earned))\n\n    -- Set that the zone has been visited.\n    entered:setVisited()\n  end\n\n  -- Set the colour on the overview to show where we are.\n  enteredColour:setColour(currentZoneColour)\n\n  -- Set the zone to show in our view.\n  view:setZone(entered)\n\n  -- Set the default theme to use in the UI.\n  theme = entered:getTheme()\n  themeSet:setDefaultTheme(theme)\n\n  -- Activate dynamic objects in the zone.\n  entered:resetDynamics()\n  entered:setActive(true)\n\n  -- Update the hint icon\n  if disableHud == nil then\n    local hintCount = currentZone:getHintCount()\n    if hintCount > 0 then\n      currentZone:giveHint(0)\n    else\n      hintIcon:setScreen(nil)\n    end\n  end\n\n  -- Do we show the ending yet?\n  if zoneCount:getValue() == 0 and hangworld:getPickUpCount() == jewelsCollected:getValue() then\n    ending:execute()\n  end\n  mandatoryZoneTime:setTime(0);\nelse\n  -- The entrance delay is implemented by momentarily pausing the game.\n  zoneToEnter = entered\n  equilibria:setPause(true)\n  gameTimeLimit:pause()\n  if alienContactCount > 0 then\n    sound:pause()\n    damage:pause()\n  end\nend"},"Equilibria Handle Zone Exited":{"bindings":[{"variable":"doneColour","to":{"key":":Colour","asset":{"key":"Basics/Colour/C64 Palette 8"}}},{"variable":"missedColour","to":{"key":":Colour","asset":{"key":"Basics/Colour/C64 Palette 5"}}}],"arguments":[],"code":"exitedZone = exited\nif exited ~= nil then\n  exited:setActive(false)\n  exited:resetLifts()\n\n  if exited:getRemainingPickUpCount() > 0 then\n    exitedColour:setColour(missedColour)\n  else\n    exitedColour:setColour(doneColour)\n  end\n  exitedColour = nil\nend"},"Equilibria Play Ending Cutscene":{"bindings":[{"variable":"endingSequence","to":{"key":"Basics/Sequence/Ending (Mission Success)/Instance"}},{"variable":"project","to":{"key":"Project"}},{"variable":"endingMessage","to":{"key":"Basics/String/Message End Cause"}},{"variable":"scoreMessage","to":{"key":"Basics/String/Message Score"}},{"variable":"mappedMessage","to":{"key":"Basics/String/Message World Explored"}},{"variable":"jewelsMessage","to":{"key":"Basics/String/Message Jewels Collected"}},{"variable":"completeMessage","to":{"key":"Basics/String/Message Completion"}},{"variable":"score","to":{"key":":Integer","asset":{"key":"Basics/Integer/Score"}}},{"variable":"gameTimeLimit","to":{"key":"Basics/Sequence/Timer (Game Time Limit)/Instance"}},{"variable":"equilibria","to":{"key":"Equilibria"}},{"variable":"sound","to":{"key":"Basics/Sequence/Alien Damage (Sound Loop)/Instance"}},{"variable":"damage","to":{"key":"Basics/Sequence/Alien Damage (Screen Border Effect)/Instance"}}],"arguments":[],"code":"-- Prevent menu access, etc.\nhasFocus = false\n\n-- Set result values\nendingMessage:setValue(\"Map Complete: Mission Success\")\nmappedMessage:setValue(\"100%\")\njewelsMessage:setValue(\"100%\")\ncompleteMessage:setValue(\"100%\")\nscoreMessage:setValue(\"\" .. score:getValue())\n\n-- Pause the game\nequilibria:setPause(true)\ngameTimeLimit:pause()\nif alienContactCount > 0 then\n  sound:pause()\n  damage:pause()\nend\n\n-- Play the ending\nendingSequence:play()"},"Equilibria Play Random Lift Click":{"bindings":[{"variable":"click1","to":{"key":":Action","asset":{"key":"Basics/Sound/Lift Click Variant 1"}}},{"variable":"click2","to":{"key":":Action","asset":{"key":"Basics/Sound/Lift Click Variant 2"}}},{"variable":"click3","to":{"key":":Action","asset":{"key":"Basics/Sound/Lift Click Variant 3"}}}],"arguments":[],"code":"local val = math.random(0, 2)\nif val == 0 then\n  click1:execute()\nelseif val == 1 then\n  click2:execute()\nelseif val == 2 then\n  click3:execute()\nend"},"Equilibria Show Terrain State Hint Icon":{"bindings":[{"variable":"hintComponent","to":{"key":"UI/Layout/Equilibria HUD/Hint"}}],"arguments":[{"name":"hintIcon","luaName":"hintIcon","type":{"key":"Screen"}}],"code":"if disableHud == nil then\n  hintComponent:setScreen(hintIcon)\nend"}},"omissions":[]},"InputGroup":{"instances":{"Equilibria Game Controls":{"inputs":[{"input":{"key":"Basics/AnalogueControl/GERALD Movement X"}},{"input":{"key":"Basics/AnalogueControl/GERALD Movement Y"}},{"input":{"key":"Basics/DigitalControl/GERALD Thrust"}},{"input":{"key":"Basics/DigitalControl/GERALD Brake"}},{"input":{"key":"Basics/DigitalControl/GERALD Transform"}},{"input":{"key":"Basics/DigitalControl/GERALD Destruct"}},{"input":{"key":"Basics/DigitalControl/Camera Reset"}},{"input":{"key":"Basics/DigitalControl/Camera Reverse"}},{"input":{"key":"Basics/DigitalControl/Camera Rotate Left"}},{"input":{"key":"Basics/DigitalControl/Camera Rotate Right"}},{"input":{"key":"Basics/DigitalControl/Toggle Pause"}},{"input":{"key":"Basics/DigitalControl/Toggle Map"}}]}},"omissions":[]},"InputSwitch":{"instances":{"Main":{"value":{"key":"Basics/InputGroup/Equilibria Game Controls"}}},"omissions":[]},"I