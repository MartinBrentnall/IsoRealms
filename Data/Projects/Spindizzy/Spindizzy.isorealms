        "Function": {
          "instances": {
            "Activate State": {
              "bindings": [
                {
                  "variable": "switchIconPrimary",
                  "to": {
                    "key": "UI/Layout/Layout/SwitchStatePrimary"
                  }
                },
                {
                  "variable": "switchIconSecondary",
                  "to": {
                    "key": "UI/Layout/Layout/SwitchStateSecondary"
                  }
                },
                {
                  "variable": "hintIcon",
                  "to": {
                    "key": "UI/Layout/Layout/Hint"
                  }
                }
              ],
              "arguments": [
                {
                  "name": "switchState",
                  "type": {
                    "key": "Spindizzy/Terrain State"
                  }
                },
                {
                  "name": "switchIcon",
                  "type": {
                    "key": "Screen"
                  }
                },
                {
                  "name": "sound",
                  "type": {
                    "key": "Action"
                  }
                }
              ],
              "code": "if activeSwitchA ~= switchState or activeSwitchB ~= nil then\nsound:execute()\nnextSwitch = 1\nif activeSwitchA ~= nil then\n  activeSwitchA:setValue(false)\nend\nif activeSwitchB ~= nil then\n  activeSwitchB:setValue(false)\n  switchIconSecondary:setScreen(nil)\n  activeSwitchB = nil\nend\nswitchState:setValue(true)\nif disableHud == nil then\n  switchIconPrimary:setScreen(switchIcon)\nend\nactiveSwitchA = switchState;\n\n-- Update the hint icon\nif currentZone ~= nil and disableHud == nil then\n  local hintCount = currentZone:getHintCount()\n  if hintCount > 0 then\n    currentZone:giveHint(0)\n  else\n    hintIcon:setScreen(nil)\n  end\nend\nend"
            },
            "Activate State (retain last state)": {
              "bindings": [
                {
                  "variable": "switchIconPrimary",
                  "to": {
                    "key": "UI/Layout/Layout/SwitchStatePrimary"
                  }
                },
                {
                  "variable": "switchIconSecondary",
                  "to": {
                    "key": "UI/Layout/Layout/SwitchStateSecondary"
                  }
                },
                {
                  "variable": "hintIcon",
                  "to": {
                    "key": "UI/Layout/Layout/Hint"
                  }
                }
              ],
              "arguments": [
                {
                  "name": "switchState",
                  "type": {
                    "key": "Spindizzy/Terrain State"
                  }
                },
                {
                  "name": "switchIcon",
                  "type": {
                    "key": "Screen"
                  }
                },
                {
                  "name": "sound",
                  "type": {
                    "key": "Action"
                  }
                }
              ],
              "code": "if activeSwitchA ~= switchState and activeSwitchB ~= switchState then\nsound:execute()\nif nextSwitch == 1 then\n  if activeSwitchB ~= nil then\n    activeSwitchB:setValue(false)\n  end\n  activeSwitchB = switchState\n  if disableHud == nil then\n    switchIconSecondary:setScreen(switchIcon)\n  end\n  nextSwitch = 0\nelse\n  if activeSwitchA ~= nil then\n    activeSwitchA:setValue(false)\n  end\n  activeSwitchA = switchState\n  if disableHud == nil then\n    switchIconPrimary:setScreen(switchIcon)\n  end\n  nextSwitch = 1\nend\nswitchState:setValue(true)\n\n-- Update the hint icon\nif currentZone ~= nil and disableHud == nil then\n  local hintCount = currentZone:getHintCount()\n  if hintCount > 0 then\n    currentZone:giveHint(0)\n  else\n    hintIcon:setScreen(nil)\n  end\nend\nend"
            },
            "Handle Zone Exited": {
              "bindings": [
                {
                  "variable": "doneColour",
                  "to": {
                    "key": ":Colour",
                    "asset": {
                      "key": "Basics/Colour/Yellow"
                    }
                  }
                },
                {
                  "variable": "missedColour",
                  "to": {
                    "key": ":Colour",
                    "asset": {
                      "key": "Basics/Colour/Purple"
                    }
                  }
                }
              ],
              "arguments": [],
              "code": "exitedZone = exited\nif exited ~= nil then\n  exited:setActive(false)\n  exited:resetLifts()\n\n  if exited:getRemainingPickUpCount() > 0 then\n    exitedColour:setColour(missedColour)\n  else\n    exitedColour:setColour(doneColour)\n  end\n  exitedColour = nil\nend"
            },
            "Pause Game": {
              "bindings": [
                {
                  "variable": "gameTimeLimit",
                  "to": {
                    "key": "Basics/Sequence/Time Limit/Instance"
                  }
                },
                {
                  "variable": "spindizzy",
                  "to": {
                    "key": "Spindizzy"
                  }
                },
                {
                  "variable": "screenSwitch",
                  "to": {
                    "key": "UI/Layout/Main/Menu"
                  }
                },
                {
                  "variable": "screenMenu",
                  "to": {
                    "key": ":Screen",
                    "asset": {
                      "key": "UI/Menu/Pause"
                    }
                  }
                },
                {
                  "variable": "menu",
                  "to": {
                    "key": "UI/Menu/Pause"
                  }
                },
                {
                  "variable": "inputSwitchFE",
                  "to": {
                    "key": "Basics/InputSwitch/Options Screen"
                  }
                },
                {
                  "variable": "inputHandlerMenu",
                  "to": {
                    "key": ":InputHandler",
                    "asset": {
                      "key": "UI/Menu/Pause"
                    }
                  }
                },
                {
                  "variable": "sound",
                  "to": {
                    "key": "Basics/Sequence/DamageSound/Instance"
                  }
                },
                {
                  "variable": "damage",
                  "to": {
                    "key": "Basics/Sequence/DamageVisual/Instance"
                  }
                },
                {
                  "variable": "mainInput",
                  "to": {
                    "key": "Basics/InputSwitch/Main"
                  }
                },
                {
                  "variable": "optionsInput",
                  "to": {
                    "key": ":InputHandler",
                    "asset": {
                      "key": "Basics/InputSwitch/Options Screen"
                    }
                  }
                }
              ],
              "arguments": [],
              "code": "if hasFocus then\n\n  -- Pause the game\n  locks = locks + 1\n  if locks == 1 then\n    spindizzy:setPause(true)\n    gameTimeLimit:pause()\n    if alienContactCount > 0 then\n      sound:pause()\n      damage:pause()\n    end\n  end\n  hasFocus = false\n\n  -- Show the menu\n  table.insert(menuStack, screenMenu)\n  table.insert(inputStack, inputHandlerMenu)\n  screenSwitch:setScreen(screenMenu)\n  menu:reset()\n  inputSwitchFE:setInputHandler(inputHandlerMenu)\n  mainInput:setInputHandler(optionsInput)\nend"
            },
            "Play Random Lift Click": {
              "bindings": [
                {
                  "variable": "click1",
                  "to": {
                    "key": ":Action",
                    "asset": {
                      "key": "Basics/Sound/LiftClick1"
                    }
                  }
                },
                {
                  "variable": "click2",
                  "to": {
                    "key": ":Action",
                    "asset": {
                      "key": "Basics/Sound/LiftClick2"
                    }
                  }
                },
                {
                  "variable": "click3",
                  "to": {
                    "key": ":Action",
                    "asset": {
                      "key": "Basics/Sound/LiftClick3"
                    }
                  }
                }
              ],
              "arguments": [],
              "code": "local val = math.random(0, 2)\nif val == 0 then\n  click1:execute()\nelseif val == 1 then\n  click2:execute()\nelseif val == 2 then\n  click3:execute()\nend"
            },
            "Quit": {
              "bindings": [
                {
                  "variable": "project",
                  "to": {
                    "key": "Project"
                  }
                }
              ],
              "arguments": [],
              "code": "project:finish(false)"
            },
            "Reset States": {
              "bindings": [
                {
                  "variable": "switchIconPrimary",
                  "to": {
                    "key": "UI/Layout/Layout/SwitchStatePrimary"
                  }
                },
                {
                  "variable": "switchIconSecondary",
                  "to": {
                    "key": "UI/Layout/Layout/SwitchStateSecondary"
                  }
                },
                {
                  "variable": "hintIcon",
                  "to": {
                    "key": "UI/Layout/Layout/Hint"
                  }
                },
                {
                  "variable": "sound",
                  "to": {
                    "key": ":Action",
                    "asset": {
                      "key": "Basics/Sound/DiamondNone"
                    }
                  }
                }
              ],
              "arguments": [],
              "code": "if activeSwitchA ~= nil then\n  sound:execute()\n  nextSwitch = 0\n  activeSwitchA:setValue(false)\n  switchIconPrimary:setScreen(nil)\n  activeSwitchA = nil\n  if activeSwitchB ~= nil then\n    activeSwitchB:setValue(false)\n    switchIconSecondary:setScreen(nil)\n    activeSwitchB = nil\n  end\n\n  -- Update the hint icon\n  if currentZone ~= nil and disableHud == nil then\n    local hintCount = currentZone:getHintCount()\n    if hintCount > 0 then\n      currentZone:giveHint(0)\n    else\n      hintIcon:setScreen(nil)\n    end\n  end\nend"
            },
            "Show Hint": {
              "bindings": [
                {
                  "variable": "hintComponent",
                  "to": {
                    "key": "UI/Layout/Layout/Hint"
                  }
                }
              ],
              "arguments": [
                {
                  "name": "hintIcon",
                  "type": {
                    "key": "Screen"
                  }
                }
              ],
              "code": "if disableHud == nil then\n  hintComponent:setScreen(hintIcon)\nend"
            },
            "ShowScreen": {
              "bindings": [],
              "arguments": [
                {
                  "name": "screenSwitch",
                  "type": {
                    "key": "Any"
                  }
                },
                {
                  "name": "screen",
                  "type": {
                    "key": "Screen"
                  }
                }
              ],
              "code": "screenSwitch:setScreen(screen)"
            },
            "Unpause Game": {
              "bindings": [
                {
                  "variable": "gameTimeLimit",
                  "to": {
                    "key": "Basics/Sequence/Time Limit/Instance"
                  }
                },
                {
                  "variable": "spindizzy",
                  "to": {
                    "key": "Spindizzy"
                  }
                },
                {
                  "variable": "screen",
                  "to": {
                    "key": "UI/Layout/Main/Menu"
                  }
                },
                {
                  "variable": "menuInput",
                  "to": {
                    "key": "Basics/InputSwitch/Options Screen"
                  }
                },
                {
                  "variable": "mainInput",
                  "to": {
                    "key": "Basics/InputSwitch/Main"
                  }
                },
                {
                  "variable": "gameControls",
                  "to": {
                    "key": ":InputHandler",
                    "asset": {
                      "key": "Basics/InputGroup/SpindizzyGameControls"
                    }
                  }
                },
                {
                  "variable": "sound",
                  "to": {
                    "key": "Basics/Sequence/DamageSound/Instance"
                  }
                },
                {
                  "variable": "damage",
                  "to": {
                    "key": "Basics/Sequence/DamageVisual/Instance"
                  }
                }
              ],
              "arguments": [],
              "code": "-- Unpause the game\nlocks = locks - 1\nif locks == 0 then\n  spindizzy:setPause(false)\n  if GlobalExplorer ~= 1 then\n    gameTimeLimit:play()\n  end\n  if alienContactCount > 0 then\n    sound:play()\n    damage:play()\n  end\nend\nhasFocus = true\n\n-- Remove the menu\nwhile #menuStack > 0 do\n  table.remove(menuStack)\n  table.remove(inputStack)\nend\nscreen:setScreen(nil)\nmenuInput:setInputHandler(nil)\nmainInput:setInputHandler(gameControls)"
            }
          },
          "omissions": []
        },
