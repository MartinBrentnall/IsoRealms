{"project":{"description":"Game Mechanics and Assets","include":[{"filename":{"path":"Projects/Spindizzy/Options.isorealms"}}],"screen":{"key":"UI/Layout/Main"},"input":{"key":"Basics/InputSwitch/Main"},"editor":{"key":"Equilibria/World/Game World"},"initialisation":{"key":"Basics/Script","bindings":[{"variable":"zoneCount","to":{"key":"Basics/Integer/Remaining Zones Count"}},{"variable":"hangworld","to":{"key":"Equilibria/World/Game World"}},{"variable":"optionsLoader","to":{"key":":Action","asset":{"key":"Basics/Function/Options Reload Configuration","bindings":[]}}}],"code":"gMenuScreenStack = {}\ngMenuInputStack = {}\nzoneCount:setValue(hangworld:getZoneCount())\nmapOverviewMode = 0\nspinType = 0\nhasFocus = true\nlocks = 0\nalienContactCount = 0\n\n-- print(\"EXECUTE RELOAD...\")\noptionsLoader:execute()"},"reset":{"key":"Basics/Script","bindings":[{"variable":"zoneCount","to":{"key":"Basics/Integer/Remaining Zones Count"}},{"variable":"hangworld","to":{"key":"Equilibria/World/Game World"}},{"variable":"player","to":{"key":"Equilibria/World/Game World/Player"}},{"variable":"switchIconPrimary","to":{"key":"UI/Layout/Equilibria HUD/SwitchStatePrimary"}},{"variable":"switchIconSecondary","to":{"key":"UI/Layout/Equilibria HUD/SwitchStateSecondary"}},{"variable":"view","to":{"key":"Equilibria/WorldView/Game View"}},{"variable":"equilibria","to":{"key":"Equilibria"}},{"variable":"options","to":{"key":"Options"}},{"variable":"replayer","to":{"key":"Replay/Replayer/Gameplay Recorder"}},{"variable":"hudComponent","to":{"key":"UI/Layout/Main/Equilibria HUD"}}],"code":"-- Start recording if specified\nlocal mReplayerMode = options:getOption(\"Replayer\")\nif mReplayerMode == \"Recording\" then\n  local mReplayerFile = options:getOption(\"File\")\n  replayer:setRecording(mReplayerFile)\nelseif mReplayerMode == \"Replaying\" then\n  local mReplayerFile = options:getOption(\"File\")\n  local mReplayerUser = options:getOption(\"User\")\n  replayer:setReplaying(mReplayerFile, mReplayerUser == \"true\")\nelse\n  replayer:setInactive()\nend\n\n-- Option to make the HUD invisible (for attract mode).\nlocal mHUD = options:getOption(\"Show HUD\")\nif mHUD == \"false\" then\n  hudComponent:setScreen(nil)\nend\n\n-- Reset Lua variables\nmapOverviewMode = 0\nspinType = 0\nhasFocus = true\nlocks = 0\nalienContactCount = 0\nfirstZoneEntered = 0\n\n-- Unpause the game\nequilibria:setPause(false)\n\n-- Reset zone count\nzoneCount:setValue(hangworld:getZoneCount())\n\n-- Reset switches\nif activeSwitchA ~= nil then\n  nextSwitch = 0\n  activeSwitchA:setValue(false)\n  switchIconPrimary:setScreen(nil)\n  activeSwitchA = nil\n  if activeSwitchB ~= nil then\n    activeSwitchB:setValue(false)\n    switchIconSecondary:setScreen(nil)\n    activeSwitchB = nil\n  end\nend"},"start":{"key":"Basics/Script","bindings":[{"variable":"application","to":{"key":"Application"}}],"code":"application:setName(\"IsoRealms Equilibria\")"},"quit":{"key":"Quit"},"launchConfigurations":{"Record Demo":{"options":{"Replayer":{"key":"Literal","value":"Recording"},"File":{"key":"Literal","value":"Demo.recording"}}},"Replay Demo":{"options":{"Replayer":{"key":"Literal","value":"Replaying"},"File":{"key":"Literal","value":"Demo.recording"},"User":{"key":"Literal","value":"true"}}},"Test Arcade":{"options":{}},"Replay Demo (no HUD)":{"options":{"Replayer":{"key":"Literal","value":"Replaying"},"File":{"key":"Literal","value":"Demo.recording"},"User":{"key":"Literal","value":"true"},"Show HUD":{"key":"Literal","value":"false"}}}},"modules":{"Equilibria":{"Alien":{"instances":{"Enemy Type 1":{"appearance":{"key":"Equilibria/ModelCycler/Alien Craft/1"},"target":{"key":"Equilibria/World/Game World/Player","x":-4.5,"y":3.5},"friction":0.0010000000474974514},"Enemy Type 2":{"appearance":{"key":"Equilibria/ModelCycler/Alien Craft/2"},"target":{"key":"Equilibria/World/Game World/Player","x":-4.5,"y":3.5},"friction":0.0010000000474974514,"spinSpeed":-360.0}},"omissions":[]},"BoundaryHandler":{"instances":{"GERALD Collects Jewels":{"boundary":{"key":"PickUp/Jewel"},"object":{"key":"Player/Player"},"onEntry":{"key":"Basics/Script","bindings":[{"variable":"sound","to":{"key":":Action","asset":{"key":"Basics/Sound/Jewel Collected"}}},{"variable":"score","to":{"key":"Basics/Integer/Score"}},{"variable":"gameTimeLimit","to":{"key":"Basics/Sequence/Timer (Game Time Limit)/Instance"}},{"variable":"jewelsCollected","to":{"key":"Basics/Integer/Collected Jewel Count"}},{"variable":"zone","to":{"key":"~","local":"Boundary/Zone"}},{"variable":"zoneCount","to":{"key":":Integer","asset":{"key":"Basics/Integer/Remaining Zones Count"}}},{"variable":"hangworld","to":{"key":"Equilibria/World/Game World"}},{"variable":"ending","to":{"key":":Action","asset":{"key":"Basics/Function/Equilibria Play Ending Cutscene","bindings":[]}}}],"code":"sound:execute()\njewelsCollected:setValue(jewelsCollected:getValue() + 1)\nlocal earned = 600\nlocal newTime = gameTimeLimit:getTime() - 12000\nif newTime < 0 then\n  local excess = -newTime\n  local extraScore = excess / 10\n  earned = earned + extraScore\n  newTime = 0\nend\ngameTimeLimit:setTime(newTime)\n\nscore:setValue(math.floor(score:getValue() + earned))\n\n-- Do we show the ending yet?\nif zoneCount:getValue() == 0 and hangworld:getPickUpCount() == jewelsCollected:getValue() then\n  ending:execute()\nend"},"onExit":{"key":"None"}},"GERALD Explores Zones":{"boundary":{"key":"Zone/Zone"},"object":{"key":"Player/Player"},"onEntry":{"key":"Basics/Script","bindings":[{"variable":"zone","to":{"key":"~","local":"Boundary/Zone"}},{"variable":"zoneColour","to":{"key":"~","local":"Boundary/Zone/WorldView/World Map/ZoneView"}},{"variable":"zoneEnterFunction","to":{"key":":Action","asset":{"key":"Basics/Function/Equilibria Handle Zone Entered","bindings":[]}}},{"variable":"optionsLoader","to":{"key":":Action","asset":{"key":"Basics/Function/Options Reload Configuration","bindings":[]}}}],"code":"-- Hack to reload the controls when starting the game.\nif firstZoneEntered == 0 then\n  optionsLoader:execute()\n  firstZoneEntered = 1\nend\nentered = zone\nenteredColour = zoneColour\nzoneEnterFunction:execute()"},"onExit":{"key":"Basics/Script","bindings":[{"variable":"zone","to":{"key":"~","local":"Boundary/Zone"}},{"variable":"zoneColour","to":{"key":"~","local":"Boundary/Zone/WorldView/World Map/ZoneView"}},{"variable":"zoneExitFunction","to":{"key":":Action","asset":{"key":"Basics/Function/Equilibria Handle Zone Exited","bindings":[]}}}],"code":"exited = zone\nexitedColour = zoneColour\nzoneExitFunction:execute()"}}},"omissions":[]},"CollisionHandler":{"instances":{"GERALD Takes Damage from Alien Type 1":{"objectA":{"key":"Player/Player"},"objectB":{"key":"Alien/Enemy Type 1"},"onCollision":{"key":"Basics/Script","bindings":[{"variable":"sound","to":{"key":"Basics/Sequence/Alien Damage (Sound Loop)/Instance"}},{"variable":"damage","to":{"key":"Basics/Sequence/Alien Damage (Screen Border Effect)/Instance"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Alien Damage Indicator"}},{"variable":"indicator","to":{"key":":Screen","asset":{"key":"UI/Layout/Equilibria Damage Indicator"}}},{"variable":"timeSpeed","to":{"key":"Basics/Float/Game Time Limit Countdown Speed"}}],"code":"if alienContactCount == 0 then\n  sound:play()\n  damage:play()\n  screen:setScreen(indicator)\nend\nalienContactCount = alienContactCount + 1\ntimeSpeed:setValue(1.0 + alienContactCount * 20.0)"},"onParting":{"key":"Basics/Script","bindings":[{"variable":"sound","to":{"key":"Basics/Sequence/Alien Damage (Sound Loop)/Instance"}},{"variable":"damage","to":{"key":"Basics/Sequence/Alien Damage (Screen Border Effect)/Instance"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Alien Damage Indicator"}},{"variable":"timeSpeed","to":{"key":"Basics/Float/Game Time Limit Countdown Speed"}}],"code":"alienContactCount = alienContactCount - 1\nif alienContactCount == 0 then\n  sound:pause()\n  damage:pause()\n  screen:setScreen(nil)\nend\ntime