{
  "project": {
    "include": [
      {
        "filename": "Projects/Spindizzy/Options.isorealms"
      }
    ],
    "screen": {
      "key": "UI/Layout/Main"
    },
    "input": {
      "key": "Basics/InputSwitch/Main"
    },
    "editor": {
      "key": "Spindizzy/World/Hangworld"
    },
    "initialisation": {
      "key": "Basics/Script",
      "bindings": [
        {
          "variable": "zoneCount",
          "to": {
            "key": "Basics/Integer/RemainingZones"
          }
        },
        {
          "variable": "hangworld",
          "to": {
            "key": "Spindizzy/World/Hangworld"
          }
        },
        {
          "variable": "optionsLoader",
          "to": {
            "key": ":Action",
            "asset": {
              "key": "Basics/Function/ReloadConfiguration",
              "bindings": []
            }
          }
        }
      ],
      "code": "menuStack = {}\ninputStack = {}\nzoneCount:setValue(hangworld:getZoneCount())\nmapOverviewMode = 0\nspinType = 0\nhasFocus = true\nlocks = 0\nalienContactCount = 0\n\n-- print(\"EXECUTE RELOAD...\")\noptionsLoader:execute()"
    },
    "reset": {
      "key": "Basics/Script",
      "bindings": [
        {
          "variable": "zoneCount",
          "to": {
            "key": "Basics/Integer/RemainingZones"
          }
        },
        {
          "variable": "hangworld",
          "to": {
            "key": "Spindizzy/World/Hangworld"
          }
        },
        {
          "variable": "player",
          "to": {
            "key": "Spindizzy/World/Hangworld/Player"
          }
        },
        {
          "variable": "switchIconPrimary",
          "to": {
            "key": "UI/Layout/Layout/SwitchStatePrimary"
          }
        },
        {
          "variable": "switchIconSecondary",
          "to": {
            "key": "UI/Layout/Layout/SwitchStateSecondary"
          }
        },
        {
          "variable": "view",
          "to": {
            "key": "Spindizzy/WorldView/Hangworld"
          }
        },
        {
          "variable": "spindizzy",
          "to": {
            "key": "Spindizzy"
          }
        }
      ],
      "code": "-- Reset Lua variables\nmapOverviewMode = 0\nspinType = 0\nhasFocus = true\nlocks = 0\nalienContactCount = 0\nfirstZoneEntered = 0\n\n-- Unpause the game\nspindizzy:setPause(false)\n\n-- Reset zone count\nzoneCount:setValue(hangworld:getZoneCount())\n\n-- Reset switches\nif activeSwitchA ~= nil then\n  nextSwitch = 0\n  activeSwitchA:setValue(false)\n  switchIconPrimary:setScreen(nil)\n  activeSwitchA = nil\n  if activeSwitchB ~= nil then\n    activeSwitchB:setValue(false)\n    switchIconSecondary:setScreen(nil)\n    activeSwitchB = nil\n  end\nend"
    },
    "quit": {
      "key": "Quit"
    },
    "properties": [
      {
        "id": "Mode",
        "action": {
          "key": "Basics/Script",
          "bindings": [
            {
              "variable": "value",
              "to": {
                "key": "~",
                "local": "value"
              }
            },
            {
              "variable": "gameTimeLimit",
              "to": {
                "key": "Basics/Sequence/Time Limit/Instance"
              }
            },
            {
              "variable": "timeValue",
              "to": {
                "key": "UI/Layout/Layout/ValueTime"
              }
            },
            {
              "variable": "scoreValue",
              "to": {
                "key": "UI/Layout/Layout/ValueScore"
              }
            },
            {
              "variable": "notApplicableTime",
              "to": {
                "key": ":Screen",
                "asset": {
                  "key": "UI/Text",
                  "alignment": "Left",
                  "value": {
                    "key": "Literal",
                    "value": "N/A"
                  },
                  "font": {
                    "key": "Basics/Font/Menu"
                  },
                  "colour": {
                    "key": "Literal",
                    "red": 1,
                    "green": 1,
                    "blue": 1,
                    "alpha": 1
                  }
                }
              }
            },
            {
              "variable": "notApplicableScore",
              "to": {
                "key": ":Screen",
                "asset": {
                  "key": "UI/Text",
                  "alignment": "Right",
                  "value": {
                    "key": "Literal",
                    "value": "N/A"
                  },
                  "font": {
                    "key": "Basics/Font/Menu"
                  },
                  "colour": {
                    "key": "Literal",
                    "red": 1,
                    "green": 1,
                    "blue": 1,
                    "alpha": 1
                  }
                }
              }
            }
          ],
          "code": "if value:getValue() == \"Explorer\" then\n  gameTimeLimit:pause()\n  GlobalExplorer = 1\n  timeValue:setScreen(notApplicableTime)\n  scoreValue:setScreen(notApplicableScore)\nend"
        }
      }
    ],
    "modules": [
      {
        "name": "Basics",
        "configuration": {},
        "resources": [
          {
            "type": "BooleanTrigger",
            "instances": [
              {
                "id": "Transform",
                "value": {
                  "key": "Basics/DigitalInput/Transform"
                },
                "onBecomingTrue": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "playerCraftModels",
                      "to": {
                        "key": "Spindizzy/ModelCycler/Player Craft"
                      }
                    },
                    {
                      "variable": "alienCraftModels",
                      "to": {
                        "key": "Spindizzy/ModelCycler/Alien Craft"
                      }
                    },
                    {
                      "variable": "player",
                      "to": {
                        "key": "Spindizzy/Player/Player"
                      }
                    },
                    {
                      "variable": "alienTypeA",
                      "to": {
                        "key": "Spindizzy/Alien/Ball"
                      }
                    },
                    {
                      "variable": "alienTypeB",
                      "to": {
                        "key": "Spindizzy/Alien/Gyroscope"
                      }
                    }
                  ],
                  "code": "if hasFocus then\n  playerCraftModels:next()\n  alienCraftModels:next()\n  if spinType == 0 then\n    player:setSpinSpeed(0.0)\n    alienTypeA:setSpinSpeed(-360.0)\n    alienTypeB:setSpinSpeed(-180.0)\n    spinType = 1\n  elseif spinType == 1 then\n    player:setSpinSpeed(-360.0)\n    alienTypeA:setSpinSpeed(-180.0)\n    alienTypeB:setSpinSpeed(0.0)\n    spinType = 2\n  else\n    player:setSpinSpeed(-180.0)\n    alienTypeA:setSpinSpeed(0.0)\n    alienTypeB:setSpinSpeed(-360.0)\n    spinType = 0\n  end\nend"
                },
                "onBecomingFalse": {
                  "key": "None"
                }
              },
              {
                "id": "Brake",
                "value": {
                  "key": "Basics/DigitalInput/Brake"
                },
                "onBecomingTrue": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "player",
                      "to": {
                        "key": "Spindizzy/World/Hangworld/Player"
                      }
                    },
                    {
                      "variable": "gameTimeLimit",
                      "to": {
                        "key": "Basics/Sequence/Time Limit/Instance"
                      }
                    }
                  ],
                  "code": "if hasFocus then\n  player:stop()\n  if GlobalExplorer ~= 1 then\n    local newTime = gameTimeLimit:getTime() + 500\n    gameTimeLimit:setTime(newTime)\n  end\nend"
                },
                "onBecomingFalse": {
                  "key": "None"
                }
              },
              {
                "id": "Destruct",
                "value": {
                  "key": "Basics/DigitalInput/Destruct"
                },
                "onBecomingTrue": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "player",
                      "to": {
                        "key": "Spindizzy/World/Hangworld/Player"
                      }
                    },
                    {
                      "variable": "soundImpactHard",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Sound/ImpactHard"
                        }
                      }
                    },
                    {
                      "variable": "topDebris",
                      "to": {
                        "key": "Spindizzy/World/Hangworld/DebrisGenerator/Top"
                      }
                    },
                    {
                      "variable": "ballDebris",
                      "to": {
                        "key": "Spindizzy/World/Hangworld/DebrisGenerator/Ball"
                      }
                    },
                    {
                      "variable": "gyroscopeDebris",
                      "to": {
                        "key": "Spindizzy/World/Hangworld/DebrisGenerator/Gyroscope"
                      }
                    }
                  ],
                  "code": "if hasFocus and player:isAlive() then\n  location = player:getLocation()\n  momentum = player:getMomentum()\n  xMomentum = momentum:getX()\n  yMomentum = momentum:getY()\n  zMomentum = momentum:getZ()\n  player:destroy()\n  soundImpactHard:execute()\n  if spinType == 0 then\n    for i = 1, 5 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = (zMomentum - 0.1) * math.random()\n      topDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 1 then\n    for i = 1, 8 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = (zMomentum - 0.1) * math.random()\n      ballDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 2 then\n    for i = 1, 12 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = (zMomentum - 0.1) * math.random()\n      gyroscopeDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  end\nend"
                },
                "onBecomingFalse": {
                  "key": "None"
                }
              },
              {
                "id": "Map",
                "value": {
                  "key": "Basics/DigitalInput/Map"
                },
                "onBecomingTrue": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "view",
                      "to": {
                        "key": "Spindizzy/WorldView/Hangworld/Camera"
                      }
                    }
                  ],
                  "code": "if hasFocus then\n  if mapOverviewMode == 1 then\n    view:transitionToStart()\n    mapOverviewMode = 0\n  else\n    view:transitionToEnd()\n    mapOverviewMode = 1\n  end\nend"
                },
                "onBecomingFalse": {
                  "key": "None"
                }
              },
              {
                "id": "Pause",
                "value": {
                  "key": "Basics/DigitalInput/Pause"
                },
                "onBecomingTrue": {
                  "key": "Basics/Function/Pause",
                  "bindings": []
                },
                "onBecomingFalse": {
                  "key": "None"
                }
              },
              {
                "id": "ResetCamera",
                "value": {
                  "key": "Basics/DigitalInput/ResetCamera"
                },
                "onBecomingTrue": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "viewAngle",
                      "to": {
                        "key": "Spindizzy/WorldView/Hangworld/Camera/Start"
                      }
                    }
                  ],
                  "code": "viewAngle:faceNorthWest();"
                },
                "onBecomingFalse": {
                  "key": "None"
                }
              },
              {
                "id": "ReverseCamera",
                "value": {
                  "key": "Basics/DigitalInput/ReverseCamera"
                },
                "onBecomingTrue": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "viewAngle",
                      "to": {
                        "key": "Spindizzy/WorldView/Hangworld/Camera/Start"
                      }
                    }
                  ],
                  "code": "viewAngle:flip();"
                },
                "onBecomingFalse": {
                  "key": "None"
                }
              },
              {
                "id": "RotateCameraRight",
                "value": {
                  "key": "Basics/DigitalInput/RotateCameraRight"
                },
                "onBecomingTrue": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "viewAngle",
                      "to": {
                        "key": "Spindizzy/WorldView/Hangworld/Camera/Start"
                      }
                    }
                  ],
                  "code": "viewAngle:rotateRight();"
                },
                "onBecomingFalse": {
                  "key": "None"
                }
              },
              {
                "id": "RotateCameraLeft",
                "value": {
                  "key": "Basics/DigitalInput/RotateCameraLeft"
                },
                "onBecomingTrue": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "viewAngle",
                      "to": {
                        "key": "Spindizzy/WorldView/Hangworld/Camera/Start"
                      }
                    }
                  ],
                  "code": "viewAngle:rotateLeft();"
                },
                "onBecomingFalse": {
                  "key": "None"
                }
              }
            ]
          },
