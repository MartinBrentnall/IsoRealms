                      }
                    }
                  },
                  {
                    "variable": "menu",
                    "to": {
                      "key": "UI/Menu/Pause"
                    }
                  },
                  {
                    "variable": "inputSwitchFE",
                    "to": {
                      "key": "Basics/InputSwitch/Options Screen"
                    }
                  },
                  {
                    "variable": "inputHandlerMenu",
                    "to": {
                      "key": ":InputHandler",
                      "asset": {
