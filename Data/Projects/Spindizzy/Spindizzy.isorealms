                  {
                    "variable": "optionsInput",
                    "to": {
                      "key": ":InputHandler",
                      "asset": {
                        "key": "Basics/InputSwitch/Options Screen"
                      }
                    }
                  }
                ],
                "arguments": [],
                "code": "if hasFocus then\n\n  -- Pause the game\n  locks = locks + 1\n  if locks == 1 then\n    spindizzy:setPause(true)\n    gameTimeLimit:pause()\n    if alienContactCount > 0 then\n      sound:pause()\n      damage:pause()\n    end\n  end\n  hasFocus = false\n\n  -- Show the menu\n  table.insert(menuStack, screenMenu)\n  table.insert(inputStack, inputHandlerMenu)\n  screenSwitch:setScreen(screenMenu)\n  menu:reset()\n  inputSwitchFE:setInputHandler(inputHandlerMenu)\n  mainInput:setInputHandler(optionsInput)\nend"
              },
              {
                "id": "SetHint",
                "name": "SetHint",
                "bindings": [
                  {
                    "variable": "hintComponent",
                    "to": {
                      "key": "UI/Layout/Layout/Hint"
                    }
                  }
                ],
                "arguments": [
                  {
                    "name": "hintIcon",
                    "type": {
                      "key": "Screen"
                    }
                  }
                ],
                "code": "if disableHud == nil then\n  hintComponent:setScreen(hintIcon)\nend"
              },
              {
                "id": "SetPrimarySwitch",
                "name": "SetPrimarySwitch",
                "bindings": [
                  {
                    "variable": "switchIconPrimary",
                    "to": {
                      "key": "UI/Layout/Layout/SwitchStatePrimary"
                    }
                  },
                  {
                    "variable": "switchIconSecondary",
                    "to": {
                      "key": "UI/Layout/Layout/SwitchStateSecondary"
                    }
                  },
                  {
                    "variable": "hintIcon",
                    "to": {
                      "key": "UI/Layout/Layout/Hint"
                    }
                  }
                ],
                "arguments": [
                  {
                    "name": "switchState",
                    "type": {
                      "key": "Spindizzy/Terrain State"
                    }
                  },
                  {
                    "name": "switchIcon",
                    "type": {
                      "key": "Screen"
                    }
                  },
                  {
                    "name": "sound",
                    "type": {
                      "key": "Action"
                    }
                  }
                ],
                "code": "if activeSwitchA ~= switchState or activeSwitchB ~= nil then\nsound:execute()\nnextSwitch = 1\nif activeSwitchA ~= nil then\n  activeSwitchA:setValue(false)\nend\nif activeSwitchB ~= nil then\n  activeSwitchB:setValue(false)\n  switchIconSecondary:setScreen(nil)\n  activeSwitchB = nil\nend\nswitchState:setValue(true)\nif disableHud == nil then\n  switchIconPrimary:setScreen(switchIcon)\nend\nactiveSwitchA = switchState;\n\n-- Update the hint icon\nif currentZone ~= nil and disableHud == nil then\n  local hintCount = currentZone:getHintCount()\n  if hintCount > 0 then\n    currentZone:giveHint(0)\n  else\n    hintIcon:setScreen(nil)\n  end\nend\nend"
              },
              {
                "id": "SetSecondarySwitch",
                "name": "SetSecondarySwitch",
                "bindings": [
                  {
                    "variable": "switchIconPrimary",
                    "to": {
                      "key": "UI/Layout/Layout/SwitchStatePrimary"
                    }
                  },
                  {
                    "variable": "switchIconSecondary",
                    "to": {
                      "key": "UI/Layout/Layout/SwitchStateSecondary"
                    }
                  },
                  {
                    "variable": "hintIcon",
                    "to": {
                      "key": "UI/Layout/Layout/Hint"
                    }
                  }
                ],
                "arguments": [
                  {
                    "name": "switchState",
                    "type": {
                      "key": "Spindizzy/Terrain State"
                    }
                  },
                  {
                    "name": "switchIcon",
                    "type": {
                      "key": "Screen"
                    }
                  },
                  {
                    "name": "sound",
                    "type": {
                      "key": "Action"
                    }
                  }
                ],
                "code": "if activeSwitchA ~= switchState and activeSwitchB ~= switchState then\nsound:execute()\nif nextSwitch == 1 then\n  if activeSwitchB ~= nil then\n    activeSwitchB:setValue(false)\n  end\n  activeSwitchB = switchState\n  if disableHud == nil then\n    switchIconSecondary:setScreen(switchIcon)\n  end\n  nextSwitch = 0\nelse\n  if activeSwitchA ~= nil then\n    activeSwitchA:setValue(false)\n  end\n  activeSwitchA = switchState\n  if disableHud == nil then\n    switchIconPrimary:setScreen(switchIcon)\n  end\n  nextSwitch = 1\nend\nswitchState:setValue(true)\n\n-- Update the hint icon\nif currentZone ~= nil and disableHud == nil then\n  local hintCount = currentZone:getHintCount()\n  if hintCount > 0 then\n    currentZone:giveHint(0)\n  else\n    hintIcon:setScreen(nil)\n  end\nend\nend"
              },
              {
                "id": "ShowScreen",
