        "BoundaryHandler": {
          "instances": {
            "PlayerZoneHandler": {
              "boundary": {
                "key": "Zone/Zone"
              },
              "object": {
                "key": "Player/Player"
              },
              "onEntry": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "zone",
                    "to": {
                      "key": "Spindizzy/Zone"
                    }
                  },
                  {
                    "variable": "zoneColour",
                    "to": {
                      "key": "~",
                      "local": "Boundary/Zone/WorldView/World Map/ZoneView"
                    }
                  },
                  {
                    "variable": "zoneEnterFunction",
                    "to": {
                      "key": ":Action",
                      "asset": {
                        "key": "Basics/Function/Handle Zone Entered",
                        "bindings": []
                      }
                    }
                  },
                  {
                    "variable": "optionsLoader",
                    "to": {
                      "key": ":Action",
                      "asset": {
                        "key": "Basics/Function/ReloadConfiguration",
                        "bindings": []
                      }
                    }
                  }
                ],
                "code": "-- Hack to reload the controls when starting the game.\nif firstZoneEntered == 0 then\n  optionsLoader:execute()\n  firstZoneEntered = 1\nend\nentered = zone\nenteredColour = zoneColour\nzoneEnterFunction:execute()"
              },
              "onExit": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "zone",
                    "to": {
                      "key": "Spindizzy/Zone"
                    }
                  },
                  {
                    "variable": "zoneColour",
                    "to": {
                      "key": "~",
                      "local": "Boundary/Zone/WorldView/World Map/ZoneView"
                    }
                  },
                  {
                    "variable": "zoneExitFunction",
                    "to": {
                      "key": ":Action",
                      "asset": {
                        "key": "Basics/Function/Handle Zone Exited",
                        "bindings": []
                      }
                    }
                  }
                ],
                "code": "exited = zone\nexitedColour = zoneColour\nzoneExitFunction:execute()"
              }
            }
          },
          "omissions": []
        },
