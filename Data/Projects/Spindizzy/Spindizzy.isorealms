{"scaleX":1.2999999523162842,"scaleY":1.2999999523162842,"scaleZ":1.2999999523162842,"key":"Basics/Sprite/Icon State 11"}},"Icon Active State 2":{"appearance":{"scaleX":1.4500000476837159,"scaleY":1.4500000476837159,"scaleZ":1.4500000476837159,"yaw":315.0,"key":"Basics/Sprite/Icon State 1 and 2"}},"Icon Active State 3":{"appearance":{"scaleX":1.4500000476837159,"scaleY":1.4500000476837159,"scaleZ":1.4500000476837159,"yaw":90.0,"key":"Basics/Sprite/Icon State 3"}},"Icon Active State 4":{"appearance":{"key":"Basics/Sprite/Icon State 4"}},"Icon Active State 5":{"appearance":{"yaw":315.0,"key":"Basics/Sprite/Icon State 5 and 6"}},"Icon Active State 6":{"appearance":{"yaw":135.0,"key":"Basics/Sprite/Icon State 5 and 6"}},"Icon Active State 7":{"appearance":{"yaw":135.0,"key":"Basics/Sprite/Icon State 7"}},"Icon Active State 8":{"appearance":{"scaleX":1.2999999523162842,"scaleY":1.2999999523162842,"scaleZ":1.2999999523162842,"key":"Basics/Sprite/Icon State 8"}},"Icon Active State 9":{"appearance":{"scaleX":1.2999999523162842,"scaleY":1.2999999523162842,"scaleZ":1.2999999523162842,"yaw":135.0,"key":"Basics/Sprite/Icon State 9 and 10"}},"Jewel":{"appearance":{"key":"Spindizzy/Jewel/Jewel"}}},"omissions":[]},"Player":{"instances":{"Player":{"spinSpeed":-180.0,"bounceFactor":0.3100000023841858,"appearance":{"key":"Equilibria/ModelCycler/Player Craft/0"},"onRespawn":{"key":"Basics/Script","bindings":[{"variable":"gameTimeLimit","to":{"key":"Basics/Sequence/Timer (Game Time Limit)/Instance"}},{"variable":"soundRespawnHard","to":{"key":":Action","asset":{"key":"Basics/Sound/GERALD Respawn"}}}],"code":"local newTime = gameTimeLimit:getTime() + 10000\ngameTimeLimit:setTime(newTime)\nif gPlayerLeftSurfaceMomentumZ > 0.0 then\n  soundRespawnHard:execute()\nend"},"thrustInput":{"key":"Replay/Replayer/Gameplay Recorder/GERALD Thrust"},"xInput":{"key":"Replay/Replayer/Gameplay Recorder/GERALD Movement X"},"yInput":{"key":"Replay/Replayer/Gameplay Recorder/GERALD Movement Y"},"onFallImpact":{"key":"Basics/Script","bindings":[{"variable":"topDebris","to":{"key":"Equilibria/World/Game World/DebrisGenerator/Top"}},{"variable":"ballDebris","to":{"key":"Equilibria/World/Game World/DebrisGenerator/Ball"}},{"variable":"gyroscopeDebris","to":{"key":"Equilibria/World/Game World/DebrisGenerator/Gyroscope"}},{"variable":"player","to":{"key":"~","local":"Player"}},{"variable":"soundImpactHard","to":{"key":":Action","asset":{"key":"Basics/Sound/GERALD Surface Impact Hard"}}},{"variable":"soundImpactMedium","to":{"key":":Action","asset":{"key":"Basics/Sound/GERALD Surface Impact Medium"}}},{"variable":"soundImpactSoft","to":{"key":":Action","asset":{"key":"Basics/Sound/GERALD Surface Impact Soft"}}}],"code":"player:setStepReach(0.5)\nlocation = player:getLocation()\nif (gPlayerLeftSurfaceAtZ - location:getZ() > 2.75) then\n  momentum = player:getMomentum()\n  xMomentum = momentum:getX()\n  yMomentum = momentum:getY()\n  zMomentum = momentum:getZ()\n  player:destroy()\n  soundImpactHard:execute()\n  if spinType == 0 then\n    for i = 1, 5 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = zMomentum * math.random()\n      topDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 1 then\n    for i = 1, 8 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = zMomentum * math.random()\n      ballDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 2 then\n    for i = 1, 12 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = zMomentum * math.random()\n      gyroscopeDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  end\nelse\n  hitX = location:getX()\n  hitY = location:getY()\n  distX = math.abs(gPlayerLeftSurfaceAtX - hitX)\n  distY = math.abs(gPlayerLeftSurfaceAtY - hitY)\n  dist = math.max(distX, distY)\n  if gPlayerLeftSurfaceMomentumZ > 0.0 then\n    if dist > 1.98 then\n      soundImpactHard:execute()\n    elseif dist > 1.0 then\n      soundImpactMedium:execute()\n    elseif dist > 0.5 then\n      soundImpactSoft:execute()\n    end\n  end\nend"},"onFallBounce":{"key":"Basics/Script","bindings":[{"variable":"player","to":{"key":"~","local":"Player"}}],"code":"-- This is kinda hacky for a difficult part of the game.\nif (gPlayerLeftSurfaceAtZ - location:getZ() > 2.75) then\n  player:setStepReach(0.93)\nelse\n  player:setStepReach(0.8)\nend\n\n-- Bounce height increases under certain conditions.\nif fallDistance:getValue() > 2.75 or gPlayerLeftSurfaceMomentumZ ~= 0.0 then\n  player:setBounceFactor(0.31)\nelse\n  player:setBounceFactor(0.0)\nend"},"onWallBounce":{"key":"Basics/Script","bindings":[{"variable":"player","to":{"key":"~","local":"Player/Player"}},{"variable":"wallZone","to":{"key":"~","local":"Terrain/Zone"}},{"variable":"wallZoneColour","to":{"key":"~","local":"Terrain/Zone/WorldView/World Map/ZoneView"}},{"variable":"playerZoneColour","to":{"key":"~","local":"Player/Zone/WorldView/World Map/ZoneView"}},{"variable":"wall","to":{"key":"~","local":"Terrain/Wall"}},{"variable":"zoneEnterFunction","to":{"key":":Action","asset":{"key":"Basics/Function/Equilibria Handle Zone Entered","bindings":[]}}},{"variable":"zoneExitFunction","to":{"key":":Action","asset":{"key":"Basics/Function/Equilibria Handle Zone Exited","bindings":[]}}}],"code":"-- This action is only applicable when the wall is in a different zone than the player.\nif player:getZone() ~= wallZone and player:getZone() ~= nil and wall:isAtZoneEdge() then\n\n  -- Leave the current zone and enter the zone where the wall is.\n  zoneToExit = player:getZone();\n  zoneToEnter = wallZone;\n  if zoneToExit ~= nil then\n    exited = zoneToExit\n    exitedColour = playerZoneColour\n    zoneExitFunction:execute()\n    exited = nil\n  end\n  if zoneToEnter ~= nil then\n    entered = zoneToEnter\n    enteredColour = wallZoneColour\n    zoneEnterFunction:execute()\n    entered = nil\n  end\n\n  -- Leave the zone where the wall is and return to the player's zone.\n  -- The pause mechanism will trigger automatically since no time has passed.\n  zoneToEnter = player:getZone()\n  zoneToExit = wallZone;\n  if zoneToExit ~= nil then\n    exited = zoneToExit\n    exitedColour = wallZoneColour\n    zoneExitFunction:execute()\n    exited = nil\n  end\n  if zoneToEnter ~= nil then\n    entered = zoneToEnter\n    enteredColour = playerZoneColour\n    zoneEnterFunction:execute()\n    entered = nil\n  end\nend"},"orientation":{"key":"Equilibria/WorldView/Game View/Camera/Yaw"},"onLeaveSurface":{"key":"Basics/Script","bindings":[{"variable":"player","to":{"key":"~","local":"Player"}}],"code":"-- Store position at which the surface was left.\nlocal mPlayerLocation = player:getLocation()\ngPlayerLeftSurfaceAtX = mPlayerLocation:getX()\ngPlayerLeftSurfaceAtY = mPlayerLocation:getY()\ngPlayerLeftSurfaceAtZ = mPlayerLocation:getZ()\n\n-- Store verticale momentum at which surface was left.\nlocal mPlayerMomentum = player:getMomentum()\ngPlayerLeftSurfaceMomentumZ = mPlayerMomentum:getZ()"},"onApex":{"key":"Basics/Script","bindings":[{"variable":"player","to":{"key":"~","local":"Player"}}],"code":"-- Store current position to calculate fall height.\nlocal mPlayerLocation = player:getLocation()\ngPlayerLeftSurfaceAtZ = mPlayerLocation:getZ()"}}},"omissions":[]},"Terrain":{"instances":{"Activate State 1":{"solid":true,"friction":0.001500000013038516,"grip":1.0,"allowRespawn":true,"onImpact":{"key":"None"},"onTouch":{"key":"Basics/Function/Equilibria Activate State","bindings":[{"argument":"State","to":{"key":"Equilibria/TerrainState/State 1"}},{"argument":"Icon","to":{"ke