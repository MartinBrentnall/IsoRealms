          {
            "type": "BoundaryHandler",
            "instances": [
              {
                "id": "JewelCollector",
                "boundary": {
                  "key": "PickUp/Jewel"
                },
                "object": {
                  "key": "Player/Player"
                },
                "onEntry": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "sound",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Sound/Jewel"
                        }
                      }
                    },
                    {
                      "variable": "score",
                      "to": {
                        "key": "Basics/Integer/Score"
                      }
                    },
                    {
                      "variable": "gameTimeLimit",
                      "to": {
                        "key": "Basics/Sequence/Time Limit/Instance"
                      }
                    },
                    {
                      "variable": "jewelsCollected",
                      "to": {
                        "key": "Basics/Integer/JewelCount"
                      }
                    },
                    {
                      "variable": "zone",
                      "to": {
                        "key": "Spindizzy/Zone"
                      }
                    },
                    {
                      "variable": "zoneCount",
                      "to": {
                        "key": ":Integer",
                        "asset": {
                          "key": "Basics/Integer/RemainingZones"
                        }
                      }
                    },
                    {
                      "variable": "hangworld",
                      "to": {
                        "key": "Spindizzy/World/Hangworld"
                      }
                    },
                    {
                      "variable": "ending",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/Ending",
                          "bindings": []
                        }
                      }
                    }
                  ],
                  "code": "sound:execute()\njewelsCollected:setValue(jewelsCollected:getValue() + 1)\nlocal earned = 600\nlocal newTime = gameTimeLimit:getTime() - 12000\nif newTime < 0 then\n  local excess = -newTime\n  local extraScore = excess / 10\n  earned = earned + extraScore\n  newTime = 0\nend\ngameTimeLimit:setTime(newTime)\n\nscore:setValue(math.floor(score:getValue() + earned))\n\n-- Do we show the ending yet?\nif zoneCount:getValue() == 0 and hangworld:getPickUpCount() == jewelsCollected:getValue() then\n  ending:execute()\nend"
                },
                "onExit": {
                  "key": "None"
                }
              },
              {
                "id": "PlayerZoneHandler",
                "boundary": {
                  "key": "Zone/Zone"
                },
                "object": {
                  "key": "Player/Player"
                },
                "onEntry": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "zone",
                      "to": {
                        "key": "Spindizzy/Zone"
                      }
                    },
                    {
                      "variable": "zoneColour",
                      "to": {
                        "key": "~",
                        "local": "Boundary/Zone/WorldView/Overview/ZoneView"
                      }
                    },
                    {
                      "variable": "zoneEnterFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/ZoneEntered",
                          "bindings": []
                        }
                      }
                    },
                    {
                      "variable": "optionsLoader",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/ReloadConfiguration",
                          "bindings": []
                        }
                      }
                    }
                  ],
                  "code": "-- Hack to reload the controls when starting the game.\nif firstZoneEntered == 0 then\n  optionsLoader:execute()\n  firstZoneEntered = 1\nend\nentered = zone\nenteredColour = zoneColour\nzoneEnterFunction:execute()"
                },
                "onExit": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "zone",
                      "to": {
                        "key": "Spindizzy/Zone"
                      }
                    },
                    {
                      "variable": "zoneColour",
                      "to": {
                        "key": "~",
                        "local": "Boundary/Zone/WorldView/Overview/ZoneView"
                      }
                    },
                    {
                      "variable": "zoneExitFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/ZoneExited",
                          "bindings": []
                        }
                      }
                    }
                  ],
                  "code": "exited = zone\nexitedColour = zoneColour\nzoneExitFunction:execute()"
                }
