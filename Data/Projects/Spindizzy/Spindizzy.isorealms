        </PickUp>
        <PickUp name="Exclusive State B">
          <Model key="Basics/Sprite/SwitchDiamondHalf" scaleX="1.45" scaleY="1.45" scaleZ="1.45" yaw="315.0"/>
        </PickUp>
        <PickUp name="Exclusive State C">
