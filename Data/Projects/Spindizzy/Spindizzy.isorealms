<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Project>
  <DefaultEditor key="Spindizzy/World/Hangworld"/>
  <Include>
    <Project name="Projects/Spindizzy/Options.isorealms" user="false"/>
  </Include>
  <Properties>
    <Property id="Mode">
      <Action>
        <Action key="Basics/Script">
          <Bind variable="value">
            <To key="~" local="value"/>
          </Bind>
          <Bind variable="timer">
            <To key="Basics/Timer/TimeLimit"/>
          </Bind>
          <Bind variable="timeValue">
            <To key="UI/Layout/Layout/ValueTime"/>
          </Bind>
          <Bind variable="scoreValue">
            <To key="UI/Layout/Layout/ValueScore"/>
          </Bind>
          <Bind variable="notApplicableTime">
            <To key=":Screen">
              <Asset key="Basics/StringScreen/NotApplicableTime"/>
            </To>
          </Bind>
          <Bind variable="notApplicableScore">
            <To key=":Screen">
              <Asset key="Basics/StringScreen/NotApplicableScore"/>
            </To>
          </Bind>
          <Code>if value:getValue() == "Explorer" then
  timer:pause()
  GlobalExplorer = 1
  timeValue:setScreen(notApplicableTime)
  scoreValue:setScreen(notApplicableScore)
end</Code>
        </Action>
      </Action>
    </Property>
  </Properties>
  <Modules>
    <Module name="Basics">
      <Configuration/>
      <Resources>
        <BooleanTrigger name="Brake">
          <Value key="Basics/DigitalInput/Brake"/>
          <ActionOnTrue>
            <Action key="Basics/Script">
              <Bind variable="player">
                <To key="Spindizzy/World/Hangworld/Player"/>
              </Bind>
              <Bind variable="time">
                <To key="Basics/Timer/TimeLimit"/>
              </Bind>
              <Code>if hasFocus then
  player:stop()
  if GlobalExplorer ~= 1 then
    local newTime = time:getValue() - 500
    if newTime &lt; 0 then
      newTime = 0
    end
    time:setValue(newTime)
  end
end</Code>
            </Action>
          </ActionOnTrue>
        </BooleanTrigger>
        <BooleanTrigger name="Transform">
          <Value key="Basics/DigitalInput/Transform"/>
          <ActionOnTrue>
            <Action key="Basics/Script">
              <Bind variable="playerCraftModels">
                <To key="Basics/ModelCycler/Player Craft"/>
              </Bind>
              <Bind variable="alienCraftModels">
                <To key="Basics/ModelCycler/Alien Craft"/>
              </Bind>
              <Bind variable="player">
                <To key="Spindizzy/Player/Player"/>
              </Bind>
              <Bind variable="alienTypeA">
                <To key="Spindizzy/Alien/Ball"/>
              </Bind>
              <Bind variable="alienTypeB">
                <To key="Spindizzy/Alien/Gyroscope"/>
              </Bind>
              <Code>if hasFocus then
  playerCraftModels:next()
  alienCraftModels:next()
  if spinType == 0 then
    player:setSpinSpeed(0.0)
    alienTypeA:setSpinSpeed(-360.0)
    alienTypeB:setSpinSpeed(-180.0)
    spinType = 1
  elseif spinType == 1 then
    player:setSpinSpeed(-360.0)
    alienTypeA:setSpinSpeed(-180.0)
    alienTypeB:setSpinSpeed(0.0)
    spinType = 2
  else
    player:setSpinSpeed(-180.0)
    alienTypeA:setSpinSpeed(0.0)
    alienTypeB:setSpinSpeed(-360.0)
    spinType = 0
  end
end</Code>
            </Action>
          </ActionOnTrue>
        </BooleanTrigger>
        <BooleanTrigger name="Destruct">
          <Value key="Basics/DigitalInput/Destruct"/>
          <ActionOnTrue>
            <Action key="Basics/Script">
              <Bind variable="player">
                <To key="Spindizzy/World/Hangworld/Player"/>
              </Bind>
              <Bind variable="soundImpactHard">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Sound/ImpactHard"/>
                  </Action>
                </To>
              </Bind>
              <Bind variable="topDebris">
                <To key="Spindizzy/World/Hangworld/DebrisGenerator/Top"/>
              </Bind>
              <Bind variable="ballDebris">
                <To key="Spindizzy/World/Hangworld/DebrisGenerator/Ball"/>
              </Bind>
              <Bind variable="gyroscopeDebris">
                <To key="Spindizzy/World/Hangworld/DebrisGenerator/Gyroscope"/>
              </Bind>
              <Code>if hasFocus and player:isAlive() then
  location = player:getLocation()
  momentum = player:getMomentum()
  xMomentum = momentum:getX()
  yMomentum = momentum:getY()
  zMomentum = momentum:getZ()
  player:destroy()
  soundImpactHard:execute()
  if spinType == 0 then
    for i = 1, 5 do
      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02
      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02
      zMomentumVary = (zMomentum - 0.1) * math.random()
      topDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)
    end
  elseif spinType == 1 then
    for i = 1, 8 do
      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02
      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02
      zMomentumVary = (zMomentum - 0.1) * math.random()
      ballDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)
    end
  elseif spinType == 2 then
    for i = 1, 12 do
      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02
      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02
      zMomentumVary = (zMomentum - 0.1) * math.random()
      gyroscopeDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)
    end
  end
end</Code>
            </Action>
          </ActionOnTrue>
        </BooleanTrigger>
        <BooleanTrigger name="Map">
          <Value key="Basics/DigitalInput/Map"/>
          <ActionOnTrue>
            <Action key="Basics/Script">
              <Bind variable="view">
                <To key="Spindizzy/WorldView/Hangworld/Camera"/>
              </Bind>
              <Code>if hasFocus then
  if mapOverviewMode == 1 then
    view:transitionToStart()
    mapOverviewMode = 0
  else
    view:transitionToEnd()
    mapOverviewMode = 1
  end
end</Code>
            </Action>
          </ActionOnTrue>
        </BooleanTrigger>
        <BooleanTrigger name="Pause">
          <Value key="Basics/DigitalInput/Pause"/>
          <ActionOnTrue>
            <Action key="Basics/Function/Pause"/>
          </ActionOnTrue>
        </BooleanTrigger>
        <BooleanTrigger name="ResetCamera">
          <Value key="Basics/DigitalInput/ResetCamera"/>
          <ActionOnTrue>
            <Action key="Basics/Script">
              <Bind variable="viewAngle">
                <To key="Spindizzy/WorldView/Hangworld/Camera/Start"/>
              </Bind>
              <Code>viewAngle:faceNorthWest();</Code>
            </Action>
          </ActionOnTrue>
        </BooleanTrigger>
        <BooleanTrigger name="ReverseCamera">
          <Value key="Basics/DigitalInput/ReverseCamera"/>
          <ActionOnTrue>
            <Action key="Basics/Script">
              <Bind variable="viewAngle">
                <To key="Spindizzy/WorldView/Hangworld/Camera/Start"/>
              </Bind>
              <Code>viewAngle:flip();</Code>
            </Action>
          </ActionOnTrue>
        </BooleanTrigger>
        <BooleanTrigger name="RotateCameraRight">
          <Value key="Basics/DigitalInput/RotateCameraRight"/>
          <ActionOnTrue>
            <Action key="Basics/Script">
              <Bind variable="viewAngle">
                <To key="Spindizzy/WorldView/Hangworld/Camera/Start"/>
              </Bind>
              <Code>viewAngle:rotateRight();</Code>
            </Action>
          </ActionOnTrue>
        </BooleanTrigger>
        <BooleanTrigger name="RotateCameraLeft">
          <Value key="Basics/DigitalInput/RotateCameraLeft"/>
          <ActionOnTrue>
            <Action key="Basics/Script">
              <Bind variable="viewAngle">
                <To key="Spindizzy/WorldView/Hangworld/Camera/Start"/>
              </Bind>
              <Code>viewAngle:rotateLeft();</Code>
            </Action>
          </ActionOnTrue>
        </BooleanTrigger>
        <Colour alpha="1" blue="0" green="0" name="Black" red="0"/>
        <Colour alpha="1" blue="1" green="1" name="White" red="1"/>
        <Colour alpha="1" blue="0.203125" green="0.242188" name="Red" red="0.546875"/>
        <Colour alpha="1" blue="0.777344" green="0.746094" name="Cyan" red="0.476562"/>
        <Colour alpha="1" blue="0.699219" green="0.277344" name="Purple" red="0.550781"/>
        <Colour alpha="1" blue="0.253906" green="0.660156" name="Green" red="0.40625"/>
        <Colour alpha="1" blue="0.632812" green="0.191406" name="Blue" red="0.242188"/>
        <Colour alpha="1" blue="0.441406" green="0.859375" name="Yellow" red="0.8125"/>
        <Colour alpha="1" blue="0.144531" green="0.371094" name="Orange" red="0.5625"/>
        <Colour alpha="1" blue="0" green="0.257812" name="Brown" red="0.339844"/>
        <Colour alpha="1" blue="0.425781" green="0.464844" name="Pink" red="0.730469"/>
        <Colour alpha="1" blue="0.328125" green="0.328125" name="DarkGray" red="0.328125"/>
        <Colour alpha="1" blue="0.5" green="0.5" name="MediumGray" red="0.5"/>
        <Colour alpha="1" blue="0.53125" green="0.914062" name="LightGreen" red="0.671875"/>
        <Colour alpha="1" blue="0.851562" green="0.4375" name="LightBlue" red="0.484375"/>
        <Colour alpha="1" blue="0.667969" green="0.667969" name="LightGray" red="0.667969"/>
        <Colour alpha="1" blue="0.304144" green="0.304144" name="DesaturatedRed" red="0.304144"/>
        <Colour alpha="1" blue="0.691048" green="0.691048" name="DesaturatedCyan" red="0.691048"/>
        <Colour alpha="1" blue="0.365936" green="0.365936" name="DesaturatedPurple" red="0.365936"/>
        <Colour alpha="1" blue="0.576844" green="0.576844" name="DesaturatedGreen" red="0.576844"/>
        <Colour alpha="1" blue="0.234072" green="0.234072" name="DesaturatedBlue" red="0.234072"/>
        <Colour alpha="1" blue="0.819232" green="0.819232" name="DesaturatedYellow" red="0.819232"/>
        <Colour alpha="1" blue="0.395429" green="0.395429" name="DesaturatedOrange" red="0.395429"/>
        <Colour alpha="1" blue="0.256638" green="0.256638" name="DesaturatedBrown" red="0.256638"/>
        <Colour alpha="1" blue="0.518496" green="0.518496" name="DesaturatedPink" red="0.518496"/>
        <Colour alpha="1" blue="0.834934" green="0.834934" name="DesaturatedLightGreen" red="0.834934"/>
        <Colour alpha="1" blue="0.477361" green="0.477361" name="DesaturatedLightBlue" red="0.477361"/>
        <ColourCycler name="Ending Effect">
          <IO>
            <InputColour key="Basics/Colour/Red"/>
            <InputColour key="Basics/Colour/Yellow"/>
            <InputColour key="Basics/Colour/Green"/>
            <InputColour key="Basics/Colour/Cyan"/>
            <InputColour key="Basics/Colour/Blue"/>
            <InputColour key="Basics/Colour/Purple"/>
            <OutputColour offset="0.0000"/>
            <OutputColour offset="0.0625"/>
            <OutputColour offset="0.1250"/>
            <OutputColour offset="0.1875"/>
            <OutputColour offset="0.2500"/>
            <OutputColour offset="0.3125"/>
            <OutputColour offset="0.3750"/>
            <OutputColour offset="0.4375"/>
            <OutputColour offset="0.5000"/>
            <OutputColour offset="0.5625"/>
            <OutputColour offset="0.6250"/>
            <OutputColour offset="0.6875"/>
            <OutputColour offset="0.7500"/>
            <OutputColour offset="0.8125"/>
            <OutputColour offset="0.8750"/>
            <OutputColour offset="0.9375"/>
          </IO>
          <CycleSpeed key="Basics/Float/Ending Effect Cycle Speed"/>
        </ColourCycler>
        <ColourCycler name="DamageColours">
          <IO>
            <InputColour key="Basics/Colour/Red"/>
            <InputColour key="Basics/Colour/Yellow"/>
            <InputColour key="Basics/Colour/Green"/>
            <InputColour key="Basics/Colour/Cyan"/>
            <InputColour key="Basics/Colour/Blue"/>
            <InputColour key="Basics/Colour/Purple"/>
            <OutputColour offset="0.0"/>
          </IO>
          <CycleSpeed key="Literal" value="10000"/>
        </ColourCycler>
        <ColourCycler name="CurrentRoom">
          <IO>
            <InputColour key="Basics/Colour/Yellow"/>
            <InputColour key="Basics/Colour/Yellow"/>
            <InputColour key="Basics/Colour/Purple"/>
            <InputColour key="Basics/Colour/Purple"/>
            <OutputColour offset="0.0"/>
          </IO>
          <CycleSpeed key="Literal" value="0.025"/>
        </ColourCycler>
        <Float name="Ending Effect Cycle Speed" value="0.0025"/>
        <Function name="Ending">
          <Bind variable="endingSequence">
            <To key="Basics/Sequence/Ending"/>
          </Bind>
          <Bind variable="project">
            <To key="Project"/>
          </Bind>
          <Bind variable="endingMessage">
            <To key="Basics/String/EndingMessage"/>
          </Bind>
          <Bind variable="scoreMessage">
            <To key="Basics/String/ScoreMessage"/>
          </Bind>
          <Bind variable="mappedMessage">
            <To key="Basics/String/MappedMessage"/>
          </Bind>
          <Bind variable="jewelsMessage">
            <To key="Basics/String/JewelsMessage"/>
          </Bind>
          <Bind variable="completeMessage">
            <To key="Basics/String/CompleteMessage"/>
          </Bind>
          <Bind variable="score">
            <To key=":Integer">
              <Asset key="Basics/Integer/Score"/>
            </To>
          </Bind>
          <Bind variable="timeLimit">
            <To key="Basics/Timer/TimeLimit"/>
          </Bind>
          <Bind variable="spindizzy">
            <To key="Spindizzy"/>
          </Bind>
          <Bind variable="sound">
            <To key="Basics/Sequence/DamageSound"/>
          </Bind>
          <Bind variable="damage">
            <To key="Basics/Sequence/DamageVisual"/>
          </Bind>
          <Code>-- Prevent menu access, etc.
hasFocus = false

-- Set result values
endingMessage:setValue("Map Complete: Mission Success")
mappedMessage:setValue("100%")
jewelsMessage:setValue("100%")
completeMessage:setValue("100%")
scoreMessage:setValue("" .. score:getValue())

-- Pause the game
spindizzy:setPause(true)
timeLimit:pause()
if alienContactCount > 0 then
  sound:pause()
  damage:pause()
end

-- Play the ending
endingSequence:play()</Code>
        </Function>
        <Function name="Unpause">
          <Bind variable="timeLimit">
            <To key="Basics/Timer/TimeLimit"/>
          </Bind>
          <Bind variable="spindizzy">
            <To key="Spindizzy"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="sound">
            <To key="Basics/Sequence/DamageSound"/>
          </Bind>
          <Bind variable="damage">
            <To key="Basics/Sequence/DamageVisual"/>
          </Bind>
          <Code>-- Unpause the game
locks = locks - 1
if locks == 0 then
  spindizzy:setPause(false)
  if GlobalExplorer ~= 1 then
    timeLimit:resume()
  end
  if alienContactCount > 0 then
    sound:play()
    damage:play()
  end
end
hasFocus = true

-- Remove the menu
while #menuStack &gt; 0 do
  table.remove(menuStack)
  table.remove(inputStack)
end
screen:setScreen(nil)
input:setInputHandler(nil)
</Code>
        </Function>
        <Function name="Pause">
          <Bind variable="timeLimit">
            <To key="Basics/Timer/TimeLimit"/>
          </Bind>
          <Bind variable="spindizzy">
            <To key="Spindizzy"/>
          </Bind>
          <Bind variable="screenSwitch">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="screenMenu">
            <To key=":Screen">
              <Asset key="UI/Menu/Pause"/>
            </To>
          </Bind>
          <Bind variable="menu">
            <To key="UI/Menu/Pause"/>
          </Bind>
          <Bind variable="inputSwitchFE">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="inputHandlerMenu">
            <To key=":InputHandler">
              <Asset key="UI/Menu/Pause"/>
            </To>
          </Bind>
          <Bind variable="sound">
            <To key="Basics/Sequence/DamageSound"/>
          </Bind>
          <Bind variable="damage">
            <To key="Basics/Sequence/DamageVisual"/>
          </Bind>
          <Code>if hasFocus then

  -- Pause the game
  locks = locks + 1
  if locks == 1 then
    spindizzy:setPause(true)
    timeLimit:pause()
    if alienContactCount > 0 then
      sound:pause()
      damage:pause()
    end
  end
  hasFocus = false

  -- Show the menu
  table.insert(menuStack, screenMenu)
  table.insert(inputStack, inputHandlerMenu)
  screenSwitch:setScreen(screenMenu)
  menu:reset()
  inputSwitchFE:setInputHandler(inputHandlerMenu)
end</Code>
        </Function>
        <Function name="Quit">
          <Bind variable="project">
            <To key="Project"/>
          </Bind>
          <Code>project:finish(false)</Code>
        </Function>
        <Function name="RandomClick">
          <Bind variable="click1">
            <To key=":Action">
              <Action>
                <Action key="Basics/Sound/LiftClick1"/>
              </Action>
            </To>
          </Bind>
          <Bind variable="click2">
            <To key=":Action">
              <Action>
                <Action key="Basics/Sound/LiftClick2"/>
              </Action>
            </To>
          </Bind>
          <Bind variable="click3">
            <To key=":Action">
              <Action>
                <Action key="Basics/Sound/LiftClick3"/>
              </Action>
            </To>
          </Bind>
          <Code>local val = math.random(0, 2)
if val == 0 then
  click1:execute()
elseif val == 1 then
  click2:execute()
elseif val == 2 then
  click3:execute()
end</Code>
        </Function>
        <Function name="ResetSwitch">
          <Bind variable="switchIconPrimary">
            <To key="UI/Layout/Layout/SwitchStatePrimary"/>
          </Bind>
          <Bind variable="switchIconSecondary">
            <To key="UI/Layout/Layout/SwitchStateSecondary"/>
          </Bind>
          <Bind variable="hintIcon">
            <To key="UI/Layout/Layout/Hint"/>
          </Bind>
          <Argument name="sound"/>
          <Code>if activeSwitchA ~= nil then
  sound:execute()
  nextSwitch = 0
  activeSwitchA:setValue(false)
  switchIconPrimary:setScreen(nil)
  activeSwitchA = nil
  if activeSwitchB ~= nil then
    activeSwitchB:setValue(false)
    switchIconSecondary:setScreen(nil)
    activeSwitchB = nil
  end

  -- Update the hint icon
  if currentZone ~= nil and disableHud == nil then
    local hintCount = currentZone:getHintCount()
    if hintCount &gt; 0 then
      currentZone:giveHint(0)
    else
      hintIcon:setScreen(nil)
    end
  end
end</Code>
        </Function>
        <Function name="SetHint">
          <Bind variable="hintComponent">
            <To key="UI/Layout/Layout/Hint"/>
          </Bind>
          <Argument name="hintIcon"/>
          <Code>if disableHud == nil then
  hintComponent:setScreen(hintIcon)
end</Code>
        </Function>
        <Function name="SetPrimarySwitch">
          <Bind variable="switchIconPrimary">
            <To key="UI/Layout/Layout/SwitchStatePrimary"/>
          </Bind>
          <Bind variable="switchIconSecondary">
            <To key="UI/Layout/Layout/SwitchStateSecondary"/>
          </Bind>
          <Bind variable="hintIcon">
            <To key="UI/Layout/Layout/Hint"/>
          </Bind>
          <Argument name="switchState"/>
          <Argument name="switchIcon"/>
          <Argument name="sound"/>
          <Code>if activeSwitchA ~= switchState or activeSwitchB ~= nil then
sound:execute()
nextSwitch = 1
if activeSwitchA ~= nil then
  activeSwitchA:setValue(false)
end
if activeSwitchB ~= nil then
  activeSwitchB:setValue(false)
  switchIconSecondary:setScreen(nil)
  activeSwitchB = nil
end
switchState:setValue(true)
if disableHud == nil then
  switchIconPrimary:setScreen(switchIcon)
end
activeSwitchA = switchState;

-- Update the hint icon
if currentZone ~= nil and disableHud == nil then
  local hintCount = currentZone:getHintCount()
  if hintCount &gt; 0 then
    currentZone:giveHint(0)
  else
    hintIcon:setScreen(nil)
  end
end
end</Code>
        </Function>
        <Function name="SetSecondarySwitch">
          <Bind variable="switchIconPrimary">
            <To key="UI/Layout/Layout/SwitchStatePrimary"/>
          </Bind>
          <Bind variable="switchIconSecondary">
            <To key="UI/Layout/Layout/SwitchStateSecondary"/>
          </Bind>
          <Bind variable="hintIcon">
            <To key="UI/Layout/Layout/Hint"/>
          </Bind>
          <Argument name="switchState"/>
          <Argument name="switchIcon"/>
          <Argument name="sound"/>
          <Code>if activeSwitchA ~= switchState and activeSwitchB ~= switchState then
sound:execute()
if nextSwitch == 1 then
  if activeSwitchB ~= nil then
    activeSwitchB:setValue(false)
  end
  activeSwitchB = switchState
  if disableHud == nil then
    switchIconSecondary:setScreen(switchIcon)
  end
  nextSwitch = 0
else
  if activeSwitchA ~= nil then
    activeSwitchA:setValue(false)
  end
  activeSwitchA = switchState
  if disableHud == nil then
    switchIconPrimary:setScreen(switchIcon)
  end
  nextSwitch = 1
end
switchState:setValue(true)

-- Update the hint icon
if currentZone ~= nil and disableHud == nil then
  local hintCount = currentZone:getHintCount()
  if hintCount &gt; 0 then
    currentZone:giveHint(0)
  else
    hintIcon:setScreen(nil)
  end
end
end</Code>
        </Function>
        <Function name="ShowScreen">
          <Argument name="screenSwitch"/>
          <Argument name="screen"/>
          <Code>screenSwitch:setScreen(screen)</Code>
        </Function>
        <Function name="SpindizzyInit">
          <Bind variable="zoneCount">
            <To key="Basics/Integer/RemainingZones"/>
          </Bind>
          <Bind variable="hangworld">
            <To key="Spindizzy/World/Hangworld"/>
          </Bind>
          <Bind variable="optionsLoader">
            <To key=":Action">
              <Action>
                <Action key="Basics/Function/ReloadConfiguration"/>
              </Action>
            </To>
          </Bind>
          <Code>menuStack = {}
inputStack = {}
zoneCount:setValue(hangworld:getZoneCount())
mapOverviewMode = 0
spinType = 0
hasFocus = true
locks = 0
alienContactCount = 0

-- print("EXECUTE RELOAD...")
optionsLoader:execute()</Code>
        </Function>
        <Function name="SpindizzyReset">
          <Bind variable="zoneCount">
            <To key="Basics/Integer/RemainingZones"/>
          </Bind>
          <Bind variable="hangworld">
            <To key="Spindizzy/World/Hangworld"/>
          </Bind>
          <Bind variable="player">
            <To key="Spindizzy/World/Hangworld/Player"/>
          </Bind>
          <Bind variable="switchIconPrimary">
            <To key="UI/Layout/Layout/SwitchStatePrimary"/>
          </Bind>
          <Bind variable="switchIconSecondary">
            <To key="UI/Layout/Layout/SwitchStateSecondary"/>
          </Bind>
          <Bind variable="view">
            <To key="Spindizzy/WorldView/Hangworld"/>
          </Bind>
          <Bind variable="timeLimit">
            <To key="Basics/Timer/TimeLimit"/>
          </Bind>
          <Bind variable="spindizzy">
            <To key="Spindizzy"/>
          </Bind>
          <Code>-- Reset Lua variables
mapOverviewMode = 0
spinType = 0
hasFocus = true
locks = 0
alienContactCount = 0
firstZoneEntered = 0

-- Unpause the game
spindizzy:setPause(false)

-- Reset zone count
zoneCount:setValue(hangworld:getZoneCount())

-- Reset switches
if activeSwitchA ~= nil then
  nextSwitch = 0
  activeSwitchA:setValue(false)
  switchIconPrimary:setScreen(nil)
  activeSwitchA = nil
  if activeSwitchB ~= nil then
    activeSwitchB:setValue(false)
    switchIconSecondary:setScreen(nil)
    activeSwitchB = nil
  end
end</Code>
        </Function>
        <Function name="ZoneEntered">
          <Bind variable="score">
            <To key="Basics/Integer/Score"/>
          </Bind>
          <Bind variable="time">
            <To key="Basics/Timer/TimeLimit"/>
          </Bind>
          <Bind variable="zoneCount">
            <To key="Basics/Integer/RemainingZones"/>
          </Bind>
          <Bind variable="hintIcon">
            <To key="UI/Layout/Layout/Hint"/>
          </Bind>
          <Bind variable="themeSet">
            <To key="Spindizzy/ThemeSet/C64"/>
          </Bind>
          <Bind variable="topDebris">
            <To key="Spindizzy/World/Hangworld/DebrisGenerator/Top"/>
          </Bind>
          <Bind variable="ballDebris">
            <To key="Spindizzy/World/Hangworld/DebrisGenerator/Ball"/>
          </Bind>
          <Bind variable="gyroscopeDebris">
            <To key="Spindizzy/World/Hangworld/DebrisGenerator/Gyroscope"/>
          </Bind>
          <Bind variable="view">
            <To key="Spindizzy/WorldView/Hangworld"/>
          </Bind>
          <Bind variable="jewelsCollected">
            <To key=":Integer">
              <Asset key="Basics/Integer/JewelCount"/>
            </To>
          </Bind>
          <Bind variable="hangworld">
            <To key="Spindizzy/World/Hangworld"/>
          </Bind>
          <Bind variable="ending">
            <To key=":Action">
              <Action>
                <Action key="Basics/Function/Ending"/>
              </Action>
            </To>
          </Bind>
          <Bind variable="mandatoryZoneTime">
            <To key="Basics/Timer/MandatoryZoneTime"/>
          </Bind>
          <Bind variable="spindizzy">
            <To key="Spindizzy"/>
          </Bind>
          <Bind variable="timeLimit">
            <To key="Basics/Timer/TimeLimit"/>
          </Bind>
          <Bind variable="currentZoneColour">
            <To key=":Colour">
              <Asset key="Basics/ColourCycler/CurrentRoom/0"/>
            </To>
          </Bind>
          <Bind variable="sound">
            <To key="Basics/Sequence/DamageSound"/>
          </Bind>
          <Bind variable="damage">
            <To key="Basics/Sequence/DamageVisual"/>
          </Bind>
          <Code>-- Delay entry to the previous zone when leaving too quickly.
if mandatoryZoneTime:getValue() &lt; 800 or entered ~= previousZone then

  -- Clear all debris from the screen.
  if entered ~= exitedZone then
    topDebris:clear()
    ballDebris:clear()
    gyroscopeDebris:clear()
  end

  -- Keep track of the current zone and the previous zone.
  previousZone = currentZone
  currentZone = entered

  -- Update timer, score, and overview if this is the first time visiting the zone.
  -- TODO: Can test colour from zone to determine if visited.
  if entered:isVisited() == false then
    zoneCount:setValue(zoneCount:getValue() - 1)
    local earned = 400
    local newTime = time:getValue() + 8000

    -- Any time to add beyond the 3-minute cap is converted to additional score bonus.
    if newTime &gt; 180000 then
      local excess = newTime - 180000
      local extraScore = excess / 10
      earned = earned + extraScore
      newTime = 180000
    end
    time:setValue(newTime)
    score:setValue(math.floor(score:getValue() + earned))

    -- Set that the zone has been visited.
    entered:setVisited()
  end

  -- Set the colour on the overview to show where we are.
  enteredColour:setColour(currentZoneColour)

  -- Set the zone to show in our view.
  view:setZone(entered)

  -- Set the default theme to use in the UI.
  theme = entered:getTheme()
  themeSet:setDefaultTheme(theme)

  -- Activate dynamic objects in the zone.
  entered:resetDynamics()
  entered:setActive(true)

  -- Update the hint icon
  if disableHud == nil then
    local hintCount = currentZone:getHintCount()
    if hintCount &gt; 0 then
      currentZone:giveHint(0)
    else
      hintIcon:setScreen(nil)
    end
  end

  -- Do we show the ending yet?
  if zoneCount:getValue() == 0 and hangworld:getPickUpCount() == jewelsCollected:getValue() then
    ending:execute()
  end
  mandatoryZoneTime:setValue(1000);
else
  -- The entrance delay is implemented by momentarily pausing the game.
  zoneToEnter = entered
  spindizzy:setPause(true)
  timeLimit:pause()
  if alienContactCount > 0 then
    sound:pause()
    damage:pause()
  end
end</Code>
        </Function>
        <Function name="ZoneExited">
          <Bind variable="doneColour">
            <To key=":Colour">
              <Asset key="Basics/Colour/Yellow"/>
            </To>
          </Bind>
          <Bind variable="missedColour">
            <To key=":Colour">
              <Asset key="Basics/Colour/Purple"/>
            </To>
          </Bind>
          <Code>exitedZone = exited
if exited ~= nil then
  exited:setActive(false)
  exited:resetLifts()

  if exited:getRemainingPickUpCount() > 0 then
    exitedColour:setColour(missedColour)
  else
    exitedColour:setColour(doneColour)
  end
  exitedColour = nil
end</Code>
        </Function>
