                                "to": {
                                  "key": "UI/Layout/Main/Damage"
                                }
                              }
                            ],
                            "code": "-- Stooop alien damage; we've probably had enough of that...\nsound:pause()\ndamage:pause()\nscreen:setScreen(nil)\n\n-- Pause the game\nlocks = locks + 1\nif locks == 1 then\n  spindizzy:setPause(true)\n  gameTimeLimit:pause()\nend\n\nlocal message = endMessage:getValue()\nif string.len(message) == 0 then\n  endMessage:setValue(\"Fuel Depleted: Mission Aborted\")\nend\n\n-- Calculate some rounded percentages\ntotalZones = hangworld:getZoneCount()\nmappedPercentage = math.ceil((math.abs((zoneCount:getValue() / totalZones) - 1) * 100) - 0.5)\ntotalJewels = hangworld:getPickUpCount()\njewelsPercentage = math.ceil(((jewelsCollected:getValue() / totalJewels) * 100) - 0.5)\ncompletePercentage = math.ceil(((mappedPercentage + jewelsPercentage) / 2) - 0.5)\n\n-- Set result values\nmappedMessage:setValue(\"\" .. mappedPercentage .. \"%\")\njewelsMessage:setValue(\"\" .. jewelsPercentage .. \"%\")\ncompleteMessage:setValue(\"\" .. completePercentage .. \"%\")\nif GlobalExplorer ~= 1 then\n  scoreMessage:setValue(\"\" .. score:getValue())\nelse\n  -- Prevent high score from triggering\n  score:setValue(-1)\n  scoreMessage:setValue(\"N/A\")\n  GlobalExplorer = nil\nend\nhasFocus = false\ngameOverSequence:play()"
