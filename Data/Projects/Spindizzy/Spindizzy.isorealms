        <Menu name="Pause">
          <Colour key="Basics/ColourCycler/Menu Selection Highlight/0"/>
          <Font key="Basics/Font/Menu"/>
          <Options>
            <Action label="Resume">
              <Action>
                <Action key="Basics/Function/Unpause"/>
              </Action>
            </Action>
            <Action label="Options">
              <Action>
                <Action key="Basics/Function/PushScreen">
                  <Bind argument="menuScreen">
                    <To key=":Screen">
                      <Asset key="UI/Menu/Options"/>
                    </To>
                  </Bind>
                  <Bind argument="menuInput">
                    <To key=":InputHandler">
                      <Asset key="UI/Menu/Options"/>
                    </To>
                  </Bind>
                  <Bind argument="menu">
                    <To key="UI/Menu/Options"/>
                  </Bind>
                </Action>
              </Action>
            </Action>
            <Action label="Abort Mission">
              <Action>
                <Action key="Basics/Function/PushScreen">
                  <Bind argument="menuScreen">
                    <To key=":Screen">
                      <Asset key="UI/Prompt/AbortMission"/>
                    </To>
                  </Bind>
                  <Bind argument="menuInput">
                    <To key=":InputHandler">
                      <Asset key="UI/Prompt/AbortMission"/>
                    </To>
                  </Bind>
                  <Bind argument="menu">
                    <To key="UI/Prompt/AbortMission"/>
                  </Bind>
                </Action>
              </Action>
            </Action>
          </Options>
          <Exit>
            <Action key="Basics/Function/Unpause"/>
          </Exit>
        </Menu>
        <Prompt name="AbortMission" text="Abort Mission?" false="No" true="Yes">
          <Highlight key="Basics/ColourCycler/Menu Selection Highlight/0"/>
          <Font key="Basics/Font/Menu"/>
          <False>
            <Action key="Basics/Function/PopScreen"/>
          </False>
          <True>
            <Action key="Basics/Script">
              <Bind variable="time">
                <To key="Basics/Timer/TimeLimit"/>
              </Bind>
              <Bind variable="screen">
                <To key="UI/Layout/Main/Menu"/>
              </Bind>
              <Bind variable="spindizzy">
                <To key="Spindizzy"/>
              </Bind>
              <Bind variable="endingMessage">
                <To key="Basics/String/EndingMessage"/>
              </Bind>
              <Code>-- Setting time to zero causes mission to end
time:setValue(0)

-- Pop all menu screens
while #menuStack &gt; 0 do
  table.remove(menuStack)
  table.remove(inputStack)
end

-- Set message that player has quit
endingMessage:setValue("Cartographer Quit: Mission Aborted")

-- Get rid of the prompt
screen:setScreen(nil)

-- Unpause the game
locks = locks - 1
if locks == 0 then
  spindizzy:setPause(false)
  if GlobalExplorer ~= 1 then
    time:resume()
  end
end

-- Disable menu access
hasFocus = false</Code>
            </Action>
          </True>
        </Prompt>
      </Resources>
