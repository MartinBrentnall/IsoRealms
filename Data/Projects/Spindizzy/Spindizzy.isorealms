 + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = (zMomentum - 0.1) * math.random()\n      topDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 1 then\n    for i = 1, 8 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = (zMomentum - 0.1) * math.random()\n      ballDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 2 then\n    for i = 1, 12 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = (zMomentum - 0.1) * math.random()\n      gyroscopeDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  end\nend"},"onBecomingFalse":{"key":"None"}},"GERALD Transform":{"value":{"key":"Replay/Replayer/Gameplay Recorder/GERALD Transform"},"onBecomingTrue":{"key":"Basics/Script","bindings":[{"variable":"playerCraftModels","to":{"key":"Equilibria/ModelCycler/Player Craft"}},{"variable":"alienCraftModels","to":{"key":"Equilibria/ModelCycler/Alien Craft"}},{"variable":"player","to":{"key":"Equilibria/Player/Player"}},{"variable":"alienTypeA","to":{"key":"Equilibria/Alien/Enemy Type 1"}},{"variable":"alienTypeB","to":{"key":"Equilibria/Alien/Enemy Type 2"}}],"code":"if hasFocus then\n  playerCraftModels:next()\n  alienCraftModels:next()\n  if spinType == 0 then\n    player:setSpinSpeed(0.0)\n    alienTypeA:setSpinSpeed(-360.0)\n    alienTypeB:setSpinSpeed(-180.0)\n    spinType = 1\n  elseif spinType == 1 then\n    player:setSpinSpeed(-360.0)\n    alienTypeA:setSpinSpeed(-180.0)\n    alienTypeB:setSpinSpeed(0.0)\n    spinType = 2\n  else\n    player:setSpinSpeed(-180.0)\n    alienTypeA:setSpinSpeed(0.0)\n    alienTypeB:setSpinSpeed(-360.0)\n    spinType = 0\n  end\nend"},"onBecomingFalse":{"key":"None"}},"Toggle Map":{"value":{"key":"Replay/Replayer/Gameplay Recorder/Toggle Map"},"onBecomingTrue":{"key":"Basics/Script","bindings":[{"variable":"view","to":{"key":"Equilibria/WorldView/Game View/Camera"}}],"code":"if hasFocus then\n  if mapOverviewMode == 1 then\n    view:transitionToStart()\n    mapOverviewMode = 0\n  else\n    view:transitionToEnd()\n    mapOverviewMode = 1\n  end\nend"},"onBecomingFalse":{"key":"None"}},"Toggle Pause":{"value":{"key":"Replay/Replayer/Gameplay Recorder/Toggle Pause"},"onBecomingTrue":{"key":"Basics/Function/Equilibria Game Pause","bindings":[]},"onBecomingFalse":{"key":"None"}}},"omissions":[]},"Colour":{"instances":{"C64 Palette 1":{"alpha":1.0},"C64 Palette 10":{"red":0.3398439884185791,"green":0.2578119933605194,"alpha":1.0},"C64 Palette 10 (Desaturated)":{"red":0.25663799047470095,"green":0.25663799047470095,"blue":0.25663799047470095,"alpha":1.0},"C64 Palette 11":{"red":0.7304689884185791,"green":0.4648439884185791,"blue":0.4257810115814209,"alpha":1.0},"C64 Palette 11 (Desaturated)":{"red":0.5184959769248962,"green":0.5184959769248962,"blue":0.5184959769248962,"alpha":1.0},"C64 Palette 12":{"red":0.328125,"green":0.328125,"blue":0.328125,"alpha":1.0},"C64 Palette 13":{"red":0.5,"green":0.5,"blue":0.5,"alpha":1.0},"C64 Palette 14":{"red":0.671875,"green":0.9140620231628418,"blue":0.53125,"alpha":1.0},"C64 Palette 14 (Desaturated)":{"red":0.8349339962005615,"green":0.8349339962005615,"blue":0.8349339962005615,"alpha":1.0},"C64 Palette 15":{"red":0.484375,"green":0.4375,"blue":0.8515620231628418,"alpha":1.0},"C64 Palette 15 (Desaturated)":{"red":0.4773609936237335,"green":0.4773609936237335,"blue":0.4773609936237335,"alpha":1.0},"C64 Palette 16":{"red":0.6679689884185791,"green":0.6679689884185791,"blue":0.6679689884185791,"alpha":1.0},"C64 Palette 2":{"red":1.0,"green":1.0,"blue":1.0,"alpha":1.0},"C64 Palette 3":{"red":0.546875,"green":0.2421880066394806