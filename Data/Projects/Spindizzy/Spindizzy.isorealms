        "CollisionHandler": {
          "instances": {
            "PlayerToAlienA": {
              "objectA": {
                "key": "Player/Player"
              },
              "objectB": {
                "key": "Alien/Enemy Type A"
              },
              "onCollision": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "sound",
                    "to": {
                      "key": "Basics/Sequence/DamageSound/Instance"
                    }
                  },
                  {
                    "variable": "damage",
                    "to": {
                      "key": "Basics/Sequence/DamageVisual/Instance"
                    }
                  },
                  {
                    "variable": "screen",
                    "to": {
                      "key": "UI/Layout/Main/Damage"
                    }
                  },
                  {
                    "variable": "indicator",
                    "to": {
                      "key": ":Screen",
                      "asset": {
                        "key": "UI/Layout/Damage Indicator"
                      }
                    }
                  },
                  {
                    "variable": "timeSpeed",
                    "to": {
                      "key": "Basics/Float/Time Speed"
                    }
                  }
                ],
                "code": "if alienContactCount == 0 then\n  sound:play()\n  damage:play()\n  screen:setScreen(indicator)\nend\nalienContactCount = alienContactCount + 1\ntimeSpeed:setValue(1.0 + alienContactCount * 20.0)"
              },
              "onParting": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "sound",
                    "to": {
                      "key": "Basics/Sequence/DamageSound/Instance"
                    }
                  },
                  {
                    "variable": "damage",
                    "to": {
                      "key": "Basics/Sequence/DamageVisual/Instance"
                    }
                  },
                  {
                    "variable": "screen",
                    "to": {
                      "key": "UI/Layout/Main/Damage"
                    }
                  },
                  {
                    "variable": "timeSpeed",
                    "to": {
                      "key": "Basics/Float/Time Speed"
                    }
                  }
                ],
                "code": "alienContactCount = alienContactCount - 1\nif alienContactCount == 0 then\n  sound:pause()\n  damage:pause()\n  screen:setScreen(nil)\nend\ntimeSpeed:setValue(1.0 + alienContactCount * 20.0)"
              }
            },
