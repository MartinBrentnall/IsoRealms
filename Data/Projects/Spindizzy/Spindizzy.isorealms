        </PickUp>
        <Player name="Player" spinSpeed="-180.0" acceleration="0.0000265" bounceFactor="0.31">
          <InputThrust key="Basics/DigitalInput/Thrust"/>
          <InputX key="Basics/AnalogueInput/MoveX"/>
          <InputY key="Basics/AnalogueInput/MoveY"/>
          <Model key="Basics/ModelCycler/Player Craft/0"/>
          <Orientation key="Spindizzy/WorldView/Hangworld/Camera/Yaw"/>
          <RespawnAction>
            <Action key="Basics/Script">
              <Bind variable="time">
                <To key="Basics/Timer/TimeLimit"/>
              </Bind>
              <Bind variable="soundRespawnHard">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Sound/RespawnHard"/>
                  </Action>
                </To>
              </Bind>
              <Bind variable="launchMomentum">
                <To key="Spindizzy/LaunchMomentum"/>
              </Bind>
              <Code>local newTime = time:getValue() - 10000
  if newTime &lt; 0 then
  newTime = 0
end
time:setValue(newTime)
if launchMomentum:getZ() > 0.0 then
  soundRespawnHard:execute()
end</Code>
            </Action>
          </RespawnAction>
          <FallImpactAction>
            <Action key="Basics/Script">
              <Bind variable="topDebris">
                <To key="Spindizzy/World/Hangworld/DebrisGenerator/Top"/>
              </Bind>
              <Bind variable="ballDebris">
                <To key="Spindizzy/World/Hangworld/DebrisGenerator/Ball"/>
              </Bind>
              <Bind variable="gyroscopeDebris">
                <To key="Spindizzy/World/Hangworld/DebrisGenerator/Gyroscope"/>
              </Bind>
              <Bind variable="player">
                <To key="Spindizzy/Player"/>
              </Bind>
              <Bind variable="fallDistance">
                <To key="Spindizzy/FallDistance"/>
              </Bind>
              <Bind variable="launchLocation">
                <To key="Spindizzy/LaunchLocation"/>
              </Bind>
              <Bind variable="launchMomentum">
                <To key="Spindizzy/LaunchMomentum"/>
              </Bind>
              <Bind variable="soundImpactHard">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Sound/ImpactHard"/>
                  </Action>
                </To>
              </Bind>
              <Bind variable="soundImpactMedium">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Sound/ImpactMedium"/>
                  </Action>
                </To>
              </Bind>
              <Bind variable="soundImpactSoft">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Sound/ImpactSoft"/>
                  </Action>
                </To>
              </Bind>
              <Code>player:setStepReach(0.5)
location = player:getLocation()
if fallDistance:getValue() &gt; 2.75 then
  momentum = player:getMomentum()
  xMomentum = momentum:getX()
  yMomentum = momentum:getY()
  zMomentum = momentum:getZ()
  player:destroy()
  soundImpactHard:execute()
  if spinType == 0 then
    for i = 1, 5 do
      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02
      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02
      zMomentumVary = zMomentum * math.random()
      topDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)
    end
  elseif spinType == 1 then
    for i = 1, 8 do
      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02
      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02
      zMomentumVary = zMomentum * math.random()
      ballDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)
    end
  elseif spinType == 2 then
    for i = 1, 12 do
      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02
      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02
      zMomentumVary = zMomentum * math.random()
      gyroscopeDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)
    end
  end
elseif launchLocation:getX() ~= nil then
  hitX = location:getX()
  hitY = location:getY()
  distX = math.abs(launchLocation:getX() - hitX)
  distY = math.abs(launchLocation:getY() - hitY)
  dist = math.max(distX, distY)
  if launchMomentum:getZ() > 0.0 then
    if dist > 1.98 then
      soundImpactHard:execute()
    elseif dist > 1.0 then
      soundImpactMedium:execute()
    elseif dist > 0.5 then
      soundImpactSoft:execute()
    end
  end
end</Code>
            </Action>
          </FallImpactAction>
          <FallBounceAction>
            <Action key="Basics/Script">
              <Bind variable="player">
                <To key="Spindizzy/Player"/>
              </Bind>
              <Bind variable="fallDistance">
                <To key="Spindizzy/FallDistance"/>
              </Bind>
              <Bind variable="launchLocation">
                <To key="Spindizzy/LaunchLocation"/>
              </Bind>
              <Bind variable="launchMomentum">
                <To key="Spindizzy/LaunchMomentum"/>
              </Bind>
              <Code>-- This is kinda hacky for a difficult part of the game.
if fallDistance:getValue() &gt; 2.75 then
  player:setStepReach(0.93)
else
  player:setStepReach(0.8)
end
if fallDistance:getValue() &gt; 2.75 or launchMomentum:getZ() ~= 0.0 then
  player:setBounceFactor(0.31)
else
  player:setBounceFactor(0.0)
end</Code>
            </Action>
          </FallBounceAction>
          <WallBounceAction>
            <Action key="Basics/Script">
              <Bind variable="player">
                <To key="Spindizzy/Player"/>
              </Bind>
              <Bind variable="wallZone">
                <To key="Spindizzy/Zone"/>
              </Bind>
              <Bind variable="wallZoneColour">
                <To key="~" local="Terrain/Zone/WorldView/Overview/ZoneView"/>
              </Bind>
              <Bind variable="playerZoneColour">
                <To key="~" local="Player/Zone/WorldView/Overview/ZoneView"/>
              </Bind>
              <Bind variable="wall">
                <To key="Spindizzy/Wall"/>
              </Bind>
              <Bind variable="zoneEnterFunction">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Function/ZoneEntered"/>
                  </Action>
                </To>
              </Bind>
              <Bind variable="zoneExitFunction">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Function/ZoneExited"/>
                  </Action>
                </To>
              </Bind>
              <Code>-- This action is only applicable when the wall is in a different zone than the player.
if player:getZone() ~= wallZone and player:getZone() ~= nil and wall:isAtZoneEdge() then

  -- Leave the current zone and enter the zone where the wall is.
  zoneToExit = player:getZone();
  zoneToEnter = wallZone;
  if zoneToExit ~= nil then
    exited = zoneToExit
    exitedColour = playerZoneColour
    zoneExitFunction:execute()
    exited = nil
  end
  if zoneToEnter ~= nil then
    entered = zoneToEnter
    enteredColour = wallZoneColour
    zoneEnterFunction:execute()
    entered = nil
  end

  -- Leave the zone where the wall is and return to the player's zone.
  -- The pause mechanism will trigger automatically since no time has passed.
  zoneToEnter = player:getZone()
  zoneToExit = wallZone;
  if zoneToExit ~= nil then
    exited = zoneToExit
    exitedColour = wallZoneColour
    zoneExitFunction:execute()
    exited = nil
  end
  if zoneToEnter ~= nil then
    entered = zoneToEnter
    enteredColour = playerZoneColour
    zoneEnterFunction:execute()
    entered = nil
  end
end</Code>
            </Action>
          </WallBounceAction>
        </Player>
