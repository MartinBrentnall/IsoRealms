,"to":{"key":"Basics/String/Message World Explored"}},{"variable":"jewelsMessage","to":{"key":"Basics/String/Message Jewels Collected"}},{"variable":"completeMessage","to":{"key":"Basics/String/Message Completion"}},{"variable":"score","to":{"key":"Basics/Integer/Score"}},{"variable":"jewelsCollected","to":{"key":":Integer","asset":{"key":"Basics/Integer/Collected Jewel Count"}}},{"variable":"zoneCount","to":{"key":":Integer","asset":{"key":"Basics/Integer/Remaining Zones Count"}}},{"variable":"hangworld","to":{"key":"Equilibria/World/Game World"}},{"variable":"sound","to":{"key":"Basics/Sequence/Alien Damage (Sound Loop)/Instance"}},{"variable":"damage","to":{"key":"Basics/Sequence/Alien Damage (Screen Border Effect)/Instance"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Alien Damage Indicator"}}],"code":"-- Stooop alien damage; we've probably had enough of that...\nsound:pause()\ndamage:pause()\nscreen:setScreen(nil)\n\n-- Pause the game\nlocks = locks + 1\nif locks == 1 then\n  equilibria:setPause(true)\n  gameTimeLimit:pause()\nend\n\nlocal message = endMessage:getValue()\nif string.len(message) == 0 then\n  endMessage:setValue(\"Fuel Depleted: Mission Aborted\")\nend\n\n-- Calculate some rounded percentages\ntotalZones = hangworld:getZoneCount()\nmappedPercentage = math.ceil((math.abs((zoneCount:getValue() / totalZones) - 1) * 100) - 0.5)\ntotalJewels = hangworld:getPickUpCount()\njewelsPercentage = math.ceil(((jewelsCollected:getValue() / totalJewels) * 100) - 0.5)\ncompletePercentage = math.ceil(((mappedPercentage + jewelsPercentage) / 2) - 0.5)\n\n-- Set result values\nmappedMessage:setValue(\"\" .. mappedPercentage .. \"%\")\njewelsMessage:setValue(\"\" .. jewelsPercentage .. \"%\")\ncompleteMessage:setValue(\"\" .. completePercentage .. \"%\")\nif GlobalExplorer ~= 1 then\n  scoreMessage:setValue(\"\" .. score:getValue())\nelse\n  -- Prevent high score from triggering\n  score:setValue(-1)\n  scoreMessage:setValue(\"N/A\")\n  GlobalExplorer = nil\nend\nhasFocus = false\ngameOverSequence:play()"}}]}}],"instances":[{"name":"Instance","startTime":30000}]},"Timer (Minimum Zone Visible Time)":{"playing":true,"speed":{"key":"Literal","value":1.0},"tracks":[{"track":{"key":"Action","events":[{"delay":1000,"execute":{"key":"Basics/Script","bindings":[{"variable":"equilibria","to":{"key":"Equilibria"}},{"variable":"gameTimeLimit","to":{"key":"Basics/Sequence/Timer (Game Time Limit)/Instance"}},{"variable":"zoneEnterFunction","to":{"key":":Action","asset":{"key":"Basics/Function/Equilibria Handle Zone Entered","bindings":[]}}},{"variable":"sound","to":{"key":"Basics/Sequence/Alien Damage (Sound Loop)/Instance"}},{"variable":"damage","to":{"key":"Basics/Sequence/Alien Damage (Screen Border Effect)/Instance"}}],"code":"if zoneToEnter ~= nil then\n  equilibria:setPause(false)\n  if GlobalExplorer ~= 1 then\n    gameTimeLimit:play()\n  end\n  if alienContactCount > 0 then\n    sound:play()\n    damage:play()\n  end\n  entered = zoneToEnter\n  zoneEnterFunction:execute()\n  zoneToEnter = nil\nend"}}]}}],"instances":[{"name":"Instance"}]}},"omissions":[]},"Sound":{"instances":{"Activate State 1":{"filename":{"path":"Sounds/Diamond Left.ogg"}},"Activate State 10":{"filename":{"path":"Sounds/Circle Right.ogg"}},"Activate State 11":{"filename":{"path":"Sounds/Circle Both.ogg"}},"Activate State 2":{"filename":{"path":"Sounds/Diamond Right.ogg"}},"Activate State 3":{"filename":{"path":"Sounds/Diamond Both.ogg"}},"Activate State 4":{"filename":{"path":"Sounds/Square None.ogg"}},"Activate State 5":{"filename":{"path":"Sounds/Square Left.ogg"}},"Activate State 6":{"filename":{"path":"Sounds/Square Right.ogg"}},"Activate State 7":{"filename":{"path":"Sounds/Square Both.ogg"}},"Activate State 8":{"filename":{"path":"Sounds/Circle None.ogg"}},"Activate State 9":{"filename":{"path":"Sounds/Circle Left.ogg"}},"Alien Damage":{"filename":{"path":"Sounds/Alien Contact.ogg"}},"Deactivate All States":{"filename":{"path":"Sounds/Diamond None.ogg