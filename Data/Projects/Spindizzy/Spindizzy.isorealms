        <BoundaryHandler name="JewelCollector">
          <Type key="PickUp/Jewel"/>
          <Object key="Player/Player"/>
          <EnteredAction>
            <Action key="Basics/Script">
              <Bind variable="sound">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Sound/Jewel"/>
                  </Action>
                </To>
              </Bind>
              <Bind variable="score">
                <To key="Basics/Integer/Score"/>
              </Bind>
              <Bind variable="time">
                <To key="Basics/Timer/TimeLimit"/>
              </Bind>
              <Bind variable="jewelsCollected">
                <To key="Basics/Integer/JewelCount"/>
              </Bind>
              <Bind variable="zone">
                <To key="Spindizzy/Zone"/>
              </Bind>
              <Bind variable="zoneCount">
                <To key=":Integer">
                  <Asset key="Basics/Integer/RemainingZones"/>
                </To>
              </Bind>
              <Bind variable="hangworld">
                <To key="Spindizzy/World/Hangworld"/>
              </Bind>
              <Bind variable="ending">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Function/Ending"/>
                  </Action>
                </To>
              </Bind>
              <Code>sound:execute()
jewelsCollected:setValue(jewelsCollected:getValue() + 1)
local earned = 600
local newTime = time:getValue() + 12000
if newTime &gt; 180000 then
  local excess = newTime - 180000
  local extraScore = excess / 10
  earned = earned + extraScore
  newTime = 180000
end
time:setValue(newTime)
score:setValue(math.floor(score:getValue() + earned))

-- Do we show the ending yet?
if zoneCount:getValue() == 0 and hangworld:getPickUpCount() == jewelsCollected:getValue() then
  ending:execute()
end</Code>
            </Action>
          </EnteredAction>
        </BoundaryHandler>
        <BoundaryHandler name="PlayerZoneHandler">
          <Type key="Zone/Zone"/>
          <Object key="Player/Player"/>
          <EnteredAction>
            <Action key="Basics/Script">
              <Bind variable="zone">
                <To key="Spindizzy/Zone"/>
              </Bind>
              <Bind variable="zoneColour">
                <To key="~" local="Boundary/Zone/WorldView/Overview/ZoneView"/>
              </Bind>
              <Bind variable="zoneEnterFunction">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Function/ZoneEntered"/>
                  </Action>
                </To>
              </Bind>
              <Bind variable="optionsLoader">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Function/ReloadConfiguration"/>
                  </Action>
                </To>
              </Bind>
              <Code>-- Hack to reload the controls when starting the game.
if firstZoneEntered == 0 then
  optionsLoader:execute()
  firstZoneEntered = 1
end
entered = zone
enteredColour = zoneColour
zoneEnterFunction:execute()</Code>
            </Action>
          </EnteredAction>
          <ExitedAction>
            <Action key="Basics/Script">
              <Bind variable="zone">
                <To key="Spindizzy/Zone"/>
              </Bind>
              <Bind variable="zoneColour">
                <To key="~" local="Boundary/Zone/WorldView/Overview/ZoneView"/>
              </Bind>
              <Bind variable="zoneExitFunction">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Function/ZoneExited"/>
                  </Action>
                </To>
              </Bind>
              <Code>exited = zone
exitedColour = zoneColour
zoneExitFunction:execute()</Code>
            </Action>
          </ExitedAction>
        </BoundaryHandler>
