        <WorldView name="Hangworld" world="Hangworld">
          <Camera key="Transitional" duration="500">
            <Start key="Gameplay" direction="NorthWest" duration="500"/>
            <End key="Overview"/>
            <OnStartDeparture>
              <Action key="Basics/Script">
                <Bind variable="map">
                  <To key="Spindizzy/World/Hangworld"/>
                </Bind>
                <Bind variable="timeLimit">
                  <To key="Basics/Timer/TimeLimit"/>
                </Bind>
                <Bind variable="spindizzy">
                  <To key="Spindizzy"/>
                </Bind>
                <Bind variable="background">
                  <To key="UI/Layout/Main/Background"/>
                </Bind>
                <Bind variable="backgroundBlack">
                  <To key=":Screen">
                    <Asset key="UI/Panel/BackgroundOverview"/>
                  </To>
                </Bind>
                <Bind variable="world">
                  <To key="UI/Layout/Layout/Game"/>
                </Bind>
                <Bind variable="worldOverview">
                  <To key=":Screen">
                    <Asset key="Spindizzy/WorldView/Overview"/>
                  </To>
                </Bind>
                <Bind variable="sound">
                  <To key="Basics/Sequence/DamageSound"/>
                </Bind>
                <Bind variable="damage">
                  <To key="Basics/Sequence/DamageVisual"/>
                </Bind>
                <Code>locks = locks + 1
if locks == 1 then
  spindizzy:setPause(true)
  timeLimit:pause()
  background:setScreen(backgroundBlack)
  world:setScreen(worldOverview)
  if alienContactCount > 0 then
    sound:pause()
    damage:pause()
  end
end</Code>
              </Action>
            </OnStartDeparture>
            <OnStartArrival>
              <Action key="Basics/Script">
                <Bind variable="map">
                  <To key="Spindizzy/World/Hangworld"/>
                </Bind>
                <Bind variable="timeLimit">
                  <To key="Basics/Timer/TimeLimit"/>
                </Bind>
                <Bind variable="spindizzy">
                  <To key="Spindizzy"/>
                </Bind>
                <Bind variable="background">
                  <To key="UI/Layout/Main/Background"/>
                </Bind>
                <Bind variable="backgroundNormal">
                  <To key=":Screen">
                    <Asset key="UI/Panel/Background"/>
                  </To>
                </Bind>
                <Bind variable="world">
                  <To key="UI/Layout/Layout/Game"/>
                </Bind>
                <Bind variable="worldNormal">
                  <To key=":Screen">
                    <Asset key="Spindizzy/WorldView/Hangworld"/>
                  </To>
                </Bind>
                <Bind variable="sound">
                  <To key="Basics/Sequence/DamageSound"/>
                </Bind>
                <Bind variable="damage">
                  <To key="Basics/Sequence/DamageVisual"/>
                </Bind>
                <Code>locks = locks - 1
if locks == 0 then
  spindizzy:setPause(false)
  if GlobalExplorer ~= 1 then
    timeLimit:resume()
  end
  background:setScreen(backgroundNormal)
  world:setScreen(worldNormal)
  if alienContactCount > 0 then
    sound:play()
    damage:play()
  end
end</Code>
              </Action>
            </OnStartArrival>
          </Camera>
          <ZoneViewType key="Actual"/>
        </WorldView>
