          {
            "type": "Player",
            "instances": [
              {
                "id": "Player",
                "spinSpeed": -180,
                "bounceFactor": 0.3100000023841858,
                "appearance": {
                  "key": "Spindizzy/ModelCycler/Player Craft/0"
                },
                "onRespawn": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "gameTimeLimit",
                      "to": {
                        "key": "Basics/Sequence/Time Limit/Instance"
                      }
                    },
                    {
                      "variable": "soundRespawnHard",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Sound/RespawnHard"
                        }
                      }
                    },
                    {
                      "variable": "launchMomentum",
                      "to": {
                        "key": "Spindizzy/LaunchMomentum"
                      }
                    }
                  ],
                  "code": "local newTime = gameTimeLimit:getTime() + 10000\ngameTimeLimit:setTime(newTime)\nif launchMomentum:getZ() > 0.0 then\n  soundRespawnHard:execute()\nend"
                },
                "thrustInput": {
                  "key": "Basics/DigitalInput/Thrust"
                },
                "xInput": {
                  "key": "Basics/AnalogueInput/MoveX"
                },
                "yInput": {
                  "key": "Basics/AnalogueInput/MoveY"
                },
                "onFallImpact": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "topDebris",
                      "to": {
                        "key": "Spindizzy/World/Hangworld/DebrisGenerator/Top"
                      }
                    },
                    {
                      "variable": "ballDebris",
                      "to": {
                        "key": "Spindizzy/World/Hangworld/DebrisGenerator/Ball"
                      }
                    },
                    {
                      "variable": "gyroscopeDebris",
                      "to": {
                        "key": "Spindizzy/World/Hangworld/DebrisGenerator/Gyroscope"
                      }
                    },
                    {
                      "variable": "player",
                      "to": {
                        "key": "Spindizzy/Player"
                      }
                    },
                    {
                      "variable": "fallDistance",
                      "to": {
                        "key": "Spindizzy/FallDistance"
                      }
                    },
                    {
                      "variable": "launchLocation",
                      "to": {
                        "key": "Spindizzy/LaunchLocation"
                      }
                    },
                    {
                      "variable": "launchMomentum",
                      "to": {
                        "key": "Spindizzy/LaunchMomentum"
                      }
                    },
                    {
                      "variable": "soundImpactHard",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Sound/ImpactHard"
                        }
                      }
                    },
                    {
                      "variable": "soundImpactMedium",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Sound/ImpactMedium"
                        }
                      }
                    },
                    {
                      "variable": "soundImpactSoft",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Sound/ImpactSoft"
                        }
                      }
                    }
                  ],
                  "code": "player:setStepReach(0.5)\nlocation = player:getLocation()\nif fallDistance:getValue() > 2.75 then\n  momentum = player:getMomentum()\n  xMomentum = momentum:getX()\n  yMomentum = momentum:getY()\n  zMomentum = momentum:getZ()\n  player:destroy()\n  soundImpactHard:execute()\n  if spinType == 0 then\n    for i = 1, 5 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = zMomentum * math.random()\n      topDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 1 then\n    for i = 1, 8 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = zMomentum * math.random()\n      ballDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 2 then\n    for i = 1, 12 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = zMomentum * math.random()\n      gyroscopeDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  end\nelseif launchLocation:getX() ~= nil then\n  hitX = location:getX()\n  hitY = location:getY()\n  distX = math.abs(launchLocation:getX() - hitX)\n  distY = math.abs(launchLocation:getY() - hitY)\n  dist = math.max(distX, distY)\n  if launchMomentum:getZ() > 0.0 then\n    if dist > 1.98 then\n      soundImpactHard:execute()\n    elseif dist > 1.0 then\n      soundImpactMedium:execute()\n    elseif dist > 0.5 then\n      soundImpactSoft:execute()\n    end\n  end\nend"
                },
                "onFallBounce": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "player",
                      "to": {
                        "key": "Spindizzy/Player"
                      }
                    },
                    {
                      "variable": "fallDistance",
                      "to": {
                        "key": "Spindizzy/FallDistance"
                      }
                    },
                    {
                      "variable": "launchLocation",
                      "to": {
                        "key": "Spindizzy/LaunchLocation"
                      }
                    },
                    {
                      "variable": "launchMomentum",
                      "to": {
                        "key": "Spindizzy/LaunchMomentum"
                      }
                    }
                  ],
                  "code": "-- This is kinda hacky for a difficult part of the game.\nif fallDistance:getValue() > 2.75 then\n  player:setStepReach(0.93)\nelse\n  player:setStepReach(0.8)\nend\nif fallDistance:getValue() > 2.75 or launchMomentum:getZ() ~= 0.0 then\n  player:setBounceFactor(0.31)\nelse\n  player:setBounceFactor(0.0)\nend"
                },
                "onWallBounce": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "player",
                      "to": {
                        "key": "Spindizzy/Player"
                      }
                    },
                    {
                      "variable": "wallZone",
                      "to": {
                        "key": "Spindizzy/Zone"
                      }
                    },
                    {
                      "variable": "wallZoneColour",
                      "to": {
                        "key": "~",
                        "local": "Terrain/Zone/WorldView/Overview/ZoneView"
                      }
                    },
                    {
                      "variable": "playerZoneColour",
                      "to": {
                        "key": "~",
                        "local": "Player/Zone/WorldView/Overview/ZoneView"
                      }
                    },
                    {
                      "variable": "wall",
                      "to": {
                        "key": "Spindizzy/Wall"
                      }
                    },
                    {
                      "variable": "zoneEnterFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/ZoneEntered",
                          "bindings": []
                        }
                      }
                    },
                    {
                      "variable": "zoneExitFunction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/ZoneExited",
                          "bindings": []
                        }
                      }
                    }
                  ],
                  "code": "-- This action is only applicable when the wall is in a different zone than the player.\nif player:getZone() ~= wallZone and player:getZone() ~= nil and wall:isAtZoneEdge() then\n\n  -- Leave the current zone and enter the zone where the wall is.\n  zoneToExit = player:getZone();\n  zoneToEnter = wallZone;\n  if zoneToExit ~= nil then\n    exited = zoneToExit\n    exitedColour = playerZoneColour\n    zoneExitFunction:execute()\n    exited = nil\n  end\n  if zoneToEnter ~= nil then\n    entered = zoneToEnter\n    enteredColour = wallZoneColour\n    zoneEnterFunction:execute()\n    entered = nil\n  end\n\n  -- Leave the zone where the wall is and return to the player's zone.\n  -- The pause mechanism will trigger automatically since no time has passed.\n  zoneToEnter = player:getZone()\n  zoneToExit = wallZone;\n  if zoneToExit ~= nil then\n    exited = zoneToExit\n    exitedColour = wallZoneColour\n    zoneExitFunction:execute()\n    exited = nil\n  end\n  if zoneToEnter ~= nil then\n    entered = zoneToEnter\n    enteredColour = playerZoneColour\n    zoneEnterFunction:execute()\n    entered = nil\n  end\nend"
                },
                "orientation": {
                  "key": "Spindizzy/WorldView/Hangworld/Camera/Yaw"
                }
              }
            ]
          },
