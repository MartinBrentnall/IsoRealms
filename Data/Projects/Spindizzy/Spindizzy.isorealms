                "onStartDeparture": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "map",
                      "to": {
                        "key": "Spindizzy/World/Game World"
                      }
                    },
                    {
                      "variable": "gameTimeLimit",
                      "to": {
                        "key": "Basics/Sequence/Time Limit/Instance"
                      }
                    },
                    {
                      "variable": "spindizzy",
                      "to": {
                        "key": "Spindizzy"
                      }
                    },
                    {
                      "variable": "sound",
                      "to": {
                        "key": "Basics/Sequence/DamageSound/Instance"
                      }
                    },
                    {
                      "variable": "damage",
                      "to": {
                        "key": "Basics/Sequence/DamageVisual/Instance"
                      }
                    }
                  ],
                  "code": "locks = locks + 1\nif locks == 1 then\n  spindizzy:setPause(true)\n  gameTimeLimit:pause()\n  if alienContactCount > 0 then\n    sound:pause()\n    damage:pause()\n  end\nend"
                },
                "onStartArrival": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "map",
                      "to": {
                        "key": "Spindizzy/World/Game World"
                      }
                    },
                    {
                      "variable": "gameTimeLimit",
                      "to": {
                        "key": "Basics/Sequence/Time Limit/Instance"
                      }
                    },
                    {
                      "variable": "spindizzy",
                      "to": {
                        "key": "Spindizzy"
                      }
                    },
                    {
                      "variable": "sound",
                      "to": {
                        "key": "Basics/Sequence/DamageSound/Instance"
                      }
                    },
                    {
                      "variable": "damage",
                      "to": {
                        "key": "Basics/Sequence/DamageVisual/Instance"
                      }
                    }
                  ],
                  "code": "locks = locks - 1\nif locks == 0 then\n  spindizzy:setPause(false)\n  if GlobalExplorer ~= 1 then\n    gameTimeLimit:play()\n  end\n  if alienContactCount > 0 then\n    sound:play()\n    damage:play()\n  end\nend"
                },
                "onEndDeparture": {
                  "key": "None"
                },
                "onEndArrival": {
                  "key": "None"
                }
