                      {
                        "variable": "damage",
                        "to": {
                          "key": "Basics/Sequence/DamageVisual/Instance"
                        }
                      }
                    ],
                    "code": "locks = locks - 1\nif locks == 0 then\n  spindizzy:setPause(false)\n  if GlobalExplorer ~= 1 then\n    gameTimeLimit:play()\n  end\n  background:setScreen(backgroundNormal)\n  world:setScreen(worldNormal)\n  if alienContactCount > 0 then\n    sound:play()\n    damage:play()\n  end\nend"
