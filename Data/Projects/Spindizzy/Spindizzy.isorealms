        <CollisionHandler name="PlayerToAlienA">
          <TypeA key="Player/Player"/>
          <TypeB key="Alien/Ball"/>
          <EnteredAction>
            <Action key="Basics/Script">
              <Bind variable="sound">
                <To key="Basics/Sequence/DamageSound"/>
              </Bind>
              <Bind variable="damage">
                <To key="Basics/Sequence/DamageVisual"/>
              </Bind>
              <Bind variable="screen">
                <To key="UI/Layout/Main/Damage"/>
              </Bind>
              <Bind variable="indicator">
                <To key=":Screen">
                  <Asset key="Spindizzy/DamageIndicator/DamageIndicator"/>
                </To>
              </Bind>
              <Bind variable="timeLimit">
                <To key="Basics/Timer/TimeLimit"/>
              </Bind>
              <Code>if alienContactCount == 0 then
  sound:play()
  damage:play()
  screen:setScreen(indicator)
end
alienContactCount = alienContactCount + 1
timeLimit:setSpeed(1.0 + alienContactCount * 20.0)</Code>
            </Action>
          </EnteredAction>
          <ExitedAction>
            <Action key="Basics/Script">
              <Bind variable="sound">
                <To key="Basics/Sequence/DamageSound"/>
              </Bind>
              <Bind variable="damage">
                <To key="Basics/Sequence/DamageVisual"/>
              </Bind>
              <Bind variable="screen">
                <To key="UI/Layout/Main/Damage"/>
              </Bind>
              <Bind variable="timeLimit">
                <To key="Basics/Timer/TimeLimit"/>
              </Bind>
              <Code>alienContactCount = alienContactCount - 1
if alienContactCount == 0 then
  sound:pause()
  damage:pause()
  screen:setScreen(nil)
end
timeLimit:setSpeed(1.0 + alienContactCount * 20.0)</Code>
            </Action>
          </ExitedAction>
        </CollisionHandler>
