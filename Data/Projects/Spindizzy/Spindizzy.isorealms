{
  "project": {
    "description": "Game Mechanics and Assets",
    "include": [
      {
        "filename": {
          "path": "Projects/Spindizzy/Options.isorealms"
        }
      }
    ],
    "screen": {
      "key": "UI/Layout/Main"
    },
    "input": {
      "key": "Basics/InputSwitch/Main"
    },
    "editor": {
      "key": "Spindizzy/World/Game World"
    },
    "initialisation": {
      "key": "Basics/Script",
      "bindings": [
        {
          "variable": "zoneCount",
          "to": {
            "key": "Basics/Integer/RemainingZones"
          }
        },
        {
          "variable": "hangworld",
          "to": {
            "key": "Spindizzy/World/Game World"
          }
        },
        {
          "variable": "optionsLoader",
          "to": {
            "key": ":Action",
            "asset": {
              "key": "Basics/Function/ReloadConfiguration",
              "bindings": []
            }
          }
        }
      ],
      "code": "menuStack = {}\ninputStack = {}\nzoneCount:setValue(hangworld:getZoneCount())\nmapOverviewMode = 0\nspinType = 0\nhasFocus = true\nlocks = 0\nalienContactCount = 0\n\n-- print(\"EXECUTE RELOAD...\")\noptionsLoader:execute()"
    },
    "reset": {
      "key": "Basics/Script",
      "bindings": [
        {
          "variable": "zoneCount",
          "to": {
            "key": "Basics/Integer/RemainingZones"
          }
        },
        {
          "variable": "hangworld",
          "to": {
            "key": "Spindizzy/World/Game World"
          }
        },
        {
          "variable": "player",
          "to": {
            "key": "Spindizzy/World/Game World/Player"
          }
        },
        {
          "variable": "switchIconPrimary",
          "to": {
            "key": "UI/Layout/Layout/SwitchStatePrimary"
          }
        },
        {
          "variable": "switchIconSecondary",
          "to": {
            "key": "UI/Layout/Layout/SwitchStateSecondary"
          }
        },
        {
          "variable": "view",
          "to": {
            "key": "Spindizzy/WorldView/Game View"
          }
        },
        {
          "variable": "spindizzy",
          "to": {
            "key": "Spindizzy"
          }
        },
        {
          "variable": "options",
          "to": {
            "key": "Options"
          }
        },
        {
          "variable": "replayer",
          "to": {
            "key": "Replay/Replayer/Gameplay Recorder"
          }
        }
      ],
      "code": " -- Start recording if specified\nlocal mReplayerMode = options:getOption(\"Replayer\")\nif mReplayerMode == \"Recording\" then\n  local mReplayerFile = options:getOption(\"File\")\n  replayer:setRecording(mReplayerFile)\nelseif mReplayerMode == \"Replaying\" then\n  local mReplayerFile = options:getOption(\"File\")\n  local mReplayerUser = options:getOption(\"User\")\n  replayer:setReplaying(mReplayerFile, mReplayerUser == \"true\")\nelse\n  replayer:setInactive()\nend\n\n-- Reset Lua variables\nmapOverviewMode = 0\nspinType = 0\nhasFocus = true\nlocks = 0\nalienContactCount = 0\nfirstZoneEntered = 0\n\n-- Unpause the game\nspindizzy:setPause(false)\n\n-- Reset zone count\nzoneCount:setValue(hangworld:getZoneCount())\n\n-- Reset switches\nif activeSwitchA ~= nil then\n  nextSwitch = 0\n  activeSwitchA:setValue(false)\n  switchIconPrimary:setScreen(nil)\n  activeSwitchA = nil\n  if activeSwitchB ~= nil then\n    activeSwitchB:setValue(false)\n    switchIconSecondary:setScreen(nil)\n    activeSwitchB = nil\n  end\nend"
    },
    "start": {
      "key": "Basics/Script",
      "bindings": [
        {
          "variable": "application",
          "to": {
            "key": "Application"
          }
        }
      ],
      "code": "application:setName(\"IsoRealms Spindizzy\")"
    },
    "quit": {
      "key": "Quit"
    },
    "launchConfigurations": {
      "Record Demo": {
        "preparationAction": {
          "key": "Basics/Script",
          "bindings": []
        },
        "options": {
          "Replayer": {
            "key": "Literal",
            "value": "Recording"
          },
          "File": {
            "key": "Literal",
            "value": "Demo.recording"
          }
        }
      },
      "Replay Demo": {
        "preparationAction": {
          "key": "Basics/Script",
          "bindings": []
        },
        "options": {
          "Replayer": {
            "key": "Literal",
            "value": "Replaying"
          },
          "File": {
            "key": "Literal",
            "value": "Demo.recording"
          },
          "User": {
            "key": "Literal",
            "value": "true"
          }
        }
      },
      "Test Arcade": {
        "preparationAction": {
          "key": "None"
        },
        "options": {}
      }
    },
