              {
                "id": "Pause",
                "colour": {
                  "key": "Basics/Sequence/Menu Selection Colour/Instance/Colour"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onExit": {
                  "key": "Basics/Function/Unpause",
                  "bindings": []
                },
                "options": [
                  {
                    "item": {
                      "key": "Action",
                      "label": "Resume",
                      "onSelection": {
                        "key": "Basics/Function/Unpause",
                        "bindings": []
                      }
                    }
                  },
                  {
                    "item": {
                      "key": "Action",
                      "label": "Options",
                      "onSelection": {
                        "key": "Basics/Function/PushScreen",
                        "bindings": [
                          {
                            "argument": "menuScreen",
                            "to": {
                              "key": ":Screen",
                              "asset": {
                                "key": "UI/Menu/Options"
                              }
                            }
                          },
                          {
                            "argument": "menu",
                            "to": {
                              "key": "UI/Menu/Options"
                            }
                          },
                          {
                            "argument": "menuInput",
                            "to": {
                              "key": ":InputHandler",
                              "asset": {
                                "key": "UI/Menu/Options"
                              }
                            }
                          }
                        ]
                      }
                    }
                  },
                  {
                    "item": {
                      "key": "Action",
                      "label": "Abort Mission",
                      "onSelection": {
                        "key": "Basics/Function/PushScreen",
                        "bindings": [
                          {
                            "argument": "menuScreen",
                            "to": {
                              "key": ":Screen",
                              "asset": {
                                "key": "UI/Prompt/AbortMission"
                              }
                            }
                          },
                          {
                            "argument": "menu",
                            "to": {
                              "key": "UI/Prompt/AbortMission"
                            }
                          },
                          {
                            "argument": "menuInput",
                            "to": {
                              "key": ":InputHandler",
                              "asset": {
                                "key": "UI/Prompt/AbortMission"
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Prompt",
            "instances": [
              {
                "id": "AbortMission",
                "message": "Abort Mission?",
                "cancelLabel": "No",
                "confirmLabel": "Yes",
                "selectionColour": {
                  "key": "Basics/Sequence/Menu Selection Colour/Instance/Colour"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "gameTimeLimit",
                      "to": {
                        "key": "Basics/Sequence/Time Limit/Instance"
                      }
                    },
                    {
                      "variable": "screen",
                      "to": {
                        "key": "UI/Layout/Main/Menu"
                      }
                    },
                    {
                      "variable": "spindizzy",
                      "to": {
                        "key": "Spindizzy"
                      }
                    },
                    {
                      "variable": "endingMessage",
                      "to": {
                        "key": "Basics/String/EndingMessage"
                      }
                    }
                  ],
                  "code": "-- Setting time to 3 minutes causes mission to end\ngameTimeLimit:setTime(180000)\n\n-- Pop all menu screens\nwhile #menuStack > 0 do\n  table.remove(menuStack)\n  table.remove(inputStack)\nend\n\n-- Set message that player has quit\nendingMessage:setValue(\"Cartographer Quit: Mission Aborted\")\n\n-- Get rid of the prompt\nscreen:setScreen(nil)\n\n-- Unpause the game\nlocks = locks - 1\nif locks == 0 then\n  spindizzy:setPause(false)\n  if GlobalExplorer ~= 1 then\n    gameTimeLimit:play()\n  end\nend\n\n-- Disable menu access\nhasFocus = false"
                },
                "onCancel": {
                  "key": "Basics/Function/PopScreen",
                  "bindings": []
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
