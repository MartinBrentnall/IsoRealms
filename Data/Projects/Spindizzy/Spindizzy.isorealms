                "code": "if alienContactCount == 0 then\n  sound:play()\n  damage:play()\n  screen:setScreen(indicator)\nend\nalienContactCount = alienContactCount + 1\ntimeSpeed:setValue(1.0 + alienContactCount * 20.0)"
              },
              "onParting": {
                "key": "Basics/Script",
                "bindings": [
