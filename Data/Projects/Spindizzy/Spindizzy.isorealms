        </StringScreen>
        <Texture file="Images/Map.png" name="Map"/>
        <Texture file="Images/Score.png" name="Score"/>
        <Texture file="Images/Time.png" name="Time"/>
        <Timer name="MandatoryZoneTime" value="0">
          <ExpirationAction>
            <Action key="Basics/Script">
              <Bind variable="spindizzy">
                <To key="Spindizzy"/>
              </Bind>
              <Bind variable="timeLimit">
                <To key="Basics/Timer/TimeLimit"/>
              </Bind>
              <Bind variable="zoneEnterFunction">
                <To key=":Action">
                  <Action>
                    <Action key="Basics/Function/ZoneEntered"/>
                  </Action>
                </To>
              </Bind>
              <Bind variable="sound">
                <To key="Basics/Sequence/DamageSound"/>
              </Bind>
              <Bind variable="damage">
                <To key="Basics/Sequence/DamageVisual"/>
              </Bind>
              <Code>if zoneToEnter ~= nil then
  spindizzy:setPause(false)
  if GlobalExplorer ~= 1 then
    timeLimit:resume()
  end
  if alienContactCount > 0 then
    sound:play()
    damage:play()
  end
  entered = zoneToEnter
  zoneEnterFunction:execute()
  zoneToEnter = nil
end</Code>
            </Action>
          </ExpirationAction>
        </Timer>
        <Timer name="TimeLimit" value="150000">
          <ExpirationAction>
            <Action key="Basics/Script">
              <Bind variable="spindizzy">
                <To key="Spindizzy"/>
              </Bind>
              <Bind variable="timeLimit">
                <To key="Basics/Timer/TimeLimit"/>
              </Bind>
              <Bind variable="gameOverSequence">
                <To key="Basics/Sequence/GameOver"/>
              </Bind>
              <Bind variable="project">
                <To key="Project"/>
              </Bind>
              <Bind variable="endMessage">
                <To key="Basics/String/EndingMessage"/>
              </Bind>
              <Bind variable="scoreMessage">
                <To key="Basics/String/ScoreMessage"/>
              </Bind>
              <Bind variable="mappedMessage">
                <To key="Basics/String/MappedMessage"/>
              </Bind>
              <Bind variable="jewelsMessage">
                <To key="Basics/String/JewelsMessage"/>
              </Bind>
              <Bind variable="completeMessage">
                <To key="Basics/String/CompleteMessage"/>
              </Bind>
              <Bind variable="score">
                <To key="Basics/Integer/Score"/>
              </Bind>
              <Bind variable="jewelsCollected">
                <To key=":Integer">
                  <Asset key="Basics/Integer/JewelCount"/>
                </To>
              </Bind>
              <Bind variable="zoneCount">
                <To key=":Integer">
                  <Asset key="Basics/Integer/RemainingZones"/>
                </To>
              </Bind>
              <Bind variable="hangworld">
                <To key="Spindizzy/World/Hangworld"/>
              </Bind>
              <Bind variable="sound">
                <To key="Basics/Sequence/DamageSound"/>
              </Bind>
              <Bind variable="damage">
                <To key="Basics/Sequence/DamageVisual"/>
              </Bind>
              <Bind variable="screen">
                <To key="UI/Layout/Main/Damage"/>
              </Bind>
              <Code>-- Stop alien damage; we've probably had enough of that...
sound:pause()
damage:pause()
screen:setScreen(nil)

-- Pause the game
locks = locks + 1
if locks == 1 then
  spindizzy:setPause(true)
  timeLimit:pause()
end

local message = endMessage:getValue()
if string.len(message) == 0 then
  endMessage:setValue("Fuel Depleted: Mission Aborted")
end

-- Calculate some rounded percentages
totalZones = hangworld:getZoneCount()
mappedPercentage = math.ceil((math.abs((zoneCount:getValue() / totalZones) - 1) * 100) - 0.5)
totalJewels = hangworld:getPickUpCount()
jewelsPercentage = math.ceil(((jewelsCollected:getValue() / totalJewels) * 100) - 0.5)
completePercentage = math.ceil(((mappedPercentage + jewelsPercentage) / 2) - 0.5)

-- Set result values
mappedMessage:setValue("" .. mappedPercentage .. "%")
jewelsMessage:setValue("" .. jewelsPercentage .. "%")
completeMessage:setValue("" .. completePercentage .. "%")
if GlobalExplorer ~= 1 then
  scoreMessage:setValue("" .. score:getValue())
else
  -- Prevent high score from triggering
  score:setValue(-1)
  scoreMessage:setValue("N/A")
  GlobalExplorer = nil
end
hasFocus = false
gameOverSequence:play()</Code>
            </Action>
          </ExpirationAction>
        </Timer>
        <Vertex name="ZoneLocation"/>
      </Resources>
