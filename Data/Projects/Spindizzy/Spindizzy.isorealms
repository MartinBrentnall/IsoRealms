                                "key": "Basics/Sequence/Time Limit/Instance"
                              }
                            },
                            {
                              "variable": "zoneEnterFunction",
                              "to": {
                                "key": ":Action",
                                "asset": {
                                  "key": "Basics/Function/Handle Zone Entered",
                                  "bindings": []
                                }
                              }
                            },
                            {
                              "variable": "sound",
                              "to": {
                                "key": "Basics/Sequence/DamageSound/Instance"
                              }
                            },
                            {
                              "variable": "damage",
                              "to": {
                                "key": "Basics/Sequence/DamageVisual/Instance"
                              }
                            }
                          ],
                          "code": "if zoneToEnter ~= nil then\n  spindizzy:setPause(false)\n  if GlobalExplorer ~= 1 then\n    gameTimeLimit:play()\n  end\n  if alienContactCount > 0 then\n    sound:play()\n    damage:play()\n  end\n  entered = zoneToEnter\n  zoneEnterFunction:execute()\n  zoneToEnter = nil\nend"
                        }
                      }
                    ]
                  }
                }
              ],
