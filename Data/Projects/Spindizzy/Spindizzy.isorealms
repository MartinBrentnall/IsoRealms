                        }
                      },
                      {
                        "variable": "damage",
                        "to": {
                          "key": "Basics/Sequence/DamageVisual/Instance"
                        }
                      }
                    ],
                    "code": "locks = locks + 1\nif locks == 1 then\n  spindizzy:setPause(true)\n  gameTimeLimit:pause()\n  background:setScreen(backgroundBlack)\n  world:setScreen(worldOverview)\n  if alienContactCount > 0 then\n    sound:pause()\n    damage:pause()\n  end\nend"
                  },
                  "onStartArrival": {
                    "key": "Basics/Script",
                    "bindings": [
                      {
