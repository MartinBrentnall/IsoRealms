      "Basics": {
        "BooleanTrigger": {
          "instances": {
            "Brake": {
              "value": {
                "key": "Replay/Replayer/Gameplay Recorder/Brake"
              },
              "onBecomingTrue": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "player",
                    "to": {
                      "key": "Spindizzy/World/Game World/Player"
                    }
                  },
                  {
                    "variable": "gameTimeLimit",
                    "to": {
                      "key": "Basics/Sequence/Time Limit/Instance"
                    }
                  }
                ],
                "code": "if hasFocus then\n  player:stop()\n  if GlobalExplorer ~= 1 then\n    local newTime = gameTimeLimit:getTime() + 500\n    gameTimeLimit:setTime(newTime)\n  end\nend"
              },
              "onBecomingFalse": {
                "key": "None"
              }
            },
            "Destruct": {
              "value": {
                "key": "Replay/Replayer/Gameplay Recorder/Destruct"
              },
              "onBecomingTrue": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "player",
                    "to": {
                      "key": "Spindizzy/World/Game World/Player"
                    }
                  },
                  {
                    "variable": "soundImpactHard",
                    "to": {
                      "key": ":Action",
                      "asset": {
                        "key": "Basics/Sound/ImpactHard"
                      }
                    }
                  },
                  {
                    "variable": "topDebris",
                    "to": {
                      "key": "Spindizzy/World/Game World/DebrisGenerator/Top"
                    }
                  },
                  {
                    "variable": "ballDebris",
                    "to": {
                      "key": "Spindizzy/World/Game World/DebrisGenerator/Ball"
                    }
                  },
                  {
                    "variable": "gyroscopeDebris",
                    "to": {
                      "key": "Spindizzy/World/Game World/DebrisGenerator/Gyroscope"
                    }
                  }
                ],
                "code": "if hasFocus and player:isAlive() then\n  location = player:getLocation()\n  momentum = player:getMomentum()\n  xMomentum = momentum:getX()\n  yMomentum = momentum:getY()\n  zMomentum = momentum:getZ()\n  player:destroy()\n  soundImpactHard:execute()\n  if spinType == 0 then\n    for i = 1, 5 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = (zMomentum - 0.1) * math.random()\n      topDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 1 then\n    for i = 1, 8 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = (zMomentum - 0.1) * math.random()\n      ballDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  elseif spinType == 2 then\n    for i = 1, 12 do\n      xMomentumVary = xMomentum + (math.random() - 0.5) * 0.02\n      yMomentumVary = yMomentum + (math.random() - 0.5) * 0.02\n      zMomentumVary = (zMomentum - 0.1) * math.random()\n      gyroscopeDebris:generateDebris(location, xMomentumVary, yMomentumVary, -zMomentumVary, currentZone)\n    end\n  end\nend"
              },
              "onBecomingFalse": {
                "key": "None"
              }
            },
            "Map": {
              "value": {
                "key": "Replay/Replayer/Gameplay Recorder/Map"
              },
              "onBecomingTrue": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "view",
                    "to": {
                      "key": "Spindizzy/WorldView/Game View/Camera"
                    }
                  }
                ],
                "code": "if hasFocus then\n  if mapOverviewMode == 1 then\n    view:transitionToStart()\n    mapOverviewMode = 0\n  else\n    view:transitionToEnd()\n    mapOverviewMode = 1\n  end\nend"
              },
              "onBecomingFalse": {
                "key": "None"
              }
            },
            "Pause": {
              "value": {
                "key": "Replay/Replayer/Gameplay Recorder/Pause"
              },
              "onBecomingTrue": {
                "key": "Basics/Function/Pause Game",
                "bindings": []
              },
              "onBecomingFalse": {
                "key": "None"
              }
            },
            "ResetCamera": {
              "value": {
                "key": "Replay/Replayer/Gameplay Recorder/Reset Camera"
              },
              "onBecomingTrue": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "viewAngle",
                    "to": {
                      "key": "Spindizzy/WorldView/Game View/Camera/Start"
                    }
                  }
                ],
                "code": "viewAngle:faceNorthWest();"
              },
              "onBecomingFalse": {
                "key": "None"
              }
            },
            "ReverseCamera": {
              "value": {
                "key": "Replay/Replayer/Gameplay Recorder/Reverse Camera"
              },
              "onBecomingTrue": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "viewAngle",
                    "to": {
                      "key": "Spindizzy/WorldView/Game View/Camera/Start"
                    }
                  }
                ],
                "code": "viewAngle:flip();"
              },
              "onBecomingFalse": {
                "key": "None"
              }
            },
            "RotateCameraLeft": {
              "value": {
                "key": "Replay/Replayer/Gameplay Recorder/Rotate Camera Left"
              },
              "onBecomingTrue": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "viewAngle",
                    "to": {
                      "key": "Spindizzy/WorldView/Game View/Camera/Start"
                    }
                  }
                ],
                "code": "viewAngle:rotateLeft();"
              },
              "onBecomingFalse": {
                "key": "None"
              }
            },
            "RotateCameraRight": {
              "value": {
                "key": "Replay/Replayer/Gameplay Recorder/Rotate Camera Right"
              },
              "onBecomingTrue": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "viewAngle",
                    "to": {
                      "key": "Spindizzy/WorldView/Game View/Camera/Start"
                    }
                  }
                ],
                "code": "viewAngle:rotateRight();"
              },
              "onBecomingFalse": {
                "key": "None"
              }
            },
            "Transform": {
              "value": {
                "key": "Replay/Replayer/Gameplay Recorder/Transform"
              },
              "onBecomingTrue": {
                "key": "Basics/Script",
                "bindings": [
                  {
                    "variable": "playerCraftModels",
                    "to": {
                      "key": "Spindizzy/ModelCycler/Player Craft"
                    }
                  },
                  {
                    "variable": "alienCraftModels",
                    "to": {
                      "key": "Spindizzy/ModelCycler/Alien Craft"
                    }
                  },
                  {
                    "variable": "player",
                    "to": {
                      "key": "Spindizzy/Player/Player"
                    }
                  },
                  {
                    "variable": "alienTypeA",
                    "to": {
                      "key": "Spindizzy/Alien/Enemy Type A"
                    }
                  },
                  {
                    "variable": "alienTypeB",
                    "to": {
                      "key": "Spindizzy/Alien/Enemy Type B"
                    }
                  }
                ],
                "code": "if hasFocus then\n  playerCraftModels:next()\n  alienCraftModels:next()\n  if spinType == 0 then\n    player:setSpinSpeed(0.0)\n    alienTypeA:setSpinSpeed(-360.0)\n    alienTypeB:setSpinSpeed(-180.0)\n    spinType = 1\n  elseif spinType == 1 then\n    player:setSpinSpeed(-360.0)\n    alienTypeA:setSpinSpeed(-180.0)\n    alienTypeB:setSpinSpeed(0.0)\n    spinType = 2\n  else\n    player:setSpinSpeed(-180.0)\n    alienTypeA:setSpinSpeed(0.0)\n    alienTypeB:setSpinSpeed(-360.0)\n    spinType = 0\n  end\nend"
              },
              "onBecomingFalse": {
                "key": "None"
              }
            }
          },
          "omissions": []
        },
