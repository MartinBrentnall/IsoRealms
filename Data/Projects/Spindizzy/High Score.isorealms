                  "path": "Fonts/Bubblegum_Sans/BubblegumSans-Regular.ttf"
                },
                "scale": 0.699999988079071,
                "offsetY": 0.20000000298023224
              }
            ]
          },
          {
            "type": "Function",
            "instances": [
              {
                "id": "Quit",
                "name": "Quit",
                "bindings": [
                  {
                    "variable": "project",
                    "to": {
                      "key": "Project"
                    }
                  }
                ],
                "arguments": [],
                "code": "project:finish(false)"
              },
              {
                "id": "WriteValues",
                "name": "WriteValues",
                "bindings": [
                  {
                    "variable": "project",
                    "to": {
                      "key": "Project"
                    }
                  },
                  {
                    "variable": "highScore",
                    "to": {
                      "key": "HighScore/ScoreTracker/Project"
                    }
                  }
                ],
                "arguments": [],
                "code": "highScore:writeValues()\nproject:finish(false)"
              }
            ]
          },
          {
            "type": "InputGroup",
            "instances": [
              {
                "id": "Score",
