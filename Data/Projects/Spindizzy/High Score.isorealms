    "properties": [
      {
        "id": "Mode",
        "action": {
          "key": "Basics/Script",
          "bindings": [
            {
              "variable": "value",
              "to": {
                "key": "~",
                "local": "value"
              }
            },
            {
              "variable": "project",
              "to": {
                "key": ":Project",
                "asset": {
                  "key": "HighScore/ScoreTracker/Project/Project"
                }
              }
            }
          ],
          "code": "project:setProperty(\"Mode\", value:getValue())"
        }
      }
    ],
    "modules": [
      {
        "name": "Basics",
        "configuration": {},
