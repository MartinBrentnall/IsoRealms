      {
        "name": "HighScore",
        "configuration": {},
        "resources": [
          {
            "type": "ScoreTracker",
            "instances": [
              {
                "id": "Project",
                "recordLimit": 10,
                "user": {
                  "key": "Basics/Boolean/User"
                },
                "savePath": {
                  "key": ":Project",
                  "project": {
                    "key": "HighScore/ScoreTracker/Project/Project"
                  },
                  "value": {
                    "key": ":Project",
                    "project": {
                      "key": "Replay/Recorder/Recorder/Project"
                    },
                    "value": {
                      "key": "ProjectFilename"
                    }
                  }
                },
                "onHighScoreAchieved": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "layerSwitch",
                      "to": {
                        "key": "UI/Layout/HighScore/Game"
                      }
                    },
                    {
                      "variable": "layerNameEntry",
                      "to": {
                        "key": ":Screen",
                        "asset": {
                          "key": "UI/Layout/NameEntry"
                        }
                      }
                    },
                    {
                      "variable": "nameEntry",
                      "to": {
                        "key": "UI/VirtualKeyboard/NameEntry"
                      }
                    },
                    {
                      "variable": "input",
                      "to": {
                        "key": "Basics/InputSwitch/NameEntry"
                      }
                    },
                    {
                      "variable": "handler",
                      "to": {
                        "key": ":InputHandler",
                        "asset": {
                          "key": "UI/VirtualKeyboard/NameEntry"
                        }
                      }
                    }
                  ],
                  "code": "layerSwitch:setScreen(layerNameEntry)\nnameEntry:reset()\ninput:setInputHandler(handler)"
                },
                "onHighScoreFailed": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "layerSwitch",
                      "to": {
                        "key": "UI/Layout/HighScore/Game"
                      }
                    },
                    {
                      "variable": "layerAnyKey",
                      "to": {
                        "key": ":Screen",
                        "asset": {
                          "key": "UI/Layout/AnyKey"
                        }
                      }
                    },
                    {
                      "variable": "input",
                      "to": {
                        "key": "Basics/InputSwitch/NameEntry"
                      }
                    },
                    {
                      "variable": "handler",
                      "to": {
                        "key": ":InputHandler",
                        "asset": {
                          "key": "Basics/InterruptHandler/NoHighScore"
                        }
                      }
                    }
                  ],
                  "code": "layerSwitch:setScreen(layerAnyKey)\ninput:setInputHandler(handler)"
                },
                "onFinish": {
                  "key": "Basics/Function/Quit",
                  "bindings": []
                },
                "mappings": [
                  {
                    "type": "Integer",
                    "name": "Jewels",
                    "value": {
                      "key": ":Project",
                      "project": {
                        "key": "HighScore/ScoreTracker/Project/Project"
                      },
                      "value": {
                        "key": ":Project",
                        "project": {
                          "key": "Replay/Recorder/Recorder/Project"
                        },
                        "value": {
                          "key": "Basics/Integer/JewelCount"
                        }
                      }
                    }
                  },
                  {
                    "type": "Integer",
                    "name": "Score",
                    "value": {
                      "key": ":Project",
                      "project": {
                        "key": "HighScore/ScoreTracker/Project/Project"
                      },
                      "value": {
                        "key": ":Project",
                        "project": {
                          "key": "Replay/Recorder/Recorder/Project"
                        },
                        "value": {
                          "key": "Basics/Integer/Score"
                        }
                      }
                    },
                    "compare": true
                  },
                  {
                    "type": "Integer",
                    "name": "Zones",
                    "value": {
                      "key": ":Project",
                      "project": {
                        "key": "HighScore/ScoreTracker/Project/Project"
                      },
                      "value": {
                        "key": ":Project",
                        "project": {
                          "key": "Replay/Recorder/Recorder/Project"
                        },
                        "value": {
                          "key": "Basics/Integer/RemainingZones"
                        }
                      }
                    }
                  },
                  {
                    "type": "String",
                    "name": "Name",
                    "value": {
                      "key": "UI/VirtualKeyboard/NameEntry"
                    }
                  },
                  {
                    "type": "String",
                    "name": "Recording",
                    "value": {
                      "key": ":Project",
                      "project": {
                        "key": "HighScore/ScoreTracker/Project/Project"
                      },
                      "value": {
                        "key": ":Project",
                        "project": {
                          "key": "Replay/Recorder/Recorder/Project"
                        },
                        "value": {
                          "key": "ProjectFilename"
                        }
                      }
                    }
                  },
                  {
                    "type": "String",
                    "name": "Time",
                    "value": {
                      "key": ":Project",
                      "project": {
                        "key": "HighScore/ScoreTracker/Project/Project"
                      },
                      "value": {
                        "key": ":Project",
                        "project": {
                          "key": "Replay/Recorder/Recorder/Project"
                        },
                        "value": {
                          "key": "UI/Time",
                          "value": {
                            "key": "Basics/Sequence/Time Limit/Instance/Remaining"
                          },
                          "format": "{m}:{s:02}.{ms:2}"
                        }
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
