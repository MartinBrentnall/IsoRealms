                ],
                "arguments": [],
                "code": "optionMoveCursorForward:setValue(inputMoveCursorForward:getInputsString())\noptionMoveCursorBackward:setValue(inputMoveCursorBackward:getInputsString())\noptionMoveCursorLeft:setValue(inputMoveCursorLeft:getInputsString())\noptionMoveCursorRight:setValue(inputMoveCursorRight:getInputsString())\noptionMoveCursorUp:setValue(inputMoveCursorUp:getInputsString())\noptionMoveCursorDown:setValue(inputMoveCursorDown:getInputsString())\noptionMoveCursorFaster:setValue(inputMoveCursorFaster:getInputsString())\noptionMoveCursorSlower:setValue(inputMoveCursorSlower:getInputsString())\noptionPreviousTool:setValue(inputPreviousTool:getInputsString())\noptionNextTool:setValue(inputNextTool:getInputsString())\noptionUseTool:setValue(inputUseTool:getInputsString())\noptionCancel:setValue(inputCancel:getInputsString())\noptionConfigureTool:setValue(inputConfigureTool:getInputsString())\noptionToolMode:setValue(inputToolMode:getInputsString())\noptionPreviousTheme:setValue(inputPreviousTheme:getInputsString())\noptionNextTheme:setValue(inputNextTheme:getInputsString())\noptionMoveView:setValue(inputMoveView:getInputsString())\noptionRotateView:setValue(inputRotateView:getInputsString())\noptionEditorMenu:setValue(inputEditorMenu:getInputsString())"
              },
              {
                "id": "Pause",
                "name": "Pause",
                "bindings": [
                  {
                    "variable": "mainInput",
                    "to": {
                      "key": "Basics/InputSwitch/Main"
                    }
                  },
                  {
                    "variable": "inputHandlerMenu",
                    "to": {
                      "key": ":InputHandler",
                      "asset": {
                        "key": "Basics/InputSwitch/Options Screen"
                      }
                    }
                  },
                  {
                    "variable": "showMenu",
                    "to": {
                      "key": ":Action",
                      "asset": {
                        "key": "Basics/Function/PushScreen",
                        "bindings": [
                          {
                            "argument": "menuScreen",
                            "to": {
                              "key": ":Screen",
                              "asset": {
                                "key": "UI/Menu/Pause"
                              }
                            }
                          },
                          {
                            "argument": "menu",
                            "to": {
                              "key": "UI/Menu/Pause"
                            }
                          },
                          {
                            "argument": "menuInput",
                            "to": {
                              "key": ":InputHandler",
                              "asset": {
                                "key": "UI/Menu/Pause"
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                ],
                "arguments": [],
                "code": "if hasFocus then\n  hasFocus = false\n  mainInput:setInputHandler(inputHandlerMenu)\n  currentEditor:notifyLostFocus()\n  showMenu:execute()\nend"
              },
              {
                "id": "Unpause",
                "name": "Unpause",
                "bindings": [
                  {
                    "variable": "basics",
                    "to": {
                      "key": "Basics"
                    }
                  },
                  {
                    "variable": "screen",
                    "to": {
                      "key": "UI/Layout/Main/Menu"
                    }
                  },
                  {
                    "variable": "editorInput",
                    "to": {
                      "key": "Basics/InputSwitch/Main"
                    }
                  },
                  {
                    "variable": "inputHandlerEditor",
                    "to": {
                      "key": ":InputHandler",
                      "asset": {
                        "key": "Basics/InputGroup/EditorInput"
                      }
                    }
                  }
                ],
                "arguments": [],
                "code": "hasFocus = true\nwhile #menuStack > 0 do\n  table.remove(menuStack)\n  table.remove(inputStack)\nend\nscreen:setScreen(nil)\n\n-- TODO: What if currentEditor is nil?\neditorInput:setInputHandler(inputHandlerEditor)\ncurrentEditor:notifyGainedFocus()"
              },
              {
                "id": "ShowScreen",
                "name": "ShowScreen",
                "bindings": [],
                "arguments": [
                  {
                    "name": "screenSwitch",
                    "defaultValue": {
                      "key": "Literal"
                    }
                  },
                  {
                    "name": "screen",
                    "defaultValue": {
                      "key": "Literal"
                    }
                  }
                ],
                "code": "screenSwitch:setScreen(screen)"
              },
              {
                "id": "LoadWorld",
                "name": "LoadWorld",
                "bindings": [
                  {
                    "variable": "showPrompt",
                    "to": {
                      "key": ":Action",
                      "asset": {
                        "key": "Basics/Function/PushScreen",
                        "bindings": [
                          {
                            "argument": "menuScreen",
                            "to": {
                              "key": ":Screen",
                              "asset": {
                                "key": "UI/Prompt/Load"
                              }
                            }
                          },
                          {
                            "argument": "menu",
                            "to": {
                              "key": "UI/Prompt/Load"
                            }
                          },
                          {
                            "argument": "menuInput",
                            "to": {
                              "key": ":InputHandler",
                              "asset": {
                                "key": "UI/Prompt/Load"
                              }
                            }
                          }
                        ]
                      }
                    }
                  },
                  {
                    "variable": "missionToLoad",
                    "to": {
                      "key": "Basics/String/MissionToLoad"
                    }
                  },
                  {
                    "variable": "missionType",
                    "to": {
                      "key": "Basics/String/MissionType"
                    }
                  }
                ],
                "arguments": [
                  {
                    "name": "mission",
                    "defaultValue": {
                      "key": "Literal"
                    }
                  },
                  {
                    "name": "user",
                    "defaultValue": {
                      "key": "Literal"
                    }
                  }
                ],
                "code": "missionFileName = mission:getValue()\nmissionToLoad:setValue(missionFileName);\nmissionUser = user:getValue()\nif missionUser then\n  missionType:setValue(\"user\")\nelse\n  missionType:setValue(\"program\")\nend\nshowPrompt:execute()"
              }
            ]
          },
          {
            "type": "InputGroup",
            "instances": [
              {
                "id": "EditorInput",
                "inputs": [
                  {"input": {"key": "Basics/DigitalInput/Cancel"}},
                  {"input": {"key": "Basics/DigitalInput/ConfigureTool"}},
                  {"input": {"key": "Basics/DigitalInput/MoveCursorBackward"}},
                  {"input": {"key": "Basics/DigitalInput/MoveCursorDown"}},
                  {"input": {"key": "Basics/DigitalInput/MoveCursorFaster"}},
                  {"input": {"key": "Basics/DigitalInput/MoveCursorForward"}},
