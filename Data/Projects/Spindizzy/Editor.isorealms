            ]
          },
          {
            "type": "Prompt",
            "instances": [
              {
                "id": "New",
                "message": "Create new map?  Changes won't be saved!",
                "cancelLabel": "Cancel",
                "confirmLabel": "New Map",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "project",
                      "to": {
                        "key": "Basics/Project/Project"
                      }
                    },
                    {
                      "variable": "template",
                      "to": {
                        "key": ":ProjectOptions",
                        "asset": {
                          "key": "Basics/ProjectOptions/Template"
                        }
                      }
                    },
                    {
                      "variable": "popScreen",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/PopScreen",
                          "bindings": []
                        }
                      }
                    },
                    {
                      "variable": "screen",
                      "to": {
                        "key": "UI/Layout/Main/Menu"
                      }
                    },
                    {
                      "variable": "loading",
                      "to": {
                        "key": ":Screen",
                        "asset": {
                          "key": "UI/Throbber/LoadingScreen"
                        }
                      }
                    }
                  ],
                  "code": "project:prepare(template, true)\npopScreen:execute()\npopScreen:execute()\nscreen:setScreen(loading)"
                },
                "onCancel": {
                  "key": "Basics/Function/PopScreen",
                  "bindings": []
                }
              },
              {
                "id": "Close",
                "message": "Close IsoRealms?  Changes won't be saved!",
                "cancelLabel": "Cancel",
                "confirmLabel": "Close",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "quit",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Quit"
                        }
                      }
                    }
                  ],
                  "code": "quit:execute()"
                },
                "onCancel": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "cancel",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/Unpause",
                          "bindings": []
                        }
                      }
                    }
                  ],
                  "code": "awaitingQuit = nil\ncancel:execute()"
                }
              },
              {
                "id": "Quit",
                "message": "Quit Editor?  Changes won't be saved!",
                "cancelLabel": "Cancel",
                "confirmLabel": "Quit",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "project",
                      "to": {
                        "key": "Project"
                      }
                    }
                  ],
                  "code": "project:finish(false)"
                },
                "onCancel": {
                  "key": "Basics/Function/PopScreen",
                  "bindings": []
                }
              },
              {
                "id": "Load",
                "message": "Load world?  Changes to the current world won't be saved!",
                "cancelLabel": "Cancel",
                "confirmLabel": "Load world",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "project",
                      "to": {
                        "key": "Basics/Project/Project"
                      }
                    },
                    {
                      "variable": "loadMissionOptions",
                      "to": {
                        "key": ":ProjectOptions",
                        "asset": {
                          "key": "Basics/ProjectOptions/LoadMission"
                        }
                      }
                    },
                    {
                      "variable": "popScreen",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/PopScreen",
                          "bindings": []
                        }
                      }
                    },
                    {
                      "variable": "screen",
                      "to": {
                        "key": "UI/Layout/Main/Menu"
                      }
                    },
                    {
                      "variable": "loading",
                      "to": {
                        "key": ":Screen",
                        "asset": {
                          "key": "UI/Throbber/LoadingScreen"
                        }
                      }
                    }
                  ],
                  "code": "print(\"Mission to load: \" .. missionFileName)\nproject:prepare(loadMissionOptions, true)\npopScreen:execute()\npopScreen:execute()\nscreen:setScreen(loading)"
                },
                "onCancel": {
                  "key": "Basics/Function/PopScreen",
                  "bindings": []
                }
              },
              {
                "id": "Overwrite",
                "message": "Overwrite existing project?",
                "cancelLabel": "Cancel",
                "confirmLabel": "Overwrite",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "unpause",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/Unpause",
                          "bindings": []
                        }
                      }
                    },
                    {
                      "variable": "project",
                      "to": {
                        "key": "Basics/Project/Project"
                      }
                    },
                    {
                      "variable": "filename",
                      "to": {
                        "key": ":String",
                        "asset": {
                          "key": "UI/VirtualKeyboard/SaveAsPrompt"
                        }
                      }
                    }
                  ],
                  "code": "print('SAVING')\nproject:saveAs(\"Projects/\" .. filename:getValue())\nunpause:execute()"
                },
                "onCancel": {
                  "key": "Basics/Function/PopScreen",
                  "bindings": []
                }
              }
            ]
          },
          {
            "type": "Throbber",
            "instances": [
              {
                "id": "LoadingScreen",
                "colour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                }
              }
            ]
          },
          {
            "type": "VirtualKeyboard",
            "instances": [
              {
                "id": "SaveAsPrompt",
                "selectionColour": {
                  "key": "Basics/ColourCycler/Menu Selection Highlight/0"
                },
                "font": {
                  "key": "Basics/Font/Layout"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "project",
                      "to": {
                        "key": "Basics/Project/Project"
                      }
                    },
                    {
                      "variable": "unpause",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/Unpause",
                          "bindings": []
                        }
                      }
                    },
                    {
                      "variable": "filename",
                      "to": {
                        "key": ":String",
                        "asset": {
                          "key": "UI/VirtualKeyboard/SaveAsPrompt"
                        }
                      }
                    },
                    {
                      "variable": "overwritePrompt",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/PushScreen",
                          "bindings": [
                            {
                              "argument": "menuScreen",
                              "to": {
                                "key": ":Screen",
                                "asset": {
                                  "key": "UI/Prompt/Overwrite"
                                }
                              }
                            },
                            {
                              "argument": "menu",
                              "to": {
                                "key": "UI/Prompt/Overwrite"
                              }
                            },
                            {
                              "argument": "menuInput",
                              "to": {
                                "key": ":InputHandler",
                                "asset": {
                                  "key": "UI/Prompt/Overwrite"
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  ],
                  "code": "if project:exists(\"Projects/\" .. filename:getValue()) then\n  overwritePrompt:execute()\nelse\n  project:saveAs(\"Projects/\" .. filename:getValue())\n  unpause:execute()\nend"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
