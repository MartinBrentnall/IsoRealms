{
  "project": {
    "include": [
      {
        "filename": "Projects/Spindizzy/Options.isorealms"
      }
    ],
    "screen": {
      "key": "UI/Layout/Runtime"
    },
    "input": {
      "key": "Basics/InputSwitch/Main"
    },
    "editor": {
      "key": "Literal"
    },
    "initialisation": {
      "key": "Basics/Script",
      "bindings": [
        {
          "variable": "optionsLoader",
          "to": {
            "key": ":Action",
            "asset": {
              "key": "Basics/Function/ReloadConfiguration",
              "bindings": []
            }
          }
        }
      ],
      "code": "firstRun = 1\nmenuStack = {}\ninputStack = {}\nhasFocus = true\noptionsLoader:execute()"
    },
    "reset": {
      "key": "Basics/Script",
      "bindings": [
        {
          "variable": "project",
          "to": {
            "key": "Basics/Project/Project"
          }
        },
        {
          "variable": "template",
          "to": {
            "key": ":ProjectOptions",
            "asset": {
              "key": "Basics/ProjectOptions/Template"
            }
          }
        },
        {
          "variable": "popScreen",
          "to": {
            "key": ":Action",
            "asset": {
              "key": "Basics/Function/PopScreen",
              "bindings": []
            }
          }
        },
        {
          "variable": "screen",
          "to": {
            "key": "UI/Layout/Main/Menu"
          }
        },
        {
          "variable": "loading",
          "to": {
            "key": ":Screen",
            "asset": {
              "key": "UI/Throbber/LoadingScreen"
            }
          }
        },
        {
          "variable": "reloadEditorControlsFunction",
          "to": {
            "key": ":Action",
            "asset": {
              "key": "Basics/Function/ReloadEditorControls",
              "bindings": []
            }
          }
        }
      ],
      "code": "reloadEditorControlsFunction:execute()\nif firstRun == 1 then\n  firstRun = 0\nelse\n  project:prepare(template, true)\n  popScreen:execute()\n  popScreen:execute()\n  screen:setScreen(loading)\nend"
    },
    "quit": {
      "key": "Basics/Script",
      "bindings": [
        {
          "variable": "confirm",
          "to": {
            "key": ":Action",
            "asset": {
              "key": "Basics/Function/PushScreen",
              "bindings": [
                {
                  "argument": "menuScreen",
                  "to": {
                    "key": ":Screen",
                    "asset": {
                      "key": "UI/Prompt/Close"
                    }
                  }
                },
                {
                  "argument": "menu",
                  "to": {
                    "key": "UI/Prompt/Close"
                  }
                },
                {
                  "argument": "menuInput",
                  "to": {
                    "key": ":InputHandler",
                    "asset": {
                      "key": "UI/Prompt/Close"
                    }
                  }
                }
              ]
            }
          }
        },
        {
          "variable": "unpause",
          "to": {
            "key": ":Action",
            "asset": {
              "key": "Basics/Function/Unpause",
              "bindings": []
            }
          }
        },
        {
          "variable": "project",
          "to": {
            "key": "Basics/Project/Project"
          }
        },
        {
          "variable": "screen",
          "to": {
            "key": "UI/Layout/Runtime/Screen"
          }
        },
        {
          "variable": "input",
          "to": {
            "key": "Basics/InputSwitch/Main"
          }
        },
        {
          "variable": "editorInput",
          "to": {
            "key": ":InputHandler",
            "asset": {
              "key": "Basics/InputGroup/EditorInput"
            }
          }
        },
        {
          "variable": "editorScreen",
          "to": {
            "key": ":Screen",
            "asset": {
              "key": "UI/Layout/Main"
            }
          }
        }
      ],
      "code": "if awaitingQuit == nil then\n  if playTesting ~= nil then\n    currentEditor:notifyVisible()\n    screen:setScreen(editorScreen)\n    input:setInputHandler(editorInput)\n    project:reset()\n    project:setEditing(true)\n    project:setRunning(false)\n    playTesting = nil\n  end\n  unpause:execute()\n  confirm:execute()\n  awaitingQuit = true\nend"
    },
    "modules": [
      {
        "name": "Basics",
        "configuration": {},
        "resources": [
          {
            "type": "AnalogueInput",
            "instances": [


              {"id": "MoveCursorX", "mappings": [{"type": "Axis", "axis": 0, "deadZone": 0.15259000658988953}]},
              {"id": "MoveCursorY", "mappings": [{"type": "Axis", "axis": 1, "deadZone": 0.15259000658988953}]},
              {"id": "RotateViewYaw", "mappings": [{"type": "Axis", "axis": 4, "deadZone": 0.15259000658988953}]},
              {"id": "RotateViewPitch", "mappings": [{"type": "Axis", "axis": 5, "deadZone": 0.15259000658988953}]},
              {"id": "MoveViewIn", "mappings": [{"type": "Axis", "axis": 3, "deadZone": 0.15259000658988953}]},
              {"id": "MoveViewOut", "mappings": [{"type": "Axis", "axis": 2, "deadZone": 0.15259000658988953}]}


            ]
          },
          {
            "type": "BooleanTrigger",
            "instances": [
              {
                "id": "Pause",
                "value": {
                  "key": "Basics/DigitalInput/Pause"
                },
                "onBecomingTrue": {
                  "key": "Basics/Function/Pause",
                  "bindings": []
                },
                "onBecomingFalse": {
                  "key": "Literal"
                }
              },
              {
                "id": "EndTest",
                "value": {
                  "key": "Basics/DigitalInput/EndTest"
                },
                "onBecomingTrue": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "project",
                      "to": {
                        "key": "Basics/Project/Project"
                      }
                    },
                    {
                      "variable": "screen",
                      "to": {
                        "key": "UI/Layout/Runtime/Screen"
                      }
                    },
                    {
                      "variable": "input",
                      "to": {
                        "key": "Basics/InputSwitch/Main"
                      }
                    },
                    {
                      "variable": "editorInput",
                      "to": {
                        "key": ":InputHandler",
                        "asset": {
                          "key": "Basics/InputGroup/EditorInput"
                        }
                      }
                    },
                    {
                      "variable": "editorScreen",
                      "to": {
                        "key": ":Screen",
                        "asset": {
                          "key": "UI/Layout/Main"
                        }
                      }
                    }
                  ],
                  "code": "currentEditor:notifyVisible()\nscreen:setScreen(editorScreen)\ninput:setInputHandler(editorInput)\nproject:reset()\nproject:setEditing(true)\nproject:setRunning(false)\nplayTesting = nil"
                },
                "onBecomingFalse": {
                  "key": "Literal"
                }
              }
            ]
          },
          {
            "type": "DigitalInput",
            "instances": [
              {
                "id": "EndTest",
                "mappings": [
                  {
                    "type": "KeyDown",
                    "key": "C"
                  },
                  {
                    "type": "ButtonDown",
                    "button": 10
                  }
                ]
              },
              {"id": "MoveCursorBackward", "mappings": [{"type": "KeyDown", "key": "ArrowDown"}]},
              {"id": "MoveCursorForward",  "mappings": [{"type": "KeyDown", "key": "ArrowUp"}]},
              {"id": "MoveCursorLeft",     "mappings": [{"type": "KeyDown", "key": "ArrowLeft"}]},
              {"id": "MoveCursorRight",    "mappings": [{"type": "KeyDown", "key": "ArrowRight"}]},
              {"id": "MoveCursorDown",     "mappings": [{"type": "KeyDown", "key": "PageDown"},    {"type": "ButtonDown","button": 4}]},
              {"id": "MoveCursorUp",       "mappings": [{"type": "KeyDown", "key": "PageUp"},      {"type": "ButtonDown","button": 5}]},
              {"id": "MoveCursorFaster",   "mappings": [{"type": "KeyDown", "key": "LeftControl"}]},
              {"id": "MoveCursorSlower",   "mappings": [{"type": "KeyDown", "key": "LeftShift"}]},
              {"id": "PreviousTool",       "mappings": [{"type": "KeyDown", "key": "F1"},          {"type": "Hat","direction": "Left"}]},
              {"id": "NextTool",           "mappings": [{"type": "KeyDown", "key": "F2"},          {"type": "Hat","direction": "Right"}]},
              {"id": "UseTool",            "mappings": [{"type": "KeyDown", "key": "Space"},       {"type": "ButtonDown","button": 0}]},
              {"id": "Cancel",             "mappings": [{"type": "KeyDown", "key": "Escape"},      {"type": "ButtonDown","button": 1}]},
              {"id": "ConfigureTool",      "mappings": [{"type": "KeyDown", "key": "F3"},          {"type": "ButtonDown","button": 2}]},
              {"id": "ToolMode",           "mappings": [{"type": "KeyDown", "key": "Tab"},         {"type": "ButtonDown","button": 3}]},
              {"id": "PreviousTheme",      "mappings": [{"type": "KeyDown", "key": "Home"},        {"type": "Hat","direction": "Down"}]},
              {"id": "NextTheme",          "mappings": [{"type": "KeyDown", "key": "End"},         {"type": "Hat","direction": "Up"}]},
              {"id": "EditorMenu",         "mappings": [{"type": "KeyDown", "key": "Escape"},      {"type": "ButtonDown","button": 9}]},
              {"id": "RotateView",         "mappings": [{"type": "MouseButtonDown", "button": "Left"}]},
              {"id": "MoveView",           "mappings": [{"type": "MouseButtonDown", "button": "Right"}]}
            ]
          },
          {
            "type": "Font",
            "instances": [
              {
                "id": "Layout",
                "filename": "Fonts/BubblegumSans-Regular.ttf"
              },
              {
                "id": "PropertiesFont",
                "filename": "Fonts/ProtestStrike-Regular.ttf"
              }
            ]
          },
