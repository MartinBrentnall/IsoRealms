                  {"input": {"key": "Basics/DigitalInput/NextTool"}},
                  {"input": {"key": "Basics/DigitalInput/PreviousTheme"}},
                  {"input": {"key": "Basics/DigitalInput/PreviousTool"}},
                  {"input": {"key": "Basics/DigitalInput/ToolMode"}},
                  {"input": {"key": "Basics/DigitalInput/UseTool"}},
                  {"input": {"key": "Basics/DigitalInput/MoveView"}},
                  {"input": {"key": "Basics/DigitalInput/RotateView"}},
                  {"input": {"key": "Basics/DigitalInput/EndTest"}},
                  {"input": {"key": "Basics/DigitalInput/EditorMenu"}},

                  {"input": {"key": "Basics/AnalogueInput/MoveCursorX"}},
                  {"input": {"key": "Basics/AnalogueInput/MoveCursorY"}},
                  {"input": {"key": "Basics/AnalogueInput/RotateViewYaw"}},
                  {"input": {"key": "Basics/AnalogueInput/RotateViewPitch"}},
                  {"input": {"key": "Basics/AnalogueInput/MoveViewIn"}},
                  {"input": {"key": "Basics/AnalogueInput/MoveViewOut"}}
                ]
              },
              {
                "id": "Test",
                "inputs": [
                  {
                    "input": {
                      "key": "Basics/DigitalInput/EndTest"
                    }
                  },
                  {
                    "input": {
                      "key": "Basics/Project/Project"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "InputSwitch",
            "instances": [
              {
                "id": "Main",
                "value": {
                  "key": "Basics/InputGroup/EditorInput"
                }
              }
            ]
          },
          {
            "type": "Project",
            "instances": [
              {
                "id": "Project",
                "editing": true,
                "onFinish": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "screen",
                      "to": {
                        "key": "UI/Layout/Runtime/Screen"
                      }
                    },
                    {
                      "variable": "input",
                      "to": {
                        "key": "Basics/InputSwitch/Main"
                      }
                    },
                    {
                      "variable": "editorInput",
                      "to": {
                        "key": ":InputHandler",
                        "asset": {
                          "key": "Basics/InputGroup/EditorInput"
                        }
                      }
                    },
                    {
                      "variable": "editorScreen",
                      "to": {
                        "key": ":Screen",
                        "asset": {
                          "key": "UI/Layout/Main"
                        }
                      }
                    }
                  ],
                  "code": "currentEditor:notifyVisible()\nscreen:setScreen(editorScreen)\ninput:setInputHandler(editorInput)\nplayTesting = nil"
                },
