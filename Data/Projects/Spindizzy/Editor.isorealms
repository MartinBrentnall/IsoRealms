                    {"variable": "digitalInputCancel", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/Cancel"}}},
                    {"variable": "digitalInputConfigureTool", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/ConfigureTool"}}},
                    {"variable": "digitalInputNextTheme", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/NextTheme"}}},
                    {"variable": "digitalInputNextTool", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/NextTool"}}},
                    {"variable": "digitalInputPreviousTheme", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/PreviousTheme"}}},
                    {"variable": "digitalInputPreviousTool", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/PreviousTool"}}},
                    {"variable": "digitalInputToolMode", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/ToolMode"}}},
                    {"variable": "digitalInputUseTool", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/UseTool"}}},

                    {"variable": "digitalInputMoveCursorBackward", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/MoveCursorBackward"}}},
                    {"variable": "digitalInputMoveCursorDown", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/MoveCursorDown"}}},
                    {"variable": "digitalInputMoveCursorFaster", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/MoveCursorFaster"}}},
                    {"variable": "digitalInputMoveCursorForward", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/MoveCursorForward"}}},
                    {"variable": "digitalInputMoveCursorLeft", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/MoveCursorLeft"}}},
                    {"variable": "digitalInputMoveCursorRight", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/MoveCursorRight"}}},
                    {"variable": "digitalInputMoveCursorSlower", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/MoveCursorSlower"}}},
                    {"variable": "digitalInputMoveCursorUp", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/MoveCursorUp"}}},
                    {"variable": "digitalInputMoveView", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/MoveView"}}},
                    {"variable": "digitalInputRotateView", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/RotateView"}}},

                    {"variable": "digitalInputEditorMenu", "to": {"key": ":Boolean", "asset": {"key": "Basics/DigitalInput/EditorMenu"}}},

                    {"variable": "analogueInputMoveCursorX", "to": {"key": ":Float", "asset": {"key": "Basics/AnalogueInput/MoveCursorX"}}},
                    {"variable": "analogueInputMoveCursorY", "to": {"key": ":Float", "asset": {"key": "Basics/AnalogueInput/MoveCursorY"}}},
                    {"variable": "analogueInputMoveViewIn", "to": {"key": ":Float", "asset": {"key": "Basics/AnalogueInput/MoveViewIn"}}},
                    {"variable": "analogueInputMoveViewOut", "to": {"key": ":Float", "asset": {"key": "Basics/AnalogueInput/MoveViewOut"}}},
                    {"variable": "analogueInputRotateViewYaw", "to": {"key": ":Float", "asset": {"key": "Basics/AnalogueInput/RotateViewYaw"}}},
                    {"variable": "analogueInputRotateViewPitch", "to": {"key": ":Float", "asset": {"key": "Basics/AnalogueInput/RotateViewPitch"}}},

                    { "variable": "exitAction",
                      "to": {
                        "key": ":Action",
                        "asset": {
                          "key": "Basics/Function/Pause",
                          "bindings": []
                        }
                      }
                    }
                  ],
                  "code": "print(\"Get Editor...\")\neditable = project:getDefaultEditor()\ncurrentEditor = editable:createEditableScreen(project:getProject())\ncurrentEditor:setAppearance(font, 0.02)\ncurrentEditor:notifyVisible()\neditor:setScreen(currentEditor:screen())\nmainInput:setInputHandler(editorInput)\nscreen:setScreen(noScreen)\nhasFocus = true\n\nprint(\"Set Digital Inputs...\")\ncurrentEditor:setDigitalInput(\"Cancel\",             digitalInputCancel)\ncurrentEditor:setDigitalInput(\"ConfigureTool\",      digitalInputConfigureTool)\ncurrentEditor:setDigitalInput(\"MoveCursorBackward\", digitalInputMoveCursorBackward)\ncurrentEditor:setDigitalInput(\"MoveCursorDown\",     digitalInputMoveCursorDown)\ncurrentEditor:setDigitalInput(\"MoveCursorFaster\",   digitalInputMoveCursorFaster)\ncurrentEditor:setDigitalInput(\"MoveCursorForward\",  digitalInputMoveCursorForward)\ncurrentEditor:setDigitalInput(\"MoveCursorLeft\",     digitalInputMoveCursorLeft)\ncurrentEditor:setDigitalInput(\"MoveCursorRight\",    digitalInputMoveCursorRight)\ncurrentEditor:setDigitalInput(\"MoveCursorSlower\",   digitalInputMoveCursorSlower)\ncurrentEditor:setDigitalInput(\"MoveCursorUp\",       digitalInputMoveCursorUp)\ncurrentEditor:setDigitalInput(\"MoveView\",           digitalInputMoveView)\ncurrentEditor:setDigitalInput(\"NextTheme\",          digitalInputNextTheme)\ncurrentEditor:setDigitalInput(\"NextTool\",           digitalInputNextTool)\ncurrentEditor:setDigitalInput(\"PreviousTheme\",      digitalInputPreviousTheme)\ncurrentEditor:setDigitalInput(\"PreviousTool\",       digitalInputPreviousTool)\ncurrentEditor:setDigitalInput(\"RotateView\",         digitalInputRotateView)\ncurrentEditor:setDigitalInput(\"ToolMode\",           digitalInputToolMode)\ncurrentEditor:setDigitalInput(\"UseTool\",            digitalInputUseTool)\ncurrentEditor:setDigitalInput(\"Exit\",               digitalInputEditorMenu)\n\nprint(\"Set Analogue Inputs...\")\ncurrentEditor:setAnalogueInput(\"MoveCursorX\",     analogueInputMoveCursorX)\ncurrentEditor:setAnalogueInput(\"MoveCursorY\",     analogueInputMoveCursorY)\ncurrentEditor:setAnalogueInput(\"MoveViewIn\",      analogueInputMoveViewIn)\ncurrentEditor:setAnalogueInput(\"MoveViewOut\",     analogueInputMoveViewOut)\ncurrentEditor:setAnalogueInput(\"RotateViewPitch\", analogueInputRotateViewPitch)\ncurrentEditor:setAnalogueInput(\"RotateViewYaw\",   analogueInputRotateViewYaw)\n\nprint(\"Set Exit Action...\")\ncurrentEditor:setExitAction(exitAction)\nprint(\"Done!!!\")"
                },
                "options": {
                  "key": "Literal"
                }
              }
            ]
          },
