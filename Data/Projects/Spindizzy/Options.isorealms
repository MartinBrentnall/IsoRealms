          {
            "type": "Prompt",
            "instances": [
              {
                "id": "VisualTest",
                "message": "Are the screen settings OK?",
                "cancelLabel": "No",
                "confirmLabel": "Yes",
                "selectionColour": {
                  "key": "Basics/Sequence/Menu Selection Colour/Instance/Colour"
                },
                "font": {
                  "key": "Basics/Font/Menu"
                },
                "onConfirm": {
                  "key": "Basics/Script",
                  "bindings": [
                    {
                      "variable": "screenTestTimer",
                      "to": {
                        "key": "Basics/Sequence/Video Mode Test Time/Instance"
                      }
                    },
                    {
                      "variable": "screen",
                      "to": {
                        "key": "UI/Layout/Main/Menu"
                      }
                    },
                    {
                      "variable": "input",
                      "to": {
                        "key": "Basics/InputSwitch/Options Screen"
                      }
                    }
                  ],
                  "code": "screenTestTimer:pause()\ntable.remove(gMenuScreenStack)\ntable.remove(gMenuInputStack)\ninput:setInputHandler(gMenuInputStack[#gMenuInputStack])\nscreen:setScreen(gMenuScreenStack[#gMenuScreenStack])"
                },
                "onCancel": {
                  "key": "Basics/Function/RestorePrevious",
                  "bindings": []
                }
              },
              {
