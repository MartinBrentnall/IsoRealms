                    "to": {
                      "key": "UI/Menu/ConfigureInput"
                    }
                  },
                  {
                    "variable": "menuScreen",
                    "to": {
                      "key": ":Screen",
                      "asset": {
                        "key": "UI/Menu/ConfigureInput"
                      }
                    }
                  },
                  {
                    "variable": "menuInput",
                    "to": {
                      "key": ":InputHandler",
                      "asset": {
                        "key": "UI/Menu/ConfigureInput"
                      }
                    }
                  },
                  {
                    "variable": "inputName",
                    "to": {
                      "key": "Basics/String/InputName"
                    }
                  },
                  {
                    "variable": "inputList",
                    "to": {
                      "key": "UI/Menu/ConfigureInput/DigitalInput/Spindizzy"
                    }
                  }
                ],
                "arguments": [
                  {
                    "name": "name",
                    "type": {
                      "key": "Any"
                    }
                  },
                  {
                    "name": "digitalInput",
                    "type": {
                      "key": "Any"
                    }
                  }
                ],
                "code": "table.insert(gMenuScreenStack, menuScreen)\ntable.insert(gMenuInputStack, menuInput)\nmenu:reset()\ninput:setInputHandler(menuInput)\nscreen:setScreen(menuScreen)\ninputName:setValue(name:getValue())\ncurrentInputList = inputList\ncurrentDigitalInput = digitalInput\ninputList:clear()\nfor i = 0, digitalInput:getMappingCount() - 1 do\n  inputList:addMapping(digitalInput:getMapping(i))\nend"
              },
