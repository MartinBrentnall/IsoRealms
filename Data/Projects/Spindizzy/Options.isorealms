                  {
                    "item": {
                      "key": "Action",
                      "label": "Apply Settings",
                      "onSelection": {
                        "key": "Basics/Script",
                        "bindings": [
                          {
                            "variable": "screen",
                            "to": {
                              "key": "UI/Layout/Main/Menu"
                            }
                          },
                          {
                            "variable": "input",
                            "to": {
                              "key": "Basics/InputSwitch/Options Screen"
                            }
                          },
                          {
                            "variable": "optionResolution",
                            "to": {
                              "key": "UI/Menu/Visual/DisplayResolution/Resolution"
                            }
                          },
                          {
                            "variable": "optionFullScreen",
                            "to": {
                              "key": "UI/Menu/Visual/Boolean/FullScreen"
                            }
                          },
                          {
                            "variable": "promptScreen",
                            "to": {
                              "key": ":Screen",
                              "asset": {
                                "key": "UI/Prompt/VisualTest"
                              }
                            }
                          },
                          {
                            "variable": "promptInput",
                            "to": {
                              "key": ":InputHandler",
                              "asset": {
                                "key": "UI/Prompt/VisualTest"
                              }
                            }
                          },
                          {
                            "variable": "prompt",
                            "to": {
                              "key": "UI/Prompt/VisualTest"
                            }
                          },
                          {
                            "variable": "screenTestTimer",
                            "to": {
                              "key": "Basics/Sequence/Video Mode Test Time/Instance"
                            }
                          }
                        ],
                        "code": "previousMode = application:getDisplayResolution()\npreviousFullScreen = application:isFullScreen()\nmode = optionResolution:getValue()\nfullScreen = optionFullScreen:getValue()\napplication:setDisplayResolution(mode, fullScreen)\nscreen:setScreen(promptScreen)\ninput:setInputHandler(promptInput)\nscreenTestTimer:setTime(0)\nscreenTestTimer:play()\nprompt:reset()"
                      }
                    }
                  }
                ]
              },
