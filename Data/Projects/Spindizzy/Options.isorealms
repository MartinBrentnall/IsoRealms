                      "variable": "isoRealms",
                      "to": {
                        "key": "Basics"
                      }
                    }
                  ],
                  "code": "currentDigitalInput:clearCustomInputs()\nfor i = 0, currentInputList:getMappingCount() - 1 do\n  currentDigitalInput:addCustomInput(currentInputList:getMapping(i))\nend\nisoRealms:persistGlobalConfiguration()\noptionsLoader:execute()\nscreenPopper:execute()"
                },
