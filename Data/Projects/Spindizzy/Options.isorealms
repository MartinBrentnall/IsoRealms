          {
            "type": "Function",
            "instances": [
              {
                "id": "RestorePrevious",
                "name": "RestorePrevious",
                "bindings": [
                  {
                    "variable": "optionResolution",
                    "to": {
                      "key": "UI/Menu/Visual/DisplayResolution/Resolution"
                    }
                  },
                  {
                    "variable": "optionFullScreen",
                    "to": {
                      "key": "UI/Menu/Visual/Boolean/FullScreen"
                    }
                  },
                  {
                    "variable": "screenTestTimer",
                    "to": {
                      "key": "Basics/Sequence/Video Mode Test Time/Instance"
                    }
                  },
                  {
                    "variable": "screen",
                    "to": {
                      "key": "UI/Layout/Main/Menu"
                    }
                  },
                  {
                    "variable": "input",
                    "to": {
                      "key": "Basics/InputSwitch/Options Screen"
                    }
                  }
                ],
                "arguments": [],
                "code": "application:setDisplayResolution(previousMode, previousFullScreen)\noptionResolution:setValue(previousMode)\noptionFullScreen:setValue(previousFullScreen)\ntable.remove(gMenuScreenStack)\ntable.remove(gMenuInputStack)\ninput:setInputHandler(gMenuInputStack[#gMenuInputStack])\nscreen:setScreen(gMenuScreenStack[#gMenuScreenStack])\nscreenTestTimer:pause()"
              },
              {
                "id": "PushScreen",
                "name": "PushScreen",
                "bindings": [
                  {
                    "variable": "screen",
                    "to": {
                      "key": "UI/Layout/Main/Menu"
                    }
                  },
                  {
                    "variable": "input",
                    "to": {
                      "key": "Basics/InputSwitch/Options Screen"
                    }
                  }
                ],
                "arguments": [
                  {
                    "name": "menuScreen",
                    "type": {
                      "key": "Any"
                    }
                  },
                  {
                    "name": "menu",
                    "type": {
                      "key": "Any"
                    }
                  },
                  {
                    "name": "menuInput",
                    "type": {
                      "key": "Any"
                    }
                  }
                ],
                "code": "table.insert(gMenuScreenStack, menuScreen)\ntable.insert(gMenuInputStack, menuInput)\nmenu:reset()\ninput:setInputHandler(menuInput)\nscreen:setScreen(menuScreen)"
              },
              {
                "id": "PopScreen",
                "name": "PopScreen",
                "bindings": [
                  {
                    "variable": "screen",
                    "to": {
                      "key": "UI/Layout/Main/Menu"
                    }
                  },
                  {
                    "variable": "input",
                    "to": {
                      "key": "Basics/InputSwitch/Options Screen"
                    }
                  },
                  {
                    "variable": "inputName",
                    "to": {
                      "key": "Basics/String/InputName"
                    }
                  }
                ],
                "arguments": [],
                "code": "table.remove(gMenuScreenStack)\ntable.remove(gMenuInputStack)\ninput:setInputHandler(gMenuInputStack[#gMenuInputStack])\nscreen:setScreen(gMenuScreenStack[#gMenuScreenStack])\ninputName:setValue(\"\")"
              },
              {
                "id": "ConfigureInput",
                "name": "ConfigureInput",
                "bindings": [
                  {
                    "variable": "screen",
                    "to": {
                      "key": "UI/Layout/Main/Menu"
                    }
                  },
                  {
                    "variable": "input",
                    "to": {
                      "key": "Basics/InputSwitch/Options Screen"
                    }
                  },
                  {
