:"file","value":{"key":"Literal","value":"Projects/Spindizzy/Player.isorealms"}},{"id":"type","value":{"key":"Literal","value":"program"}}]}]},{"type":"Sequence","instances":[{"id":"Splash","tracks":[{"type":"Colour","outputs":"Colour","start":{"key":"Literal","alpha":1},"events":[{"type":"Fade","duration":1500,"target":{"key":"Literal"}},{"type":"Pause","duration":2000},{"type":"Fade","duration":1500,"target":{"key":"Literal","alpha":1}},{"type":"Fade","duration":1500,"target":{"key":"Literal"}}]},{"type":"Action","events":[{"delay":5000,"execute":{"key":"Basics/Function/StartAttract","bindings":[]}}]}]}]},{"type":"String","instances":[{"id":"MessageText3"},{"id":"HighScoreText","value":"Master Cartographers of Hangworld"},{"id":"MissionText","value":"Spindizzy"},{"id":"MessageText2"},{"id":"MessageText1"},{"id":"UserMission","value":"false"},{"id":"Mission","value":"Projects/Spindizzy/Worlds/Hangworld.isorealms"},{"id":"Error","value":"Error"}]},{"type":"StringScreen","instances":[{"id":"AuthorsMessage1","alignment":"Left","value":{"key":"Literal","value":"Hi!  My name is Martin Brentnall, and I have chosen to release IsoRealms Spindizzy in support of Israel in the pursuit of"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"TextMessage3","alignment":"Center","value":{"key":"Basics/String/MessageText3"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"TextTitle","alignment":"Center","value":{"key":"Basics/String/MissionText"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"TextVersion","alignment":"Left","value":{"key":"Literal","value":"Early Access Version 0.6"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"HighScoreTitle","alignment":"Center","value":{"key":"Basics/String/HighScoreText"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"HeaderName","alignment":"Left","value":{"key":"Literal","value":"Name"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"HeaderScore","alignment":"Right","value":{"key":"Literal","value":"Score"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"1Pos","alignment":"Left","value":{"key":"Literal","value":"1"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage2","alignment":"Left","value":{"key":"Literal","value":"peace, and opposition of hate, antisemitism, and misinformation.  You may be asking why a British person with no personal"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage3","alignment":"Left","value":{"key":"Literal","value":"ties to Israel would opt to do this?  Well this is my place to answer that question"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage4","alignment":"Left","value":{"key":"Literal","value":"Since the October 7th atrocities by Hamas, we have been witness to a huge rise in hate, antisemitism, and misinformation"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage5","alignment":"Left","value":{"key":"Literal","value":"across the world.  The initial sympathetic response towards Israel was quickly drowned out by shouts and incidents of hatred"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage6","alignment":"Left","value":{"key":"Literal","value":"and antisemitism, supported by pro-terrorist demonstrations and lies from mainstream media like BBC, Channel 4, Al"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage7","alignment":"Left","value":{"key":"Literal","value":"Jazeera, and many others."},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage8","alignment":"Left","value":{"key":"Literal","value":"Many real events - such as Israel's great efforts to protect the lives of innocent Palestinian civilians in the elimination of"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage9","alignment":"Left","value":{"key":"Literal","value":"terrorist groups - are left unspoken by mainstream media and thus unheard by many people.  Lies and misinformation are"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage10","alignment":"Left","value":{"key":"Literal","value":"passed through social media and amplified by online communities of ignorant terrorist sympathetizers, who see an"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage11","alignment":"Left","value":{"key":"Literal","value":"opportunity to root for an underdog, without regards for reality or the monstrous acts and regressive beliefs of the people"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage12","alignment":"Left","value":{"key":"Literal","value":"they're supporting."},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage13","alignment":"Left","value":{"key":"Literal","value":"It may be easy to dismiss this conflict something that doesn't affect us.  After all, you might believe that you're safe living"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage14","alignment":"Left","value":{"key":"Literal","value":"in Europe, North America, and other countries around the world, but this a naive view.  But Islamic terrorists will not stop"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage15","alignment":"Left","value":{"key":"Literal","value":"with Israel or Jews; their belief holds no tolerance for anyone who doesn't conform to their views."},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage16","alignment":"Left","value":{"key":"Literal","value":"And this is why I feel it's important to raise awareness about this, to make sure our hearts and minds are in the right place,"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage17","alignment":"Left","value":{"key":"Literal","value":"which is why I stand with Israel in opposition of hate, antisemitism, and misinformation.  Please see the links on the"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage18","alignment":"Left","value":{"key":"Literal","value":"following screen for further information."},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"AuthorsMessage19","alignment":"Left","value":{"key":"Literal","value":"Press any key to continue, and THANK YOU for your support!"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Basics/ColourCycler/Menu Selection Highlight/0"}},{"id":"CreditsMessage1","alignment":"Left","value":{"key":"Literal","value":"IsoRealms Spindizzy is created by Martin Brentnall.  IsoRealms Spindizzy is based on the Commodore 64 game"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage2","alignment":"Left","value":{"key":"Literal","value":"Spindizzy, created by Paul Shirley and published by Electric Dreams in 1986."},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage3","alignment":"Left","value":{"key":"Literal","value":"IsoRealms Spindizzy is built on the IsoRealms Engine.  IsoRealms Engine is an application framework and toolset for"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage4","alignment":"Left","value":{"key":"Literal","value":"the development of games and applications.  Both IsoRealms Engine and IsoRealms Spindizzy are distributed for free"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage5","alignment":"Left","value":{"key":"Literal","value":"under the General Public License Version 3."},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage6","alignment":"Left","value":{"key":"Literal","value":"Spindizzy IsoRealms and IsoRealms Engine makes use of the following third-party libraries and API's:"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage7","alignment":"Left","value":{"key":"Literal","value":" - OpenGL"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage8","alignment":"Left","value":{"key":"Literal","value":" - Simple and Fast Multimedia Library"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage9","alignment":"Left","value":{"key":"Literal","value":" - FreeType"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage10","alignment":"Left","value":{"key":"Literal","value":" - RapidJSON"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage11","alignment":"Left","value":{"key":"Literal","value":" - Lua"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage12","alignment":"Left","value":{"key":"Literal","value":" - Sol"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage13","alignment":"Left","value":{"key":"Literal","value":"Please see the included Licences file for further information."},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage14","alignment":"Left","value":{"key":"Literal","value":"I'd like to thank all of my family, friends, and my girlfriend, who have supported me in the creation of IsoRelms Spindizzy"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage15","alignment":"Left","value":{"key":"Literal","value":"and IsoRealms Engine.  Thank you all!"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"CreditsMessage19","alignment":"Left","value":{"key":"Literal","value":"Press any key to continue, and THANK YOU for your support!"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Basics/ColourCycler/Menu Selection Highlight/0"}},{"id":"TextSplash1","alignment":"Center","value":{"key":"Literal","value":"IsoRealms Spindizzy is released in support of peace in Israel,"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"TextSplash2","alignment":"Center","value":{"key":"Literal","value":"and opposition of hate, antisemitism, and misinformation"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"blue":1,"alpha":1}},{"id":"TextSplash3","alignment":"Center","value":{"key":"Literal"},"font":{"key":"Basics/Font/Menu"},"colour":{"key":"Literal","red":1,"green":1,"