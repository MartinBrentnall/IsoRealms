        {
          "variable": "optionsLoader",
          "to": {
            "key": ":Action",
            "asset": {
              "key": "Basics/Function/ReloadConfiguration",
              "bindings": []
            }
          }
        },
        {
          "variable": "scoreTable",
          "to": {
            "key": "HighScore/ScoreTable/HighScores"
          }
        }
      ],
      "code": "menuStack = {}\ninputStack = {}\ngameLoading = false\nscoreTable:reload()\n\n-- settingsFilePath = project:getDataPath() .. \"/settings.json\"\n-- print(\"Reading settings from \" .. settingsFilePath)\n-- uiSettings = project:readNode(settingsFilePath)\n-- if uiSettings ~= nil then\n--   settings = uiSettings:getNode(\"UI\")\n--   currentMission:setValue(settings:getAttribute(\"project\"))\n--   currentMissionUser:setValue(settings:getAttribute(\"user\"))\n--   if currentMissionUser:getValue() == \"true\" then\n--     currentMissionUserBool = true\n--     missionName = string.sub(currentMission:getValue(), string.find(currentMission:getValue(), \"/[^/]*$\"), string.len(currentMission:getValue()) - 10)\n--     currentMissionText:setValue(\"Spindizzy: \" .. missionName)\n--     currentHighScoreText:setValue(\"Master Cartographers of \" .. missionName)\n--   else\n    currentMissionUserBool = false\n    currentMissionText:setValue(\"IsoRealms Spindizzy\")\n    currentHighScoreText:setValue(\"Master Cartographers of Hangworld\")\n--   end\n-- TODO  project:releaseReadNode(uiSettings)\n-- end\n\nmission:prepare(projectArgs, false)\n\ninput:setInputHandler(interruptHandler)\n\nsplash:play()\n\noptionsLoader:execute()\n\nmessages1 = {\"\\\"Peace will come when the Arabs will love their children more than they hate us.\\\"\",\n             \"\\\"We don't thrive on military acts. We do them because we have to,\",\n             \"\\\"When peace comes, we will perhaps in time be able to forgive the Arabs for killing our sons,\",\n             \"\\\"I prefer to stay alive and be criticized than be sympathized.\\\"\",\n             \"\\\"Israel has few true friends. Palestine has a sea of false ones.\\\"\",\n             \"\\\"Innocent Palestinian are not killed by Israel, they are sacrificed by Hamas.\\\"\",\n             \"\\\"Israel will endure and flourish. It is the child of hope and the home of the brave.\\\"\",\n             \"\\\"We do not rejoice in victories. We rejoice when a new kind of\",\n             \"\\\"The truth about Hamas and Islamic Jihad is that they don't prevent Israel\",\n             \"\\\"If the Arabs put down their weapons today, there would be no more violence.\",\n             \"\\\"Israel is the only country in the Middle East where Arabs can be\"}\n\nmessages2 = {\"- Golda Meir, 1957\",\n             \"and thank God we are efficient.\\\"\",\n             \"but it will be harder for us to forgive them for having forced us to kill their sons\",\n             \"- Golda Meir, 1973\",\n             \"- Anonymous, 2024\",\n             \"- Anonymous, 2023\",\n             \"- John F. Kennedy, 1960\",\n             \"cotton is grown and when strawberries bloom in Israel.\\\"\",\n             \"from existing or even flourishing, they prevent Palestine from coming into existence.\\\"\",\n             \"If the Jews put down their weapons today, there would be no more Israel.\\\"\",\n             \"elected to the parliament in a democratic election.\\\"\"}\n\nmessages3 = {\"\",\n             \"- Golda Meir, 1969\",\n             \"- Golda Meir, 1969\",\n             \"\",\n             \"\",\n             \"\",\n             \"\",\n             \"- Golda Meir, 1970\",\n             \"- Michael Medved\",\n             \"- Benjamin Netanyahu\",\n             \"- Adam Michnik\"}\n"
    },
    "quit": {
      "key": "Basics/Script",
      "bindings": [
        {
          "variable": "quit",
          "to": {
            "key": ":Action",
            "asset": {
              "key": "Quit"
            }
          }
        }
      ],
      "code": "if currentMission ~= nil then\n  currentMission:requestQuit()\nelse\n  quit:execute()\nend"
    },
