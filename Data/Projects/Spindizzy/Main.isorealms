                    }
                  }
                ],
                "code": "if gameLoading and currentMission == mission then\n  screen:setScreen(nil)\n  input:setInputHandler(currentMissionInput)\n  project:setScreen(currentMissionScreen)\n  decor:setScreen(nil)\n  currentMission:setRunning(true)\n  demo:setRunning(false)\nend"
              },
              {
                "id": "SelectMission",
                "name": "SelectMission",
                "bindings": [
