                  {
                    "variable": "menuInterrupt",
                    "to": {
                      "key": ":InputHandler",
                      "asset": {
                        "key": "Basics/InterruptHandler/MenuTimeOutHandler"
                      }
                    }
                  }
                ],
                "arguments": [],
                "code": "-- Did the project terminate by a close request?\nif currentMission:isQuitRequestGranted() then\n  quit:execute()\nelse\n\n  -- Return to main menu.\n  table.insert(menuStack, menuScreen)\n  table.insert(inputStack, menuInput)\n  menu:reset()\n  input:setInputHandler(menuInput)\n  screen:setScreen(menuScreen)\n\n  -- Set title decor.\n  decor:setScreen(title)\n\n  -- Deactive mission.\n  currentMission:setRunning(false)\n\n  -- Activate demo.\n  project:setScreen(demoScreen)\n  demo:setRunning(true)\n  demo:reset()\n\n  -- Reload configuration in case it changed during the game.\n  optionsLoader:execute()\n\n  -- Reload the score table in case the player achieved a high score.\n  scoreTable:reload()\n\n  -- Start idle menu timer\n  menuIdleTimer:setTime(0)\n  menuIdleTimer:play()\n\n  -- Enable menu interruption\n  interrupt:setInputHandler(menuInterrupt)\nend"
              },
              {
                "id": "MissionReady",
                "name": "MissionReady",
                "bindings": [
                  {
                    "variable": "decor",
                    "to": {
                      "key": "UI/Layout/Main/Decor"
                    }
                  },
                  {
                    "variable": "screen",
                    "to": {
