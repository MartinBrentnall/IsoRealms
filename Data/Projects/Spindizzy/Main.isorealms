{"project":{"include":[{"filename":"Projects/Spindizzy/Options.isorealms"}],"screen":{"key":"UI/Layout/Main"},"input":{"key":"Basics/InputGroup/Input"},"editor":{"key":"Literal"},"initialisation":{"key":"Basics/Script","bindings":[{"variable":"splash","to":{"key":"Basics/Sequence/Splash"}},{"variable":"mission","to":{"key":"Basics/Project/Mission"}},{"variable":"projectArgs","to":{"key":":ProjectOptions","asset":{"key":"Basics/ProjectOptions/Game"}}},{"variable":"project","to":{"key":"Project"}},{"variable":"currentMission","to":{"key":"Basics/String/Mission"}},{"variable":"currentMissionUser","to":{"key":"Basics/String/UserMission"}},{"variable":"currentMissionUserBool","to":{"key":":Boolean","asset":{"key":"Basics/Boolean/UserMission"}}},{"variable":"currentMissionText","to":{"key":"Basics/String/MissionText"}},{"variable":"currentHighScoreText","to":{"key":"Basics/String/HighScoreText"}},{"variable":"input","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"interruptHandler","to":{"key":":InputHandler","asset":{"key":"Basics/InterruptHandler/AttractInterrupt"}}},{"variable":"optionsLoader","to":{"key":":Action","asset":{"key":"Basics/Function/ReloadConfiguration","bindings":[]}}},{"variable":"scoreTable","to":{"key":"HighScore/ScoreTable/HighScores"}}],"code":"menuStack = {}\ninputStack = {}\ngameLoading = false\nscoreTable:reload()\n\n-- settingsFilePath = project:getDataPath() .. \"/settings.xml\"\n-- print(\"Reading settings from \" .. settingsFilePath)\n-- uiSettings = project:readNode(settingsFilePath)\n-- if uiSettings ~= nil then\n--   settings = uiSettings:getNode(\"UI\")\n--   currentMission:setValue(settings:getAttribute(\"project\"))\n--   currentMissionUser:setValue(settings:getAttribute(\"user\"))\n--   if currentMissionUser:getValue() == \"true\" then\n--     currentMissionUserBool = true\n--     missionName = string.sub(currentMission:getValue(), string.find(currentMission:getValue(), \"/[^/]*$\"), string.len(currentMission:getValue()) - 10)\n--     currentMissionText:setValue(\"Spindizzy: \" .. missionName)\n--     currentHighScoreText:setValue(\"Master Cartographers of \" .. missionName)\n--   else\n    currentMissionUserBool = false\n    currentMissionText:setValue(\"IsoRealms Spindizzy\")\n    currentHighScoreText:setValue(\"Master Cartographers of Hangworld\")\n--   end\n-- TODO  project:releaseReadNode(uiSettings)\n-- end\n\nmission:prepare(projectArgs, false)\n\ninput:setInputHandler(interruptHandler)\n\nsplash:play()\n\noptionsLoader:execute()\n\nmessages1 = {\"\\\"Peace will come when the Arabs will love their children more than they hate us.\\\"\",\n             \"\\\"We don't thrive on military acts. We do them because we have to,\",\n             \"\\\"When peace comes, we will perhaps in time be able to forgive the Arabs for killing our sons,\",\n             \"\\\"I prefer to stay alive and be criticized than be sympathized.\\\"\",\n             \"\\\"Israel has few true friends. Palestine has a sea of false ones.\\\"\",\n             \"\\\"Innocent Palestinian are not killed by Israel, they are sacrificed by Hamas.\\\"\",\n             \"\\\"Israel will endure and flourish. It is the child of hope and the home of the brave.\\\"\",\n             \"\\\"We do not rejoice in victories. We rejoice when a new kind of\",\n             \"\\\"The truth about Hamas and Islamic Jihad is that they don't prevent Israel\",\n             \"\\\"If the Arabs put down their weapons today, there would be no more violence.\",\n             \"\\\"Israel is the only country in the Middle East where Arabs can be\"}\n\nmessages2 = {\"- Golda Meir, 1957\",\n             \"and thank God we are efficient.\\\"\",\n             \"but it will be harder for us to forgive them for having forced us to kill their sons\",\n             \"- Golda Meir, 1973\",\n             \"- Anonymous, 2024\",\n             \"- Anonymous, 2023\",\n             \"- John F. Kennedy, 1960\",\n             \"cotton is grown and when strawberries bloom in Israel.\\\"\",\n             \"from existing or even flourishing, they prevent Palestine from coming into existence.\\\"\",\n             \"If the Jews put down their weapons today, there would be no more Israel.\\\"\",\n             \"elected to the parliament in a democratic election.\\\"\"}\n\nmessages3 = {\"\",\n             \"- Golda Meir, 1969\",\n             \"- Golda Meir, 1969\",\n             \"\",\n             \"\",\n             \"\",\n             \"\",\n             \"- Golda Meir, 1970\",\n             \"- Michael Medved\",\n             \"- Benjamin Netanyahu\",\n             \"- Adam Michnik\"}\n"},"quit":{"key":"Basics/Script","bindings":[{"variable":"quit","to":{"key":":Action","asset":{"key":"Quit"}}}],"code":"if currentMission ~= nil then\n  currentMission:requestQuit()\nelse\n  quit:execute()\nend"},"modules":[{"name":"Basics","configuration":{},"resources":[{"type":"Boolean","instances":[{"id":"UserMission"}]},{"type":"Function","instances":[{"id":"StartAttract","name":"StartAttract","bindings":[{"variable":"decor","to":{"key":"UI/Layout/Main/Decor"}},{"variable":"title","to":{"key":":Screen","asset":{"key":"UI/Layout/Title"}}},{"variable":"project","to":{"key":"UI/Layout/Main/Project"}},{"variable":"demo","to":{"key":":Screen","asset":{"key":"Basics/Project/Demo"}}},{"variable":"demoProject","to":{"key":"Basics/Project/Demo"}},{"variable":"timer","to":{"key":"Basics/Timer/TitleTimer"}}],"arguments":[],"code":"decor:setScreen(title)\nproject:setScreen(demo)\ndemoProject:setRunning(true)\ntimer:start(10000)"},{"id":"UIQuit","name":"UIQuit","bindings":[{"variable":"project","to":{"key":"Project"}},{"variable":"currentMission","to":{"key":":String","asset":{"key":"Basics/String/Mission"}}},{"variable":"currentMissionUser","to":{"key":":String","asset":{"key":"Basics/String/UserMission"}}}],"arguments":[],"code":"uiConfig = project:createNode(\"UI\")\nuiConfig:addAttributeString(\"project\", currentMission:getValue())\nuiConfig:addAttributeString(\"user\", currentMissionUser:getValue())\nsettingsFilePath = project:getUserDataPath() .. \"/settings.xml\"\nuiConfig:save(settingsFilePath)\nproject:finish(false)"},{"id":"GameEnd","name":"GameEnd","bindings":[{"variable":"decor","to":{"key":"UI/Layout/Main/Decor"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"project","to":{"key":"UI/Layout/Main/Project"}},{"variable":"input","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"demo","to":{"key":"Basics/Project/Demo"}},{"variable":"demoScreen","to":{"key":":Screen","asset":{"key":"Basics/Project/Demo"}}},{"variable":"menuScreen","to":{"key":":Screen","asset":{"key":"UI/Menu/Main"}}},{"variable":"menuInput","to":{"key":":InputHandler","asset":{"key":"UI/Menu/Main"}}},{"variable":"menu","to":{"key":"UI/Menu/Main"}},{"variable":"timer","to":{"key":"Basics/Timer/MenuIdleTimer"}},{"variable":"title","to":{"key":":Screen","asset":{"key":"UI/Layout/Title"}}},{"variable":"optionsLoader","to":{"key":":Action","asset":{"key":"Basics/Function/ReloadConfiguration","bindings":[]}}},{"variable":"quit","to":{"key":":Action","asset":{"key":"Quit"}}},{"variable":"scoreTable","to":{"key":"HighScore/ScoreTable/HighScores"}},{"variable":"interrupt","to":{"key":"Basics/InputSwitch/MenuInterrupt"}},{"variable":"menuInterrupt","to":{"key":":InputHandler","asset":{"key":"Basics/InterruptHandler/MenuTimeOutHandler"}}}],"arguments":[],"code":"-- Did the project terminate by a close request?\nif currentMission:isQuitRequestGranted() then\n  quit:execute()\nelse\n\n  -- Return to main menu.\n  table.insert(menuStack, menuScreen)\n  table.insert(inputStack, menuInput)\n  menu:reset()\n  input:setInputHandler(menuInput)\n  screen:setScreen(menuScreen)\n\n  -- Set title decor.\n  decor:setScreen(title)\n\n  -- Deactive mission.\n  currentMission:setRunning(false)\n\n  -- Activate demo.\n  project:setScreen(demoScreen)\n  demo:setRunning(true)\n  demo:reset()\n\n  -- Reload configuration in case it changed during the game.\n  optionsLoader:execute()\n\n  -- Reload the score table in case the player achieved a high score.\n  scoreTable:reload()\n\n  -- Start idle menu timer\n  timer:start(15000)\n\n  -- Enable menu interruption\n  interrupt:setInputHandler(menuInterrupt)\nend"},{"id":"MissionReady","name":"MissionReady","bindings":[{"variable":"decor","to":{"key":"UI/Layout/Main/Decor"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"project","to":{"key":"UI/Layout/Main/Project"}},{"variable":"input","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"demo","to":{"key":"Basics/Project/Demo"}}],"arguments":[{"name":"mission","defaultValue":{"key":"Literal"}}],"code":"if gameLoading and currentMission == mission then\n  screen:setScreen(nil)\n  input:setInputHandler(currentMissionInput)\n  project:setScreen(currentMissionScreen)\n  decor:setScreen(nil)\n  currentMission:setRunning(true)\n  demo:setRunning(false)\nend"},{"id":"SelectMission","name":"SelectMission","bindings":[{"variable":"projectName","to":{"key":":String","asset":{"key":"Literal","value":"Projects/Spindizzy/High Score.isorealms"}}},{"variable":"projectUser","to":{"key":":Boolean","asset":{"key":"Literal"}}},{"variable":"projectArgs","to":{"key":":ProjectOptions","asset":{"key":"Basics/ProjectOptions/Game"}}},{"variable":"currentMission","to":{"key":"Basics/String/Mission"}},{"variable":"currentMissionUser","to":{"key":"Basics/String/UserMission"}},{"variable":"currentMissionUserBool","to":{"key":":Boolean","asset":{"key":"Basics/Boolean/UserMission"}}},{"variable":"currentMissionText","to":{"key":"Basics/String/MissionText"}},{"variable":"currentHighScoreText","to":{"key":"Basics/String/HighScoreText"}},{"variable":"project","to":{"key":"Basics/Project/Mission"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"input","to":{"key":"Basics/InputSwitch/Options Screen"}}],"arguments":[{"name":"mission","defaultValue":{"key":"Literal"}},{"name":"missionUser","defaultValue":{"key":"Literal"}}],"code":"reload = false\nif missionUser:getValue() ~= currentMissionUser:getValue() then\n  reload = true\n  currentMissionUser:setValue(missionUser:getValue())\nend\ntable.remove(menuStack)\ntable.remove(inputStack)\nif currentMissionUser:getValue() == \"user\" then\n  currentMissionUserBool = true\n  missionPath = mission:getValue()\n  missionName = string.sub(missionPath, string.find(missionPath, \"/[^/]*$\") + 1, string.len(missionPath) - 10)\n  currentMissionText:setValue(\"Spindizzy: \" .. missionName)\n  currentHighScoreText:setValue(\"Master Cartographers of \" .. missionName)\n  table.remove(menuStack)\n  table.remove(inputStack)\nelse\n  currentMissionUserBool = false\n  missionPath = \"Projects/\" .. mission:getValue()\n  currentMissionText:setValue(\"IsoRealms Spindizzy\")\n  currentHighScoreText:setValue(\"Master Cartographers of Hangworld\")\nend\nif missionPath ~= currentMission:getValue() then\n  reload = true\n  currentMission:setValue(missionPath)\nend\nif reload then\n  project:prepare(projectArgs, false)\nend\ninput:setInputHandler(inputStack[#inputStack])\nscreen:setScreen(menuStack[#menuStack])"},{"id":"StartHighScore","name":"StartHighScore","bindings":[{"variable":"decor","to":{"key":"UI/Layout/Main/Decor"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"highScores","to":{"key":":Screen","asset":{"key":"UI/Layout/HighScore"}}},{"variable":"input","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"interruptHandler","to":{"key":":InputHandler","asset":{"key":"Basics/InterruptHandler/AttractInterrupt"}}},{"variable":"timer","to":{"key":"Basics/Timer/HighScoreTimer"}}],"arguments":[],"code":"while #menuStack > 0 do\n  table.remove(menuStack)\n  table.remove(inputStack)\nend\nscreen:setScreen(nil)\ndecor:setScreen(highScores)\ninput:setInputHandler(interruptHandler)\ntimer:start(10000)"},{"id":"StartMessage","name":"StartMessage","bindings":[{"variable":"decor","to":{"key":"UI/Layout/Main/Decor"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"message","to":{"key":":Screen","asset":{"key":"UI/Layout/Message"}}},{"variable":"input","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"interruptHandler","to":{"key":":InputHandler","asset":{"key":"Basics/InterruptHandler/AttractInterrupt"}}},{"variable":"timer","to":{"key":"Basics/Timer/MessageTimer"}},{"variable":"messageText1","to":{"key":"Basics/String/MessageText1"}},{"variable":"messageText2","to":{"key":"Basics/String/MessageText2"}},{"variable":"messageText3","to":{"key":"Basics/String/MessageText3"}}],"arguments":[],"code":"while #menuStack > 0 do\n  table.remove(menuStack)\n  table.remove(inputStack)\nend\nscreen:setScreen(nil)\ndecor:setScreen(message)\nselectedMessage = math.random(1,11)\nmessageText1:setValue(messages1[selectedMessage])\nmessageText2:setValue(messages2[selectedMessage])\nmessageText3:setValue(messages3[selectedMessage])\ninput:setInputHandler(interruptHandler)\ntimer:start(10000)"},{"id":"StartAuthorsMessage","name":"StartAuthorsMessage","bindings":[{"variable":"decor","to":{"key":"UI/Layout/Main/Decor"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"authorsMessage","to":{"key":":Screen","asset":{"key":"UI/Layout/AuthorsMessage"}}},{"variable":"input","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"authorsMessageHandler","to":{"key":":InputHandler","asset":{"key":"Basics/InterruptHandler/AuthorsMessageInterrupt"}}},{"variable":"timer","to":{"key":"Basics/Timer/MenuIdleTimer"}}],"arguments":[],"code":"screen:setScreen(nil)\ndecor:setScreen(authorsMessage)\ninput:setInputHandler(authorsMessageHandler)\ntimer:pause()"},{"id":"StartCreditsMessage","name":"StartCreditsMessage","bindings":[{"variable":"decor","to":{"key":"UI/Layout/Main/Decor"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"creditsMessage","to":{"key":":Screen","asset":{"key":"UI/Layout/CreditsMessage"}}},{"variable":"input","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"authorsMessageHandler","to":{"key":":InputHandler","asset":{"key":"Basics/InterruptHandler/AuthorsMessageInterrupt"}}},{"variable":"timer","to":{"key":"Basics/Timer/MenuIdleTimer"}}],"arguments":[],"code":"screen:setScreen(nil)\ndecor:setScreen(creditsMessage)\ninput:setInputHandler(authorsMessageHandler)\ntimer:pause()"},{"id":"StartProject","name":"StartProject","bindings":[{"variable":"decor","to":{"key":"UI/Layout/Main/Decor"}},{"variable":"screen","to":{"key":"UI/Layout/Main/Menu"}},{"variable":"project","to":{"key":"UI/Layout/Main/Project"}},{"variable":"input","to":{"key":"Basics/InputSwitch/Options Screen"}},{"variable":"loading","to":{"key":":Screen","asset":{"key":"UI/Throbber/LoadingScreen"}}},{"variable":"demo","to":{"key":"Basics/Project/Demo"}},{"variable":"timer","to":{"key":"Basics/Timer/MenuIdleTimer"}},{"variable":"interrupt","to":{"key":"Basics/InputSwitch/MenuInterrupt"}}],"arguments":[{"name":"mission","defaultValue":{"key":"Literal"}},{"name":"missionInput","defaultValue":{"key":"Literal"}},{"name":"missionScreen","defaultValue":{"key":"Literal"}},{"name":"mode","defaultValue":{"key":"Literal"}}],"code":"while #menuStack > 0 do\n  table.remove(menuStack)\n  table.remove(inputStack)\nend\nif mission:isReady() then\n  screen:setScreen(nil)\n  input:setInputHandler(missionInput)\n  project:setScreen(missionScreen)\n  decor:setScreen(nil)\n  mission:setRunning(true)\n  mission:setProperty(\"Mode\", mode:getValue())\n  demo:setRunning(false)\nelse\n  gameLoading = true\n  screen:setScreen(loading)\n  input:setInputHandler(nil)\nend\n\n-- Set current mission\ncurrentMission = mission\ncurrentMissionInput = missionInput\ncurrentMissionScreen = missionScreen\n\n-- Stop menu idle timer\ntimer:pause()\n\n-- Prevent menu interrupt from triggering.\ninterrupt:setInputHandler(nil)"},{"id":"StartProjectNew","name":"StartProjectNew","bindings":[{"variable":"dec