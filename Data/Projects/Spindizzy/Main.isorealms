        </StringScreen>
        <Timer name="MenuIdleTimer" value="0">
          <ExpirationAction key="Basics/Script">
            <Bind variable="screen">
              <To key="UI/Layout/Main/Menu"/>
            </Bind>
            <Bind variable="input">
              <To key="Basics/InputSwitch/Options Screen"/>
            </Bind>
            <Bind variable="interruptHandler">
              <To key=":InputHandler">
                <Asset key="Basics/InterruptHandler/AttractInterrupt"/>
              </To>
            </Bind>
            <Bind variable="timer">
              <To key="Basics/Timer/TitleTimer"/>
            </Bind>
            <Code>while #menuStack &gt; 0 do
  table.remove(menuStack)
  table.remove(inputStack)
end
screen:setScreen(nil)
input:setInputHandler(interruptHandler)
timer:start(10000)</Code>
          </ExpirationAction>
        </Timer>
        <Timer name="TitleTimer" value="0">
          <ExpirationAction key="Basics/Function/StartHighScore"/>
        </Timer>
        <Timer name="HighScoreTimer" value="0">
          <ExpirationAction key="Basics/Function/StartMessage"/>
        </Timer>
        <Timer name="MessageTimer" value="0">
          <ExpirationAction key="Basics/Function/StartAttract"/>
        </Timer>
      </Resources>
    </Module>
    <Module name="HighScore">
      <Configuration/>
      <Resources>
        <ScoreTable name="HighScores" records="10">
          <Project key="Basics/String/Mission"/>
          <User key="Basics/Boolean/UserMission"/>
          <Field name="Name"/>
          <Field name="Score"/>
          <Field name="Time"/>
          <Field name="Jewels"/>
          <Field name="Zones"/>
          <Field name="Recording"/>
          <Record>
            <Field field="Name" value="Love Hummus Not Hamas"/>
            <Field field="Score" value="100000"/>
