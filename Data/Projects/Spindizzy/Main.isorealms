        <Sequence name="Splash">
          <Colour output="Colour">
            <Init key="Literal" value="0.0 0.0 0.0 1.0"/>
            <Fade duration="1500">
              <Target key="Literal" value="0.0 0.0 0.0 0.0"/>
            </Fade>
            <Pause duration="2000" />
            <Fade duration="1500">
              <Target key="Literal" value="0.0 0.0 0.0 1.0"/>
            </Fade>
            <Fade duration="1500">
              <Target key="Literal" value="0.0 0.0 0.0 0.0"/>
