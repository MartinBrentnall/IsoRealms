                    }
                  },
                  {
                    "variable": "project",
                    "to": {
                      "key": "Basics/Project/Mission"
                    }
                  },
                  {
                    "variable": "screen",
                    "to": {
                      "key": "UI/Layout/Main/Menu"
                    }
                  },
                  {
                    "variable": "input",
                    "to": {
                      "key": "Basics/InputSwitch/Options Screen"
                    }
                  }
                ],
                "arguments": [
                  {
                    "name": "mission",
                    "type": {
                      "key": "Any"
                    }
                  },
                  {
                    "name": "missionUser",
                    "type": {
                      "key": "Any"
                    }
                  }
                ],
                "code": "reload = false\nif missionUser:getValue() ~= currentMissionUser:getValue() then\n  reload = true\n  currentMissionUser:setValue(missionUser:getValue())\nend\ntable.remove(menuStack)\ntable.remove(inputStack)\nif currentMissionUser:getValue() == \"user\" then\n  currentMissionUserBool = true\n  missionPath = mission:getValue()\n  missionName = string.sub(missionPath, string.find(missionPath, \"/[^/]*$\") + 1, string.len(missionPath) - 10)\n  currentMissionText:setValue(\"Spindizzy: \" .. missionName)\n  currentHighScoreText:setValue(\"Master Cartographers of \" .. missionName)\n  table.remove(menuStack)\n  table.remove(inputStack)\nelse\n  currentMissionUserBool = false\n  missionPath = \"Projects/\" .. mission:getValue()\n  currentMissionText:setValue(\"IsoRealms Spindizzy\")\n  currentHighScoreText:setValue(\"Master Cartographers of Hangworld\")\nend\nif missionPath ~= currentMission:getValue() then\n  reload = true\n  currentMission:setValue(missionPath)\nend\nif reload then\n  project:prepare(projectArgs, false)\nend\ninput:setInputHandler(inputStack[#inputStack])\nscreen:setScreen(menuStack[#menuStack])"
              },
