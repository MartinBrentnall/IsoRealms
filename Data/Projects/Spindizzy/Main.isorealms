        <String name="Mission" value="Projects/Spindizzy/Worlds/Hangworld.isorealms"/>
        <String name="UserMission" value="false"/>
        <String name="MissionText" value="Spindizzy"/>
        <String name="HighScoreText" value="Master Cartographers of Hangworld"/>
        <String name="MessageText1" value=""/>
        <String name="MessageText2" value=""/>
        <String name="MessageText3" value=""/>
        <String name="Error" value="Error"/>
        <StringScreen name="AuthorsMessage1" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="Hi!  My name is Martin Brentnall, and I have chosen to release IsoRealms Spindizzy in support of Israel in the pursuit of"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage2" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="peace, and opposition of hate, antisemitism, and misinformation.  You may be asking why a British person with no personal"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage3" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="ties to Israel would opt to do this?  Well this is my place to answer that question"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage4" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="Since the October 7th atrocities by Hamas, we have been witness to a huge rise in hate, antisemitism, and misinformation"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage5" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="across the world.  The initial sympathetic response towards Israel was quickly drowned out by shouts and incidents of hatred"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage6" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="and antisemitism, supported by pro-terrorist demonstrations and lies from mainstream media like BBC, Channel 4, Al"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage7" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="Jazeera, and many others."/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage8" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="Many real events - such as Israel's great efforts to protect the lives of innocent Palestinian civilians in the elimination of"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage9" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="terrorist groups - are left unspoken by mainstream media and thus unheard by many people.  Lies and misinformation are"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage10" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="passed through social media and amplified by online communities of ignorant terrorist sympathetizers, who see an"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage11" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="opportunity to root for an underdog, without regards for reality or the monstrous acts and regressive beliefs of the people"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage12" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="they're supporting."/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage13" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="It may be easy to dismiss this conflict something that doesn't affect us.  After all, you might believe that you're safe living"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage14" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="in Europe, North America, and other countries around the world, but this a naive view.  But Islamic terrorists will not stop"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage15" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="with Israel or Jews; their belief holds no tolerance for anyone who doesn't conform to their views."/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage16" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="And this is why I feel it's important to raise awareness about this, to make sure our hearts and minds are in the right place,"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage17" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="which is why I stand with Israel in opposition of hate, antisemitism, and misinformation.  Please see the links on the"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage18" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="following screen for further information."/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="AuthorsMessage19" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="Press any key to continue, and THANK YOU for your support!"/>
          <Colour key="Basics/ColourCycler/Menu Selection Highlight/0"/>
        </StringScreen>




















        <StringScreen name="CreditsMessage1" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="IsoRealms Spindizzy is created by Martin Brentnall.  IsoRealms Spindizzy is based on the Commodore 64 game"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage2" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="Spindizzy, created by Paul Shirley and published by Electric Dreams in 1986."/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage3" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="IsoRealms Spindizzy is built on the IsoRealms Engine.  IsoRealms Engine is an application framework and toolset for"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage4" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="the development of games and applications.  Both IsoRealms Engine and IsoRealms Spindizzy are distributed for free"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage5" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="under the General Public License Version 3."/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage6" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="Spindizzy IsoRealms and IsoRealms Engine makes use of the following third-party libraries and API's:"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage7" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value=" - OpenGL"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage8" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value=" - Simple and Fast Multimedia Library"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage9" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value=" - FreeType"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage10" alignment="Left">
          <Font key="Basics/Font/Menu"/>
