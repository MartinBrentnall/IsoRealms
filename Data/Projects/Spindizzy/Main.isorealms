                "code": "settingsDocument = project:createDocument()\nsettingsObject = settingsDocument:addObject(\"Settings\")\nsettingsObject:addString(\"project\", currentMission:getValue(), \"\")\nsettingsObject:addString(\"user\", currentMissionUser:getValue(), \"\")\nsettingsFilePath = project:getUserDataPath() .. \"/settings.json\"\nsettingsDocument:save(settingsFilePath)\nproject:finish(false)\n"
              },
              {
