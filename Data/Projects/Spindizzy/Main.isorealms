          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage12" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value=" - Sol"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage13" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="Please see the included Licences file for further information."/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage14" alignment="Left">
          <Font key="Basics/Font/Menu"/>
          <Value key="Literal" value="I'd like to thank all of my family, friends, and my girlfriend, who have supported me in the creation of IsoRelms Spindizzy"/>
          <Colour key="Literal" value="1.0 1.0 1.0 1.0"/>
        </StringScreen>
        <StringScreen name="CreditsMessage15" alignment="Left">
          <Font key="Basics/Font/Menu"/>
