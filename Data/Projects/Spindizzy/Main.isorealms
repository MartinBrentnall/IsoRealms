                  },
                  {
                    "name": "mode",
                    "type": {
                      "key": "Any"
                    }
                  }
                ],
                "code": "while #menuStack > 0 do\n  table.remove(menuStack)\n  table.remove(inputStack)\nend\nif mission:isReady() then\n  screen:setScreen(nil)\n  input:setInputHandler(missionInput)\n  project:setScreen(missionScreen)\n  decor:setScreen(nil)\n  mission:setRunning(true)\n  mission:setProperty(\"Mode\", mode:getValue())\n  demo:setRunning(false)\nelse\n  gameLoading = true\n  screen:setScreen(loading)\n  input:setInputHandler(nil)\nend\n\n-- Set current mission\ncurrentMission = mission\ncurrentMissionInput = missionInput\ncurrentMissionScreen = missionScreen\n\n-- Stop menu idle timer\nmenuIdleTimer:pause()\n\n-- Prevent menu interrupt from triggering.\ninterrupt:setInputHandler(nil)"
              },
              {
                "id": "StartProjectNew",
                "name": "StartProjectNew",
                "bindings": [
                  {
                    "variable": "decor",
                    "to": {
