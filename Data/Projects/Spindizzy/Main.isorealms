<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Project>
  <Screen key="UI/Layout/Main"/>
  <Input key="Basics/InputGroup/Input"/>
  <Editor key="Literal"/>
  <InitAction key="Basics/Script">
    <Bind variable="splash">
      <To key="Basics/Sequence/Splash"/>
    </Bind>
    <Bind variable="mission">
      <To key="Basics/Project/Mission"/>
    </Bind>
    <Bind variable="projectArgs">
      <To key=":ProjectOptions">
        <Asset key="Basics/ProjectOptions/Game"/>
      </To>
    </Bind>
    <Bind variable="project">
      <To key="Project"/>
    </Bind>
    <Bind variable="currentMission">
      <To key="Basics/String/Mission"/>
    </Bind>
    <Bind variable="currentMissionUser">
      <To key="Basics/String/UserMission"/>
    </Bind>
    <Bind variable="currentMissionUserBool">
      <To key=":Boolean">
        <Asset key="Basics/Boolean/UserMission"/>
      </To>
    </Bind>
    <Bind variable="currentMissionText">
      <To key="Basics/String/MissionText"/>
    </Bind>
    <Bind variable="currentHighScoreText">
      <To key="Basics/String/HighScoreText"/>
    </Bind>
    <Bind variable="input">
      <To key="Basics/InputSwitch/Options Screen"/>
    </Bind>
    <Bind variable="interruptHandler">
      <To key=":InputHandler">
        <Asset key="Basics/InterruptHandler/AttractInterrupt"/>
      </To>
    </Bind>
    <Bind variable="optionsLoader">
      <To key=":Action">
        <Action key="Basics/Function/ReloadConfiguration"/>
      </To>
    </Bind>
    <Bind variable="scoreTable">
      <To key="HighScore/ScoreTable/HighScores"/>
    </Bind>
    <Code>menuStack = {}
inputStack = {}
gameLoading = false
scoreTable:reload()

-- settingsFilePath = project:getDataPath() .. "/settings.xml"
-- print("Reading settings from " .. settingsFilePath)
-- uiSettings = project:readNode(settingsFilePath)
-- if uiSettings ~= nil then
--   settings = uiSettings:getNode("UI")
--   currentMission:setValue(settings:getAttribute("project"))
--   currentMissionUser:setValue(settings:getAttribute("user"))
--   if currentMissionUser:getValue() == "true" then
--     currentMissionUserBool = true
--     missionName = string.sub(currentMission:getValue(), string.find(currentMission:getValue(), "/[^/]*$"), string.len(currentMission:getValue()) - 10)
--     currentMissionText:setValue("Spindizzy: " .. missionName)
--     currentHighScoreText:setValue("Master Cartographers of " .. missionName)
--   else
    currentMissionUserBool = false
    currentMissionText:setValue("IsoRealms Spindizzy")
    currentHighScoreText:setValue("Master Cartographers of Hangworld")
--   end
-- TODO  project:releaseReadNode(uiSettings)
-- end

mission:prepare(projectArgs, false)

input:setInputHandler(interruptHandler)

splash:play()

optionsLoader:execute()

messages1 = {"\"Peace will come when the Arabs will love their children more than they hate us.\"",
             "\"We don't thrive on military acts. We do them because we have to,",
             "\"When peace comes, we will perhaps in time be able to forgive the Arabs for killing our sons,",
             "\"I prefer to stay alive and be criticized than be sympathized.\"",
             "\"Israel has few true friends. Palestine has a sea of false ones.\"",
             "\"Innocent Palestinian are not killed by Israel, they are sacrificed by Hamas.\"",
             "\"Israel will endure and flourish. It is the child of hope and the home of the brave.\"",
             "\"We do not rejoice in victories. We rejoice when a new kind of",
             "\"The truth about Hamas and Islamic Jihad is that they don't prevent Israel",
             "\"If the Arabs put down their weapons today, there would be no more violence.",
             "\"Israel is the only country in the Middle East where Arabs can be"}

messages2 = {"- Golda Meir, 1957",
             "and thank God we are efficient.\"",
             "but it will be harder for us to forgive them for having forced us to kill their sons",
             "- Golda Meir, 1973",
             "- Anonymous, 2024",
             "- Anonymous, 2023",
             "- John F. Kennedy, 1960",
             "cotton is grown and when strawberries bloom in Israel.\"",
             "from existing or even flourishing, they prevent Palestine from coming into existence.\"",
             "If the Jews put down their weapons today, there would be no more Israel.\"",
             "elected to the parliament in a democratic election.\""}

messages3 = {"",
             "- Golda Meir, 1969",
             "- Golda Meir, 1969",
             "",
             "",
             "",
             "",
             "- Golda Meir, 1970",
             "- Michael Medved",
             "- Benjamin Netanyahu",
             "- Adam Michnik"}
</Code>
  </InitAction>
  <QuitAction key="Basics/Script">
    <Bind variable="quit">
      <To key=":Action">
        <Action key="Quit"/>
      </To>
    </Bind>
    <Code>if currentMission ~= nil then
  currentMission:requestQuit()
else
  quit:execute()
end</Code>
  </QuitAction>
  <Include>
    <Project name="Projects/Spindizzy/Options.isorealms" user="false"/>
  </Include>
  <Modules>
    <Module name="Basics">
      <Configuration/>
      <Resources>
        <Boolean name="UserMission" value="false"/>
        <InputGroup name="Input">
          <Element>
            <InputHandler key="Basics/InputSwitch/MenuInterrupt"/>
          </Element>
          <Element>
            <InputHandler key="Basics/InputSwitch/Options Screen"/>
          </Element>
        </InputGroup>
        <InputSwitch name="MenuInterrupt">
          <Init key="Basics/InterruptHandler/MenuTimeOutHandler"/>
        </InputSwitch>
        <InterruptHandler name="AuthorsMessageInterrupt">
          <Action key="Basics/Script">
            <Bind variable="popScreenFunc">
              <To key=":Action">
                <Action key="Basics/Function/PopScreen"/>
              </To>
            </Bind>
            <Bind variable="decor">
              <To key="UI/Layout/Main/Decor"/>
            </Bind>
            <Bind variable="title">
              <To key=":Screen">
                <Asset key="UI/Layout/Title"/>
              </To>
            </Bind>
            <Code>popScreenFunc:execute()
decor:setScreen(title)</Code>
          </Action>
        </InterruptHandler>
        <InterruptHandler name="AttractInterrupt">
          <Action key="Basics/Script">
            <Bind variable="decor">
              <To key="UI/Layout/Main/Decor"/>
            </Bind>
            <Bind variable="title">
              <To key=":Screen">
                <Asset key="UI/Layout/Title"/>
              </To>
            </Bind>
            <Bind variable="screen">
              <To key="UI/Layout/Main/Menu"/>
            </Bind>
            <Bind variable="menu">
              <To key="UI/Menu/Main"/>
            </Bind>
            <Bind variable="menuScreen">
              <To key=":Screen">
                <Asset key="UI/Menu/Main"/>
              </To>
            </Bind>
            <Bind variable="input">
              <To key="Basics/InputSwitch/Options Screen"/>
            </Bind>
            <Bind variable="menuInput">
              <To key=":InputHandler">
                <Asset key="UI/Menu/Main"/>
              </To>
            </Bind>
            <Bind variable="splash">
              <To key="Basics/Sequence/Splash"/>
            </Bind>
            <Bind variable="titleTimer">
              <To key="Basics/Timer/TitleTimer"/>
            </Bind>
            <Bind variable="highScoreTimer">
              <To key="Basics/Timer/HighScoreTimer"/>
            </Bind>
            <Bind variable="messageTimer">
              <To key="Basics/Timer/MessageTimer"/>
            </Bind>
            <Code>table.insert(menuStack, menuScreen)
table.insert(inputStack, menuInput)
input:setInputHandler(menuInput)
screen:setScreen(menuScreen)
decor:setScreen(title)
menu:reset()
splash:skip(7500)
titleTimer:pause()
highScoreTimer:pause()
messageTimer:pause()</Code>
          </Action>
        </InterruptHandler>
        <InterruptHandler name="MenuTimeOutHandler" consume="false">
          <Action key="Basics/Script">
            <Bind variable="timer">
              <To key="Basics/Timer/MenuIdleTimer"/>
            </Bind>
            <Code>timer:start(15000)</Code>
          </Action>
        </InterruptHandler>
        <ProjectOptions name="Demo">
          <Option id="file">
            <Value key="Literal" value="Projects/Spindizzy/Player.isorealms"/>
          </Option>
          <Option id="type">
            <Value key="Literal" value="program"/>
          </Option>
          <Option id="Replay/Player/Player/Recording">
            <Value key="Literal" value="Recordings/Demo.recording"/>
          </Option>
          <Option id="Replay/Player/Player/User">
            <Value key="Literal" value="false"/>
          </Option>
        </ProjectOptions>
        <ProjectOptions name="Replay">
          <Option id="file">
            <Value key="Literal" value="Projects/Spindizzy/Player.isorealms"/>
          </Option>
          <Option id="type">
            <Value key="Literal" value="program"/>
          </Option>
          <Option id="Replay/Player/Player/Recording">
            <Value key="UI/Menu/Replay/List"/>
          </Option>
          <Option id="Replay/Player/Player/User">
            <Value key="Literal" value="true"/>
          </Option>
        </ProjectOptions>
        <ProjectOptions name="Game">
          <Option id="file">
            <Value key="Literal" value="Projects/Spindizzy/High Score.isorealms"/>
          </Option>
          <Option id="type">
            <Value key="Literal" value="program"/>
          </Option>
          <Option id="HighScore/ScoreTracker/Project/Project/file">
            <Value key="Literal" value="Projects/Spindizzy/Recorder.isorealms"/>
          </Option>
          <Option id="HighScore/ScoreTracker/Project/Project/Replay/Recorder/Recorder/Project/file">
            <Value key="Basics/String/Mission"/>
          </Option>
          <Option id="HighScore/ScoreTracker/Project/Project/Replay/Recorder/Recorder/Project/type">
            <Value key="Basics/String/UserMission"/>
          </Option>
          <Option id="HighScore/ScoreTracker/Project/Project/Replay/Recorder/Recorder/InputConfiguration">
            <Value key="Literal" value="Spindizzy.config"/>
          </Option>
        </ProjectOptions>
        <ProjectOptions name="Editor">
          <Option id="file">
            <Value key="Literal" value="Projects/Spindizzy/Editor.isorealms"/>
          </Option>
          <Option id="type">
            <Value key="Literal" value="program"/>
          </Option>
          <Option id="Basics/Project/Project/file">
            <Value key="Literal" value="Projects/Spindizzy/Worlds/Template.isorealms"/>
          </Option>
          <Option id="Basics/Project/Project/type">
            <Value key="Literal" value="program"/>
          </Option>
        </ProjectOptions>
        <Function name="UIQuit">
          <Bind variable="project">
            <To key="Project"/>
          </Bind>
          <Bind variable="currentMission">
            <To key=":String">
              <Asset key="Basics/String/Mission"/>
            </To>
          </Bind>
          <Bind variable="currentMissionUser">
            <To key=":String">
              <Asset key="Basics/String/UserMission"/>
            </To>
          </Bind>
          <Code>uiConfig = project:createNode("UI")
uiConfig:addAttributeString("project", currentMission:getValue())
uiConfig:addAttributeString("user", currentMissionUser:getValue())
settingsFilePath = project:getUserDataPath() .. "/settings.xml"
uiConfig:save(settingsFilePath)
project:finish(false)</Code>
        </Function>
        <Function name="GameEnd">
          <Bind variable="decor">
            <To key="UI/Layout/Main/Decor"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="project">
            <To key="UI/Layout/Main/Project"/>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="demo">
            <To key="Basics/Project/Demo"/>
          </Bind>
          <Bind variable="demoScreen">
            <To key=":Screen">
              <Asset key="Basics/Project/Demo"/>
            </To>
          </Bind>
          <Bind variable="menuScreen">
            <To key=":Screen">
              <Asset key="UI/Menu/Main"/>
            </To>
          </Bind>
          <Bind variable="menuInput">
            <To key=":InputHandler">
              <Asset key="UI/Menu/Main"/>
            </To>
          </Bind>
          <Bind variable="menu">
            <To key="UI/Menu/Main"/>
          </Bind>
          <Bind variable="timer">
            <To key="Basics/Timer/MenuIdleTimer"/>
          </Bind>
          <Bind variable="title">
            <To key=":Screen">
              <Asset key="UI/Layout/Title"/>
            </To>
          </Bind>
          <Bind variable="optionsLoader">
            <To key=":Action">
              <Action key="Basics/Function/ReloadConfiguration"/>
            </To>
          </Bind>
          <Bind variable="quit">
            <To key=":Action">
              <Action key="Quit"/>
            </To>
          </Bind>
          <Bind variable="scoreTable">
            <To key="HighScore/ScoreTable/HighScores"/>
          </Bind>
          <Bind variable="interrupt">
            <To key="Basics/InputSwitch/MenuInterrupt"/>
          </Bind>
          <Bind variable="menuInterrupt">
            <To key=":InputHandler">
              <Asset key="Basics/InterruptHandler/MenuTimeOutHandler"/>
            </To>
          </Bind>
          <Code>-- Did the project terminate by a close request?
if currentMission:isQuitRequestGranted() then
  quit:execute()
else

  -- Return to main menu.
  table.insert(menuStack, menuScreen)
  table.insert(inputStack, menuInput)
  menu:reset()
  input:setInputHandler(menuInput)
  screen:setScreen(menuScreen)

  -- Set title decor.
  decor:setScreen(title)

  -- Deactive mission.
  currentMission:setRunning(false)

  -- Activate demo.
  project:setScreen(demoScreen)
  demo:setRunning(true)
  demo:reset()

  -- Reload configuration in case it changed during the game.
  optionsLoader:execute()

  -- Reload the score table in case the player achieved a high score.
  scoreTable:reload()

  -- Start idle menu timer
  timer:start(15000)

  -- Enable menu interruption
  interrupt:setInputHandler(menuInterrupt)
end</Code>
        </Function>
        <Function name="StartAttract">
          <Bind variable="decor">
            <To key="UI/Layout/Main/Decor"/>
          </Bind>
          <Bind variable="title">
            <To key=":Screen">
              <Asset key="UI/Layout/Title"/>
            </To>
          </Bind>
          <Bind variable="project">
            <To key="UI/Layout/Main/Project"/>
          </Bind>
          <Bind variable="demo">
            <To key=":Screen">
              <Asset key="Basics/Project/Demo"/>
            </To>
          </Bind>
          <Bind variable="demoProject">
            <To key="Basics/Project/Demo"/>
          </Bind>
          <Bind variable="timer">
            <To key="Basics/Timer/TitleTimer"/>
          </Bind>
          <Code>decor:setScreen(title)
project:setScreen(demo)
demoProject:setRunning(true)
timer:start(10000)</Code>
        </Function>
        <Function name="MissionReady">
          <Bind variable="decor">
            <To key="UI/Layout/Main/Decor"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="project">
            <To key="UI/Layout/Main/Project"/>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="demo">
            <To key="Basics/Project/Demo"/>
          </Bind>
          <Argument name="mission"/>
          <Code>if gameLoading and currentMission == mission then
  screen:setScreen(nil)
  input:setInputHandler(currentMissionInput)
  project:setScreen(currentMissionScreen)
  decor:setScreen(nil)
  currentMission:setRunning(true)
  demo:setRunning(false)
end</Code>
        </Function>
        <Function name="SelectMission">
          <Bind variable="projectName">
            <To key=":String">
              <Asset key="Literal" value="Projects/Spindizzy/High Score.isorealms"/>
            </To>
          </Bind>
          <Bind variable="projectUser">
            <To key=":Boolean">
              <Asset key="Literal" value="false"/>
            </To>
          </Bind>
          <Bind variable="projectArgs">
            <To key=":ProjectOptions">
              <Asset key="Basics/ProjectOptions/Game"/>
            </To>
          </Bind>
          <Bind variable="currentMission">
            <To key="Basics/String/Mission"/>
          </Bind>
          <Bind variable="currentMissionUser">
            <To key="Basics/String/UserMission"/>
          </Bind>
          <Bind variable="currentMissionUserBool">
            <To key=":Boolean">
              <Asset key="Basics/Boolean/UserMission"/>
            </To>
          </Bind>
          <Bind variable="currentMissionText">
            <To key="Basics/String/MissionText"/>
          </Bind>
          <Bind variable="currentHighScoreText">
            <To key="Basics/String/HighScoreText"/>
          </Bind>
          <Bind variable="project">
            <To key="Basics/Project/Mission"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Argument name="mission"/>
          <Argument name="missionUser"/>
          <Code>reload = false
if missionUser:getValue() ~= currentMissionUser:getValue() then
  reload = true
  currentMissionUser:setValue(missionUser:getValue())
end
table.remove(menuStack)
table.remove(inputStack)
if currentMissionUser:getValue() == "user" then
  currentMissionUserBool = true
  missionPath = mission:getValue()
  missionName = string.sub(missionPath, string.find(missionPath, "/[^/]*$") + 1, string.len(missionPath) - 10)
  currentMissionText:setValue("Spindizzy: " .. missionName)
  currentHighScoreText:setValue("Master Cartographers of " .. missionName)
  table.remove(menuStack)
  table.remove(inputStack)
else
  currentMissionUserBool = false
  missionPath = "Projects/" .. mission:getValue()
  currentMissionText:setValue("IsoRealms Spindizzy")
  currentHighScoreText:setValue("Master Cartographers of Hangworld")
end
if missionPath ~= currentMission:getValue() then
  reload = true
  currentMission:setValue(missionPath)
end
if reload then
  project:prepare(projectArgs, false)
end
input:setInputHandler(inputStack[#inputStack])
screen:setScreen(menuStack[#menuStack])</Code>
        </Function>
        <Function name="StartHighScore">
          <Bind variable="decor">
            <To key="UI/Layout/Main/Decor"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="highScores">
            <To key=":Screen">
              <Asset key="UI/Layout/HighScore"/>
            </To>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="interruptHandler">
            <To key=":InputHandler">
              <Asset key="Basics/InterruptHandler/AttractInterrupt"/>
            </To>
          </Bind>
          <Bind variable="timer">
            <To key="Basics/Timer/HighScoreTimer"/>
          </Bind>
          <Code>while #menuStack &gt; 0 do
  table.remove(menuStack)
  table.remove(inputStack)
end
screen:setScreen(nil)
decor:setScreen(highScores)
input:setInputHandler(interruptHandler)
timer:start(10000)</Code>
        </Function>
        <Function name="StartMessage">
          <Bind variable="decor">
            <To key="UI/Layout/Main/Decor"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="message">
            <To key=":Screen">
              <Asset key="UI/Layout/Message"/>
            </To>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="interruptHandler">
            <To key=":InputHandler">
              <Asset key="Basics/InterruptHandler/AttractInterrupt"/>
            </To>
          </Bind>
          <Bind variable="timer">
            <To key="Basics/Timer/MessageTimer"/>
          </Bind>
          <Bind variable="messageText1">
            <To key="Basics/String/MessageText1"/>
          </Bind>
          <Bind variable="messageText2">
            <To key="Basics/String/MessageText2"/>
          </Bind>
          <Bind variable="messageText3">
            <To key="Basics/String/MessageText3"/>
          </Bind>
          <Code>while #menuStack &gt; 0 do
  table.remove(menuStack)
  table.remove(inputStack)
end
screen:setScreen(nil)
decor:setScreen(message)
selectedMessage = math.random(1,11)
messageText1:setValue(messages1[selectedMessage])
messageText2:setValue(messages2[selectedMessage])
messageText3:setValue(messages3[selectedMessage])
input:setInputHandler(interruptHandler)
timer:start(10000)</Code>
        </Function>
        <Function name="StartAuthorsMessage">
          <Bind variable="decor">
            <To key="UI/Layout/Main/Decor"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="authorsMessage">
            <To key=":Screen">
              <Asset key="UI/Layout/AuthorsMessage"/>
            </To>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="authorsMessageHandler">
            <To key=":InputHandler">
              <Asset key="Basics/InterruptHandler/AuthorsMessageInterrupt"/>
            </To>
          </Bind>
          <Bind variable="timer">
            <To key="Basics/Timer/MenuIdleTimer"/>
          </Bind>
          <Code>screen:setScreen(nil)
decor:setScreen(authorsMessage)
input:setInputHandler(authorsMessageHandler)
timer:pause()</Code>
        </Function>
        <Function name="StartCreditsMessage">
          <Bind variable="decor">
            <To key="UI/Layout/Main/Decor"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="creditsMessage">
            <To key=":Screen">
              <Asset key="UI/Layout/CreditsMessage"/>
            </To>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="authorsMessageHandler">
            <To key=":InputHandler">
              <Asset key="Basics/InterruptHandler/AuthorsMessageInterrupt"/>
            </To>
          </Bind>
          <Bind variable="timer">
            <To key="Basics/Timer/MenuIdleTimer"/>
          </Bind>
          <Code>screen:setScreen(nil)
decor:setScreen(creditsMessage)
input:setInputHandler(authorsMessageHandler)
timer:pause()</Code>
        </Function>
        <Function name="StartProject">
          <Bind variable="decor">
            <To key="UI/Layout/Main/Decor"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="project">
            <To key="UI/Layout/Main/Project"/>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="loading">
            <To key=":Screen">
              <Asset key="UI/Throbber/LoadingScreen"/>
            </To>
          </Bind>
          <Bind variable="demo">
            <To key="Basics/Project/Demo"/>
          </Bind>
          <Bind variable="timer">
            <To key="Basics/Timer/MenuIdleTimer"/>
          </Bind>
          <Bind variable="interrupt">
            <To key="Basics/InputSwitch/MenuInterrupt"/>
          </Bind>
          <Argument name="mission"/>
          <Argument name="missionInput"/>
          <Argument name="missionScreen"/>
          <Argument name="mode"/>
          <Code>while #menuStack &gt; 0 do
  table.remove(menuStack)
  table.remove(inputStack)
end
if mission:isReady() then
  screen:setScreen(nil)
  input:setInputHandler(missionInput)
  project:setScreen(missionScreen)
  decor:setScreen(nil)
  mission:setRunning(true)
  mission:setProperty("Mode", mode:getValue())
  demo:setRunning(false)
else
  gameLoading = true
  screen:setScreen(loading)
  input:setInputHandler(nil)
end

-- Set current mission
currentMission = mission
currentMissionInput = missionInput
currentMissionScreen = missionScreen

-- Stop menu idle timer
timer:pause()

-- Prevent menu interrupt from triggering.
interrupt:setInputHandler(nil)</Code>
        </Function>
        <Function name="StartProjectNew">
          <Bind variable="decor">
            <To key="UI/Layout/Main/Decor"/>
          </Bind>
          <Bind variable="screen">
            <To key="UI/Layout/Main/Menu"/>
          </Bind>
          <Bind variable="project">
            <To key="UI/Layout/Main/Project"/>
          </Bind>
          <Bind variable="input">
            <To key="Basics/InputSwitch/Options Screen"/>
          </Bind>
          <Bind variable="loading">
            <To key=":Screen">
              <Asset key="UI/Throbber/LoadingScreen"/>
            </To>
          </Bind>
          <Bind variable="demo">
            <To key="Basics/Project/Demo"/>
          </Bind>
          <Bind variable="timer">
            <To key="Basics/Timer/MenuIdleTimer"/>
          </Bind>
          <Bind variable="interrupt">
            <To key="Basics/InputSwitch/MenuInterrupt"/>
          </Bind>
          <Argument name="projectArgs"/>
          <Argument name="mission"/>
          <Argument name="missionInput"/>
          <Argument name="missionScreen"/>
          <Code>while #menuStack &gt; 0 do
  table.remove(menuStack)
  table.remove(inputStack)
end

mission:prepare(projectArgs, false)

if mission:isReady() then
  screen:setScreen(nil)
  input:setInputHandler(missionInput)
  project:setScreen(missionScreen)
  decor:setScreen(nil)
  mission:setRunning(true)
  demo:setRunning(false)
else
  gameLoading = true
  screen:setScreen(loading)
  input:setInputHandler(nil)
end

-- Set current mission
currentMission = mission
currentMissionInput = missionInput
currentMissionScreen = missionScreen

-- Stop menu idle timer
timer:pause()

-- Prevent menu interrupt from triggering.
interrupt:setInputHandler(nil)</Code>
        </Function>
