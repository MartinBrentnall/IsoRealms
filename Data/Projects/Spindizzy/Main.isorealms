        <Layout name="Main">
          <Component name="Project"/>
          <Component name="Decor">
            <Screen key="UI/Layout/Splash"/>
          </Component>
          <Component name="Input">
            <Screen key="UI/Layout/ConfigureInput"/>
          </Component>
          <Component name="Fader">
            <Screen key="UI/Panel/SplashFader"/>
          </Component>
          <Component name="Menu">
            <Left>
              <Location type="Absolute" value="-0.75"/>
            </Left>
            <Right>
              <Location type="Absolute" value="0.75"/>
            </Right>
          </Component>
        </Layout>
        <Panel name="SplashFader">
          <Colour key="Basics/Sequence/Splash/Colour"/>
        </Panel>
        <Panel name="AuthorsMessagePanel" cornerSize="0.1">
          <Colour key="Literal" value="0.0 0.0 0.0 0.75"/>
        </Panel>
        <Menu name="Main">
          <Colour key="Basics/ColourCycler/Menu Selection Highlight/0"/>
          <Font key="Basics/Font/Menu"/>
          <Options>
            <Action label="Play">
              <Action key="Basics/Function/PushScreen">
                <Bind argument="menuScreen">
                  <To key=":Screen">
                    <Asset key="UI/Menu/PlayMode"/>
                  </To>
                </Bind>
                <Bind argument="menuInput">
                  <To key=":InputHandler">
                    <Asset key="UI/Menu/PlayMode"/>
                  </To>
                </Bind>
                <Bind argument="menu">
                  <To key="UI/Menu/PlayMode"/>
                </Bind>
              </Action>
            </Action>
            <Action label="Missions">
              <Action key="Basics/Function/PushScreen">
                <Bind argument="menuScreen">
                  <To key=":Screen">
                    <Asset key="UI/Menu/MissionSelect"/>
                  </To>
                </Bind>
                <Bind argument="menuInput">
                  <To key=":InputHandler">
                    <Asset key="UI/Menu/MissionSelect"/>
                  </To>
                </Bind>
                <Bind argument="menu">
                  <To key="UI/Menu/MissionSelect"/>
                </Bind>
              </Action>
            </Action>
            <Action label="Create">
              <Action key="Basics/Function/StartProjectNew">
                <Bind argument="mission">
                  <To key="Basics/Project/Editor"/>
                </Bind>
                <Bind argument="missionInput">
                  <To key=":InputHandler">
                    <Asset key="Basics/Project/Editor"/>
                  </To>
                </Bind>
                <Bind argument="missionScreen">
                  <To key=":Screen">
                    <Asset key="Basics/Project/Editor"/>
                  </To>
                </Bind>
                <Bind argument="projectArgs">
                  <To key=":ProjectOptions">
                    <Asset key="Basics/ProjectOptions/Editor"/>
                  </To>
                </Bind>
              </Action>
            </Action>
            <Action label="Options">
              <Action key="Basics/Function/PushScreen">
                <Bind argument="menuScreen">
                  <To key=":Screen">
                    <Asset key="UI/Menu/Options"/>
                  </To>
                </Bind>
                <Bind argument="menuInput">
                  <To key=":InputHandler">
                    <Asset key="UI/Menu/Options"/>
                  </To>
                </Bind>
                <Bind argument="menu">
                  <To key="UI/Menu/Options"/>
                </Bind>
              </Action>
            </Action>
            <Action label="High Scores">
              <Action key="Basics/Function/StartHighScore"/>
            </Action>
            <Action label="A Word From The Author">
              <Action key="Basics/Script">
                <Bind variable="pushLinksMenuFunc">
                  <To key=":Action">
                    <Action key="Basics/Function/PushScreen">
                      <Bind argument="menuScreen">
                        <To key=":Screen">
                          <Asset key="UI/Menu/Links"/>
                        </To>
                      </Bind>
                      <Bind argument="menuInput">
                        <To key=":InputHandler">
                          <Asset key="UI/Menu/Links"/>
                        </To>
                      </Bind>
                      <Bind argument="menu">
                        <To key="UI/Menu/Links"/>
                      </Bind>
                    </Action>
                  </To>
                </Bind>
                <Bind variable="startAuthorMessageFunc"> 
                  <To key=":Action">
                    <Action key="Basics/Function/StartAuthorsMessage"/>
                  </To>
                </Bind>
                <Code>pushLinksMenuFunc:execute()
pushLinksMenuFunc:execute()
startAuthorMessageFunc:execute()</Code>
              </Action>
            </Action>
            <Action label="About">
              <Action key="Basics/Script">
                <Bind variable="pushLinksMenuFunc">
                  <To key=":Action">
                    <Action key="Basics/Function/PushScreen">
                      <Bind argument="menuScreen">
                        <To key=":Screen">
                          <Asset key="UI/Menu/Links"/>
                        </To>
                      </Bind>
                      <Bind argument="menuInput">
                        <To key=":InputHandler">
                          <Asset key="UI/Menu/Links"/>
                        </To>
                      </Bind>
                      <Bind argument="menu">
                        <To key="UI/Menu/Links"/>
                      </Bind>
                    </Action>
                  </To>
                </Bind>
                <Bind variable="startCreditsFunc">
                  <To key=":Action">
                    <Action key="Basics/Function/StartCreditsMessage"/>
                  </To>
                </Bind>
                <Code>-- TODO: This is weird... it's just pushed on to be popped off to make the main menu appear when leaving the credits
pushLinksMenuFunc:execute()
startCreditsFunc:execute()</Code>
              </Action>
            </Action>
            <Action label="Quit">
              <Action key="Basics/Function/PushScreen">
                <Bind argument="menuScreen">
                  <To key=":Screen">
                    <Asset key="UI/Prompt/ConfirmQuit"/>
                  </To>
                </Bind>
                <Bind argument="menuInput">
                  <To key=":InputHandler">
                    <Asset key="UI/Prompt/ConfirmQuit"/>
                  </To>
                </Bind>
                <Bind argument="menu">
                  <To key="UI/Prompt/ConfirmQuit"/>
                </Bind>
              </Action>
            </Action>
          </Options>
        </Menu>
        <Menu name="PlayMode">
          <Colour key="Basics/ColourCycler/Menu Selection Highlight/0"/>
          <Font key="Basics/Font/Menu"/>
          <Options>
            <Action label="Play Arcade Mode">
              <Action key="Basics/Function/StartProject">
                <Bind argument="mission">
                  <To key="Basics/Project/Mission"/>
                </Bind>
                <Bind argument="missionInput">
                  <To key=":InputHandler">
                    <Asset key="Basics/Project/Mission"/>
                  </To>
                </Bind>
                <Bind argument="missionScreen">
                  <To key=":Screen">
                    <Asset key="Basics/Project/Mission"/>
                  </To>
                </Bind>
                <Bind argument="mode">
                  <To key=":String">
                    <Asset key="Literal" value="Arcade"/>
                  </To>
                </Bind>
              </Action>
            </Action>
            <Action label="Play Explorer Mode">
              <Action key="Basics/Function/StartProject">
                <Bind argument="mission">
                  <To key="Basics/Project/Mission"/>
                </Bind>
                <Bind argument="missionInput">
                  <To key=":InputHandler">
                    <Asset key="Basics/Project/Mission"/>
                  </To>
                </Bind>
                <Bind argument="missionScreen">
                  <To key=":Screen">
                    <Asset key="Basics/Project/Mission"/>
                  </To>
                </Bind>
                <Bind argument="mode">
                  <To key=":String">
                    <Asset key="Literal" value="Explorer"/>
                  </To>
                </Bind>
              </Action>
            </Action>
          </Options>
          <Exit key="Basics/Function/PopScreen"/>
        </Menu>
        <Menu name="Links">
          <Colour key="Basics/ColourCycler/Menu Selection Highlight/0"/>
          <Font key="Basics/Font/Menu"/>
          <Options>
            <Action label="Go to IDF YouTube Channel">
              <Action key="Basics/Script">
                <Bind variable="project">
                  <To key="Project"/>
                </Bind>
                <Code>project:executeCommand("start https://www.youtube.com/@IsraelDefenseForces")</Code>
              </Action>
            </Action>
            <Action label="Go to Travelling Israel">
              <Action key="Basics/Script">
                <Bind variable="project">
                  <To key="Project"/>
                </Bind>
                <Code>project:executeCommand("start https://www.travelingisrael.com/")</Code>
              </Action>
            </Action>
            <Action label="Go to Jewish Breaking News">
              <Action key="Basics/Script">
                <Bind variable="project">
                  <To key="Project"/>
                </Bind>
                <Code>project:executeCommand("start https://chat.whatsapp.com/IYpx98S6Q5GD05vAeW3OgG")</Code>
              </Action>
            </Action>
            <Action label="Go to WorldNews Subreddit">
              <Action key="Basics/Script">
                <Bind variable="project">
                  <To key="Project"/>
                </Bind>
                <Code>project:executeCommand("start https://www.reddit.com/r/worldnews/")</Code>
              </Action>
            </Action>
          </Options>
          <Exit key="Basics/Function/PopScreen"/>
        </Menu>
        <Menu name="MissionSelect">
          <Colour key="Basics/ColourCycler/Menu Selection Highlight/0"/>
          <Font key="Basics/Font/Menu"/>
          <Options>
            <Action label="Hangworld">
              <Action key="Basics/Function/SelectMission">
                <Bind argument="mission">
                  <To key=":String">
                    <Asset key="Literal" value="Spindizzy/Worlds/Hangworld.isorealms"/>
                  </To>
                </Bind>
                <Bind argument="missionUser">
                  <To key=":String">
                    <Asset key="Literal" value="program"/>
                  </To>
                </Bind>
              </Action>
            </Action>
            <Action label="My Missions">
              <Action key="Basics/Function/PushScreen">
                <Bind argument="menuScreen">
                  <To key=":Screen">
                    <Asset key="UI/Menu/MyMissions"/>
                  </To>
                </Bind>
                <Bind argument="menuInput">
                  <To key=":InputHandler">
                    <Asset key="UI/Menu/MyMissions"/>
                  </To>
                </Bind>
                <Bind argument="menu">
                  <To key="UI/Menu/MyMissions"/>
                </Bind>
              </Action>
            </Action>
          </Options>
          <Exit key="Basics/Function/PopScreen"/>
        </Menu>
        <Menu name="MyMissions">
          <Colour key="Basics/ColourCycler/Menu Selection Highlight/0"/>
          <Font key="Basics/Font/Menu"/>
          <Options>
            <FileList id="List" folder="Projects" user="true">
              <Action key="Basics/Function/SelectMission">
                <Bind argument="mission">
                  <To key=":String">
                    <Asset key="UI/Menu/MyMissions/List"/>
                  </To>
                </Bind>
                <Bind argument="missionUser">
                  <To key=":String">
                    <Asset key="Literal" value="user"/>
                  </To>
                </Bind>
              </Action>
            </FileList>
          </Options>
          <Exit key="Basics/Function/PopScreen"/>
        </Menu>
        <Menu name="Replay">
          <Colour key="Basics/ColourCycler/Menu Selection Highlight/0"/>
          <Font key="Basics/Font/Menu"/>
          <Options>
            <FileList id="List" folder="Recordings" user="true">
              <Action key="Basics/Function/StartProjectNew">
                <Bind argument="mission">
                  <To key="Basics/Project/Replay"/>
                </Bind>
                <Bind argument="missionInput">
                  <To key=":InputHandler">
                    <Asset key="Basics/Project/Replay"/>
                  </To>
                </Bind>
                <Bind argument="missionScreen">
                  <To key=":Screen">
                    <Asset key="Basics/Project/Replay"/>
                  </To>
                </Bind>
                <Bind argument="projectArgs">
                  <To key=":ProjectOptions">
                    <Asset key="Basics/ProjectOptions/Replay"/>
                  </To>
                </Bind>
              </Action>
            </FileList>
          </Options>
          <Exit key="Basics/Function/PopScreen"/>
        </Menu>
        <Prompt name="ConfirmQuit" text="Quit Spindizzy?" false="No" true="Yes">
          <Highlight key="Basics/ColourCycler/Menu Selection Highlight/0"/>
          <Font key="Basics/Font/Menu"/>
          <False key="Basics/Function/PopScreen"/>
          <True key="Basics/Function/UIQuit"/>
        </Prompt>
        <Throbber name="LoadingScreen" duration="2000" repetitions="1" spots="8" spotSides="32" spotRadius="0.06" ringRadius="0.2">
          <Colour key="Basics/ColourCycler/Menu Selection Highlight/0"/>
        </Throbber>
      </Resources>
    </Module>
  </Modules>
</Project>
