                      "key": "UI/Layout/Main/Project"
                    }
                  },
                  {
                    "variable": "input",
                    "to": {
                      "key": "Basics/InputSwitch/Options Screen"
                    }
                  },
                  {
                    "variable": "loading",
                    "to": {
                      "key": ":Screen",
                      "asset": {
                        "key": "UI/Throbber/LoadingScreen"
                      }
                    }
                  },
                  {
                    "variable": "demo",
                    "to": {
                      "key": "Basics/Project/Demo"
                    }
                  },
                  {
                    "variable": "menuIdleTimer",
                    "to": {
                      "key": "Basics/Sequence/Menu Idle Timer/Instance"
                    }
                  },
                  {
                    "variable": "interrupt",
                    "to": {
                      "key": "Basics/InputSwitch/MenuInterrupt"
                    }
                  }
                ],
                "arguments": [
                  {
                    "name": "projectArgs",
                    "type": {
                      "key": "Any"
                    }
                  },
                  {
                    "name": "mission",
                    "type": {
                      "key": "Any"
                    }
                  },
                  {
                    "name": "missionInput",
                    "type": {
                      "key": "Any"
                    }
                  },
                  {
                    "name": "missionScreen",
                    "type": {
                      "key": "Any"
                    }
                  }
                ],
                "code": "while #menuStack > 0 do\n  table.remove(menuStack)\n  table.remove(inputStack)\nend\n\nmission:prepare(projectArgs, false)\n\nif mission:isReady() then\n  screen:setScreen(nil)\n  input:setInputHandler(missionInput)\n  project:setScreen(missionScreen)\n  decor:setScreen(nil)\n  mission:setRunning(true)\n  demo:setRunning(false)\nelse\n  gameLoading = true\n  screen:setScreen(loading)\n  input:setInputHandler(nil)\nend\n\n-- Set current mission\ncurrentMission = mission\ncurrentMissionInput = missionInput\ncurrentMissionScreen = missionScreen\n\n-- Stop menu idle timer\nmenuIdleTimer:pause()\n\n-- Prevent menu interrupt from triggering.\ninterrupt:setInputHandler(nil)"
              }
            ]
