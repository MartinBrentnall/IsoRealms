  <Modules>
    <Module name="Spindizzy">
      <Resources>
        <World name="Hangworld" slopeAcceleration="0.0000265" gravity="-0.0002">
          <DebrisGenerator id="Top" life="2000">
            <Model key="Spindizzy/DebrisChunk/Top" scaleX="0.3" scaleY="0.3" scaleZ="0.3"/>
          </DebrisGenerator>
          <DebrisGenerator id="Ball" life="2000">
            <Model key="Spindizzy/DebrisChunk/Ball" scaleX="0.3" scaleY="0.3" scaleZ="0.3"/>
