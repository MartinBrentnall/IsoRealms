      "Basics": {
        "Float": {
          "instances": {
            "Time Speed": {
              "value": 1.0440000295639039
            }
          },
          "omissions": []
        },
        "Function": {
          "instances": {
            "Handle Zone Entered": {
              "bindings": [
                {
                  "variable": "score",
                  "to": {
                    "key": "Basics/Integer/Score Blah"
                  }
                },
                {
                  "variable": "gameTimeLimit",
                  "to": {
                    "key": "Basics/Sequence/Time Limit/Instance"
                  }
                },
                {
                  "variable": "zoneCount",
                  "to": {
                    "key": "Basics/Integer/RemainingZones"
                  }
                },
                {
                  "variable": "hintIcon",
                  "to": {
                    "key": "UI/Layout/Layout/Hint"
                  }
                },
                {
                  "variable": "themeSet",
                  "to": {
                    "key": "Spindizzy/ThemeSet/C64"
                  }
                },
                {
                  "variable": "topDebris",
                  "to": {
                    "key": "Spindizzy/World/Game World/DebrisGenerator/Top"
                  }
                },
                {
                  "variable": "ballDebris",
                  "to": {
                    "key": "Spindizzy/World/Game World/DebrisGenerator/Ball"
                  }
                },
                {
                  "variable": "gyroscopeDebris",
                  "to": {
                    "key": "Spindizzy/World/Game World/DebrisGenerator/Gyroscope"
                  }
                },
                {
                  "variable": "view",
                  "to": {
                    "key": "Spindizzy/WorldView/Game View"
                  }
                },
                {
                  "variable": "jewelsCollected",
                  "to": {
                    "key": ":Integer",
                    "asset": {
                      "key": "Basics/Integer/JewelCount"
                    }
                  }
                },
                {
                  "variable": "hangworld",
                  "to": {
                    "key": "Spindizzy/World/Game World"
                  }
                },
                {
                  "variable": "ending",
                  "to": {
                    "key": ":Action",
                    "asset": {
                      "key": "Basics/Function/Play Ending",
                      "bindings": []
                    }
                  }
                },
                {
                  "variable": "mandatoryZoneTime",
                  "to": {
                    "key": "Basics/Sequence/Mandatory Zone Time/Instance"
                  }
                },
                {
                  "variable": "spindizzy",
                  "to": {
                    "key": "Spindizzy"
                  }
                },
                {
                  "variable": "currentZoneColour",
                  "to": {
                    "key": ":Colour",
                    "asset": {
                      "key": "Basics/Sequence/Map Current Room/Instance/Colour"
                    }
                  }
                },
                {
                  "variable": "sound",
                  "to": {
                    "key": "Basics/Sequence/DamageSound/Instance"
                  }
                },
                {
                  "variable": "damage",
                  "to": {
                    "key": "Basics/Sequence/DamageVisual/Instance"
                  }
                }
              ],
              "arguments": [],
              "code": "-- Delay entry to the previous zone when leaving too quickly.\nif mandatoryZoneTime:getTime() > 200 or entered ~= previousZone then\n\n  -- Clear all debris from the screen.\n  if entered ~= exitedZone then\n    topDebris:clear()\n    ballDebris:clear()\n    gyroscopeDebris:clear()\n  end\n\n  -- Keep track of the current zone and the previous zone.\n  previousZone = currentZone\n  currentZone = entered\n\n  -- Update timer, score, and overview if this is the first time visiting the zone.\n  -- TODO: Can test colour from zone to determine if visited.\n  if entered:isVisited() == false then\n    zoneCount:setValue(zoneCount:getValue() - 1)\n    local earned = 400\n    local newTime = gameTimeLimit:getTime() - 8000\n    -- Any time to add beyond the 3-minute cap is converted to additional score bonus.\n    if newTime < 0 then\n      local excess = -newTime\n      local extraScore = excess / 10\n      earned = earned + extraScore\n      newTime = 0\n    end\n    gameTimeLimit:setTime(newTime)\n    score:setValue(math.floor(score:getValue() + earned))\n\n    -- Set that the zone has been visited.\n    entered:setVisited()\n  end\n\n  -- Set the colour on the overview to show where we are.\n  enteredColour:setColour(currentZoneColour)\n\n  -- Set the zone to show in our view.\n  view:setZone(entered)\n\n  -- Set the default theme to use in the UI.\n  theme = entered:getTheme()\n  themeSet:setDefaultTheme(theme)\n\n  -- Activate dynamic objects in the zone.\n  entered:resetDynamics()\n  entered:setActive(true)\n\n  -- Update the hint icon\n  if disableHud == nil then\n    local hintCount = currentZone:getHintCount()\n    if hintCount > 0 then\n      currentZone:giveHint(0)\n    else\n      hintIcon:setScreen(nil)\n    end\n  end\n\n  -- Do we show the ending yet?\n  if zoneCount:getValue() == 0 and hangworld:getPickUpCount() == jewelsCollected:getValue() then\n    ending:execute()\n  end\n  mandatoryZoneTime:setTime(0);\nelse\n  -- The entrance delay is implemented by momentarily pausing the game.\n  zoneToEnter = entered\n  spindizzy:setPause(true)\n  gameTimeLimit:pause()\n  if alienContactCount > 0 then\n    sound:pause()\n    damage:pause()\n  end\nend"
            },
            "Play Ending": {
              "bindings": [
                {
                  "variable": "endingSequence",
                  "to": {
                    "key": "Basics/Sequence/Ending/Instance"
                  }
                },
                {
                  "variable": "project",
                  "to": {
                    "key": "Project"
                  }
                },
                {
                  "variable": "endingMessage",
                  "to": {
                    "key": "Basics/String/EndingMessage"
                  }
                },
                {
                  "variable": "scoreMessage",
                  "to": {
                    "key": "Basics/String/ScoreMessage"
                  }
                },
                {
                  "variable": "mappedMessage",
                  "to": {
                    "key": "Basics/String/MappedMessage"
                  }
                },
                {
                  "variable": "jewelsMessage",
                  "to": {
                    "key": "Basics/String/JewelsMessage"
                  }
                },
                {
                  "variable": "completeMessage",
                  "to": {
                    "key": "Basics/String/CompleteMessage"
                  }
                },
                {
                  "variable": "score",
                  "to": {
                    "key": ":Integer",
                    "asset": {
                      "key": "Basics/Integer/Score Blah"
                    }
                  }
                },
                {
                  "variable": "gameTimeLimit",
                  "to": {
                    "key": "Basics/Sequence/Time Limit/Instance"
                  }
                },
                {
                  "variable": "spindizzy",
                  "to": {
                    "key": "Spindizzy"
                  }
                },
                {
                  "variable": "sound",
                  "to": {
                    "key": "Basics/Sequence/DamageSound/Instance"
                  }
                },
                {
                  "variable": "damage",
                  "to": {
                    "key": "Basics/Sequence/DamageVisual/Instance"
                  }
                }
              ],
              "arguments": [],
              "code": "-- Prevent menu access, etc.\nhasFocus = false\n\n-- Set result values\nendingMessage:setValue(\"Map Complete: Mission Success\")\nmappedMessage:setValue(\"100%\")\njewelsMessage:setValue(\"100%\")\ncompleteMessage:setValue(\"100%\")\nscoreMessage:setValue(\"\" .. score:getValue())\n\n-- Pause the game\nspindizzy:setPause(true)\ngameTimeLimit:pause()\nif alienContactCount > 0 then\n  sound:pause()\n  damage:pause()\nend\n\n-- Play the ending\nendingSequence:play()"
            }
          },
          "omissions": []
        },
